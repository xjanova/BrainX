<Application x:Class="BrainX.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                  Neural redesign tokens FIRST — they're referenced by the
                  CyberpunkTheme NavButton + NavButtonActive (which I restyled
                  to use Neural violet brushes). If CyberpunkTheme loaded first,
                  its {StaticResource NeuralText1} etc would resolve to null
                  at load time and the whole NavButton template fails silently
                  → MainWindow never shows. Order: colors → effects →
                  typography → controls → cyberpunk (consumes).
                -->
                <ResourceDictionary Source="Themes/BrainXColors.xaml"/>
                <ResourceDictionary Source="Themes/BrainXEffects.xaml"/>
                <ResourceDictionary Source="Themes/BrainXTypography.xaml"/>
                <ResourceDictionary Source="Themes/BrainXControls.xaml"/>

                <!--
                  Cyberpunk theme — drives the existing MainWindow shell and
                  the un-migrated view templates. Consumes Neural keys for
                  NavButton + NavButtonActive (restyled to match t2.zip).
                -->
                <ResourceDictionary Source="Themes/CyberpunkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
