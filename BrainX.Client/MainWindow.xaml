                            <!-- Mesh online chip (sidebar bottom) per t2.zip screenshot.
                                 Preserves x:Names NetworkDot / NetworkStatusText / PeerCountText so
                                 existing code-behind (RefreshNetworkStats etc) keeps updating them. -->
                            <Border Grid.Row="2" Margin="14,0,14,14" Padding="12,10" CornerRadius="10"
