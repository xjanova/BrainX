<Window x:Class="BrainX.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:services="clr-namespace:BrainX.Client.Services"
        mc:Ignorable="d"
        Title="BrainX — Neural Knowledge Engine"
        Width="1400" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/Logo.ico"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- WindowStyle=None + AllowsTransparency=True strips native chrome,
         which also kills the invisible resize edges. WindowChrome restores
         them via DWM hit-testing without bringing back the Aero title bar.
         CaptionHeight=0 because we have a custom title bar (line 64+) with
         TitleBar_MouseLeftButtonDown for drag-to-move — letting WindowChrome
         claim the caption would double-handle drag. ResizeBorderThickness=6
         gives 6px grabbable on every edge / corner; the user sees the cursor
         flip to ↔ ↕ ⤡ as expected. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0.2" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="RotateBrain" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BrainRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:30"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource NeuralBgBase}"
            BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <!-- Ambient bk2 starfield + violet/cyan glow ellipses hidden per t2.zip
                 screenshots which use a clean near-black violet background (#0a0612).
                 The bk2 texture + glows were tinting the cards with extra nebula and
                 made every screen feel washed-out vs the spec. Kept x:Name +
                 Visibility=Collapsed so future "wallpaper mode" can re-enable them
                 with a single setter flip if requested. -->
            <Image x:Name="WindowBgTexture" Source="pack://application:,,,/Assets/bk2.png"
                   Stretch="UniformToFill" Opacity="0" IsHitTestVisible="False"
                   Visibility="Collapsed"/>
            <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" Opacity="0" Visibility="Collapsed">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource ElectricPurpleColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0" Visibility="Collapsed">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource NeonCyanColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Phase 3 (Universe-as-full-window-bg) reverted: WebView2 is a
                 native HWND that ALWAYS paints over WPF chrome regardless of
                 z-order (Win32 airspace rule). Hosting it at outer level
                 hides sidebar / title bar / status bar → can't navigate or
                 drag. The WebView now lives back inside UniverseView's
                 content cell where it only covers the area where chrome
                 doesn't reach. -->

            <Grid x:Name="RootShellGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TitleBarRow" Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="StatusBarRow" Height="32"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR
                     Phase 1B (partial): swap background to the new neural gradient
                     + add a 1px hairline bottom. Interior controls (hamburger /
                     logo / theme picker / window buttons) keep their cyberpunk
                     skins for now — they'll move to Neural* tokens in a later
                     pass that also restyles the popup and dim sliders.
                     The brand-mark + identity-pill rebuild from the prototype
                     spec is also deferred to that pass. -->
                <Border x:Name="TitleBarBorder" Grid.Row="0"
                        Background="{StaticResource NeuralTitlebarBg}"
                        BorderBrush="{StaticResource NeuralLine}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <!-- Hamburger: collapses the sidebar (SidebarColumn.Width 220 ↔ 0).
                                 Crucial when the sidebar is glass-translucent + sits over Universe —
                                 user may want to hide it entirely. Esc or click again restores. -->
                            <Button x:Name="SidebarToggleBtn" Width="28" Height="28"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Click="SidebarToggle_Click" Margin="0,0,8,0"
                                    ToolTip="Hide / show sidebar menu">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="4" Background="Transparent">
                                            <TextBlock Text="&#x2630;" FontSize="16"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#226CF0FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Title-bar logo — seamless (no frame, no clip) so the glow bleeds into the bg -->
                            <Image Source="pack://application:,,,/Assets/Logo.png"
                                   Width="30" Height="30" Margin="0,0,10,0"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="BrainX" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" — Neural Knowledge Engine" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                       Margin="4,2,0,0"/>
                            <!-- Brain name in parens, populated from code-behind (ex: "(My Brain)") -->
                            <TextBlock x:Name="BrainTitleLabel" Text="" FontSize="11"
                                       Foreground="{StaticResource NeonCyanBrush}"
                                       VerticalAlignment="Center" Margin="8,2,0,0"
                                       FontFamily="{StaticResource MonoFont}"
                                       Cursor="Hand" MouseLeftButtonDown="CopyAddress_Click"
                                       ToolTip="Click to copy brain address"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                            <!-- Theme picker hidden per t2.zip screenshots — titlebar shows
                                 only identity pill + user pill + window controls. Theme +
                                 dim sliders are accessible from Settings view (future) or via
                                 keyboard shortcut. Visibility=Collapsed keeps the x:Name +
                                 handler binding intact for ThemeButton_Click to be callable
                                 programmatically if needed. -->
                            <Button x:Name="ThemeButton" Width="40" Height="28"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Visibility="Collapsed"
                                    ToolTip="UI theme + background dim"
                                    Click="ThemeButton_Click" Margin="4,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="6,2"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource SurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F3A8;" FontSize="13" Margin="0,0,2,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Theme" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NeonCyanBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=ThemeButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                   HorizontalOffset="-220" VerticalOffset="4">
                                <Border Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="10" MinWidth="280">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                          BlurRadius="22" Opacity="0.55" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="UI COLOR THEME" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Margin="2,0,0,8"/>
                                        <ItemsControl x:Name="ThemeList">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <Border Margin="0,8,0,0" Padding="0,8,0,0"
                                                BorderBrush="{StaticResource SurfaceLightBrush}"
                                                BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <TextBlock Text="BACKGROUND DIM" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Margin="2,0,0,6"/>

                                                <Grid Margin="2,0,2,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Brain graph" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="GraphBgDimSlider"
                                                            Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                                            Value="0.55" ValueChanged="GraphBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="GraphBgDimLabel" Text="55%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>

                                                <Grid Margin="2,0,2,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Dashboard 3D" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="DashBgDimSlider"
                                                            Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                                            Value="0.55" ValueChanged="DashBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="DashBgDimLabel" Text="55%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>

                                                <Grid Margin="2,0,2,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Window texture" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="WindowBgDimSlider"
                                                            Minimum="0" Maximum="0.5" SmallChange="0.02" LargeChange="0.05"
                                                            Value="0.09" ValueChanged="WindowBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="WindowBgDimLabel" Text="9%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Window-chrome buttons: inline templates because the global
                                 NavButton style is built for sidebar nav (Margin=10,1 +
                                 Padding=14,9) and clips the glyph inside a 36x28 button —
                                 user: "ปุ่ม mini max ไม่เห็น" (2026-05-27 screenshot). -->
                            <Button Content="—" Click="Minimize_Click" Width="36" Height="28"
                                    FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Minimize">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="36" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="□" Click="Maximize_Click" Width="36" Height="28"
                                    FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Maximize / Restore">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="36" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="✕" Click="Close_Click" Width="36" Height="28"
                                    FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Close">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="36" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MAIN CONTENT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR (Neural redesign — Phase 1B)
                         Background → NeuralSidebarBg (#14102a → #0e0a22 violet gradient
                         matching the design handoff spec). Right edge → NeuralLine
                         (subtle 8% violet hairline, replaces the loud cyan glow gradient).
                         Width stays at 220 px for now; bumping to 240 per the spec is a
                         later commit alongside the brand-crest + nav-item migration. -->
                    <Border x:Name="SidebarBorder" Grid.Column="0"
                            Background="{StaticResource NeuralSidebarBg}"
                            BorderBrush="{StaticResource NeuralLine}"
                            BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Brand crest — circle (NO rectangle container). User: "รูป
                                 โลโก้ Zoom อีก / ต้องเป็นอนิเมชั่น rgb / และไม่ต้อง
                                 มีแสงเรืองรอบๆ". Three changes from fc71334:
                                   1. Removed the 190 px outer halo Ellipse + the
                                      DropShadowEffect on the disc — no glow around.
                                   2. Brain Image enlarged 90 → 130 px (fills the circle
                                      now, with the BRAINX wordmark prominent).
                                   3. Both rainbow rings now ROTATE forever via
                                      RotateTransform + Storyboard on Loaded. Outer ring
                                      rotates clockwise 8 s/turn; inner ring rotates
                                      counter-clockwise 6 s/turn. The diagonal linear
                                      gradient sweeping around a circle = animated RGB
                                      iridescence. -->
                            <Grid Grid.Row="0" Margin="0,16,0,10" HorizontalAlignment="Center">
                                <!-- The CIRCLE itself — 168 px disc clipped to round.
                                     No DropShadowEffect (user: no glow around). -->
                                <Border Width="168" Height="168" CornerRadius="84"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5"
                                                             RadiusX="0.95" RadiusY="0.95">
                                            <GradientStop Color="#1A1535" Offset="0"/>
                                            <GradientStop Color="#0A0820" Offset="0.7"/>
                                            <GradientStop Color="#060410" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <!-- Layer 1: Outer RGB fire ring — ROTATING. -->
                                        <Ellipse Width="160" Height="160" StrokeThickness="3.5"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.Stroke>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF2D3E" Offset="0"/>
                                                    <GradientStop Color="#FF8A2D" Offset="0.18"/>
                                                    <GradientStop Color="#FFD23C" Offset="0.33"/>
                                                    <GradientStop Color="#4AE3A7" Offset="0.5"/>
                                                    <GradientStop Color="#5BE9E9" Offset="0.66"/>
                                                    <GradientStop Color="#9D7BFF" Offset="0.83"/>
                                                    <GradientStop Color="#FF4F9E" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Stroke>
                                            <Ellipse.RenderTransform>
                                                <RotateTransform x:Name="CrestRingOuter" Angle="0"/>
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CrestRingOuter"
                                                                Storyboard.TargetProperty="Angle"
                                                                From="0" To="360" Duration="0:0:8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <!-- Layer 2: Inner ring — ROTATING THE OTHER WAY. -->
                                        <Ellipse Width="140" Height="140" StrokeThickness="1.4" Opacity="0.7"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.Stroke>
                                                <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                                    <GradientStop Color="#FF4F9E" Offset="0"/>
                                                    <GradientStop Color="#9D7BFF" Offset="0.2"/>
                                                    <GradientStop Color="#5BE9E9" Offset="0.4"/>
                                                    <GradientStop Color="#4AE3A7" Offset="0.6"/>
                                                    <GradientStop Color="#FFD23C" Offset="0.8"/>
                                                    <GradientStop Color="#FF6A2D" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Stroke>
                                            <Ellipse.RenderTransform>
                                                <RotateTransform x:Name="CrestRingInner" Angle="0"/>
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CrestRingInner"
                                                                Storyboard.TargetProperty="Angle"
                                                                From="360" To="0" Duration="0:0:6"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <!-- Layer 3: Brain — ZOOMED IN (90 → 130 px). -->
                                        <Image Source="pack://application:,,,/Assets/Logo.png"
                                               Stretch="Uniform" Width="130" Height="130"
                                               Opacity="0.92"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.OpacityMask>
                                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#FFFFFFFF" Offset="0.75"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Image.OpacityMask>
                                        </Image>
                                        <!-- Dummy 0-size PulseRing for animation compat. -->
                                        <Ellipse x:Name="PulseRing" Width="0" Height="0" Opacity="0"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Nav -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly">
                                <StackPanel Margin="0,8,0,8">
                                    <!-- ═══════════════════════════════════════════════════════════
                                         SIDEBAR NAV — restored to v2.0.96 menu structure per user
                                         "เมนูเราต้องเหมือนเดิม เปลี่ยน แต่ ui สิยึดเมนูรุ่น 2.0.96".
                                         Only UI styling changes (background / cards / fonts) — menu
                                         layout, order, item labels, and visibility ALL match v2.0.96.
                                         ═══════════════════════════════════════════════════════════ -->
                                    <TextBlock Text="WORKSPACE" Style="{StaticResource TypeNavSectionLabel}"
                                               Margin="22,8,0,8"/>
                                    <!-- Dashboard restored to the menu + default active view per
                                         user "เพิ่ม หน้า dashboard". Each row now uses a 2-col
                                         Grid (label | kbd chip) per t2.zip screenshot. The kbd
                                         chip is a small NeuralBgInset pill on the right edge. -->
                                    <Button x:Name="NavDashboard" Style="{StaticResource NavButtonActive}"
                                            Click="Nav_Click" Tag="Dashboard">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x2B21;  Dashboard"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#22FFFFFF"
                                                    BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                    CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                                                <TextBlock Text="&#x2318;1" FontSize="10.5"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="#CCFFFFFF"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="NavUniverse" Style="{StaticResource NavButton}"
                                            Click="Nav_Click" Tag="Universe">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x1F30C;  Universe"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="{StaticResource NeuralBgInset}"
                                                    BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                    CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                                                <TextBlock Text="&#x2318;2" FontSize="10.5"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource NeuralTextDim}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="NavBrainGraph" Content="&#x25C9;  Brain Graph"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="BrainGraph"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="NavNetwork" Content="&#x2B22;  Network"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Network"/>
                                    <TextBlock Text="VAULT" Style="{StaticResource TypeNavSectionLabel}"
                                               Margin="22,18,0,8"/>
                                    <Button x:Name="NavEditor" Style="{StaticResource NavButton}"
                                            Click="Nav_Click" Tag="Editor">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x270F;  Editor"
