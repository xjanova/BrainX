                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Column="1">
                        <!-- Dashboard — default startup (per user "เพิ่ม หน้า dashboard").
                             KPI cards + Activity Feed + Recently Edited inside. -->
                        <Grid x:Name="DashboardView" Visibility="Visible">
                            <!-- Hidden WebView2 used by ClaudeUsageProbe to scrape
                                 claude.ai/settings/usage. 1×1, transparent, hit-test
                                 off — present in the visual tree so its HwndHost
                                 stays alive, but invisible to the user. Cookies
                                 from Edge are injected into its CookieManager on
                                 startup so navigation auto-authenticates. -->
                            <wv2:WebView2 x:Name="DashClaudeProbeWebView"
                                          Width="1" Height="1"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Left" VerticalAlignment="Top"
                                          Panel.ZIndex="-1"/>
                            <!-- Layout: NO outer ScrollViewer (DashOuterScroll removed 2026-05-27).
                                 WebView2 = HwndHost; a parent ScrollViewer's transform does NOT
                                 translate the Win32 child surface — universe stayed pinned to its
                                 original screen position and painted UP past the titlebar when the
                                 user scrolled down (user: "universe ทะลุไปด้านบนเมื่อสกอร์ลงมา
                                 เยอะ"). Restored to a pure Grid; only the bottom row (Pro Insights
                                 + Quick Actions) gets an inner ScrollViewer where airspace doesn't
                                 matter — no WebView2 in that row. -->
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>                      <!-- header -->
                                    <RowDefinition Height="Auto"/>                      <!-- (collapsed) -->
                                    <RowDefinition Height="1.5*" MinHeight="320"/>      <!-- map row (universe + right col) -->
                                    <RowDefinition Height="1*" MinHeight="200"/>        <!-- pro insights + quick actions (scrollable) -->
                                </Grid.RowDefinitions>
                                <!-- View header — Row 0 -->
                                <Grid Grid.Row="0" Margin="0,0,0,22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Dashboard" Style="{StaticResource TypeViewTitle}"/>
                                            <TextBlock Text="Your neural knowledge overview · auto-ingested 4 minutes ago"
                                                       Style="{StaticResource TypeViewSubtitle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <Button Style="{StaticResource NeuralBtnGhost}"
                                                    Click="ReindexVault_Click" Margin="0,0,10,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x21BB;" FontSize="14" Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource NeuralBtnPrimary}"
                                                    Click="Nav_Click" Tag="Editor">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x002B;" FontSize="14" FontWeight="Bold"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="New note" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- KPI Row 1 — REMOVED. User: "ให้ universe สูงสุด แทนบล๊อก
                                         knowledge node และ total words เพราะมีบอกในนั้นแล้ว".
                                         Universe overlay already shows Notes/Words/Wiki-links/
                                         Galaxies in its top-left tile, so the two redundant KPI
                                         cards (KNOWLEDGE NODES + TOTAL WORDS) are removed. The
                                         row collapses to 0 height because the hidden container
                                         below has Visibility=Collapsed.
                                         CONNECTIONS + EXPERTISE AREAS moved to the top of the
                                         right column (just above Activity Feed) so they remain
                                         visible. StatNotes/StatWords/*Delta x:Names kept as
                                         zero-size dummies so the existing UpdateDashStats code
                                         in MainWindow.xaml.cs that writes to them stays valid. -->
                                    <StackPanel Grid.Row="1" Visibility="Collapsed">
                                        <TextBlock x:Name="StatNotes"/>
                                        <TextBlock x:Name="StatNotesDelta"/>
                                        <TextBlock x:Name="StatWords"/>
                                        <TextBlock x:Name="StatWordsDelta"/>
                                    </StackPanel>

                                    <!-- DASH-GRID — Row 2 (* — fills remaining height).
                                         2 columns (1.6fr Neural Map · 1fr Activity + Recent).
                                         MinHeight on RowDefinition (not on the Border child) so
                                         the row itself reserves at least 340 px for the universe
                                         when the window is squeezed — and the Grid honors that
                                         constraint without letting the universe paint over Row 3.
                                         MinWidth on the universe ColumnDefinition guarantees a
                                         420 px viewport even when the user narrows the window. -->
                                    <Grid Grid.Row="2" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.6*" MinWidth="420"/>
                                            <ColumnDefinition Width="*" MinWidth="280"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                Margin="0,0,8,0" Padding="0"
                                                MinHeight="320">
                                        <!-- MinHeight here is REQUIRED again now that Row 2 is Auto
                                             (was *). With Auto sizing the Row no longer reserves
                                             space; the Border MUST self-size or the WebView2
                                             collapses to 0. The earlier "overflow into Row 3"
                                             bug from putting MinHeight here is no longer a risk
                                             because the outer ScrollViewer wraps the inner Grid
                                             — if total content > viewport it scrolls, doesn't
                                             paint into adjacent rows. -->
                                        <!-- MinHeight + MinWidth previously here caused the Border
                                             to OVERFLOW into Row 3's cell space (user screenshot:
                                             "กลายเป็นทับคนอื่นไป") because WPF Grid doesn't clip
                                             children to cell bounds. Constraints moved to the
                                             RowDefinition + ColumnDefinition above so the Grid
                                             respects them at layout-pass time and never lets the
                                             universe encroach on Row 3 (Pro Insights strip).
                                             — Reinstated on 2026-05-27 with safer ScrollViewer
                                             wrapper so the older overflow problem doesn't return. -->
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Hidden 3D/2D toggle (kept off-screen so the toggle handlers
                                                 + Tag wiring stay valid for code-behind that flips
                                                 DashView3DBorder/DashView2DBorder/DashUniverseBorder
                                                 visibility). User removed the entire header bar. -->
                                            <StackPanel Visibility="Collapsed">
                                                <Button x:Name="DashView3DBtn" Tag="3D" Click="DashViewMode_Click"/>
                                                <Button x:Name="DashView2DBtn" Tag="2D" Click="DashViewMode_Click"/>
                                                <TextBlock x:Name="DashHintText" Text=""/>
                                            </StackPanel>

                                            <!-- Map area: Universe fills the whole card edge-to-edge. The
                                                 RGB glow ring is the animated layer right behind the
                                                 universe disc (Layer 0). -->
                                            <Grid Grid.Row="0" Margin="0">
                                                <!-- ▼ LAYER 0 — Subtle animated RGB glow BEHIND the universe.
                                                     A 1.4 px gradient border ring on a slightly inset rectangle,
                                                     animated via RotateTransform on the gradient brush so the
                                                     colors sweep around the card. Inside is invisible (Transparent
                                                     fill); only the border shows. The RotateTransform on
                                                     LinearGradientBrush.Transform makes the gradient angle
                                                     animate without rotating the geometry. -->
                                                <Border CornerRadius="15" BorderThickness="1.4"
                                                        IsHitTestVisible="False">
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <LinearGradientBrush.GradientStops>
                                                                <GradientStop Color="#66FF2D3E" Offset="0"/>
                                                                <GradientStop Color="#66FF8A2D" Offset="0.18"/>
                                                                <GradientStop Color="#66FFD23C" Offset="0.33"/>
                                                                <GradientStop Color="#664AE3A7" Offset="0.5"/>
                                                                <GradientStop Color="#665BE9E9" Offset="0.66"/>
                                                                <GradientStop Color="#669D7BFF" Offset="0.83"/>
                                                                <GradientStop Color="#66FF4F9E" Offset="1"/>
                                                            </LinearGradientBrush.GradientStops>
                                                            <LinearGradientBrush.RelativeTransform>
                                                                <RotateTransform x:Name="DashGlowRotate"
                                                                                 CenterX="0.5" CenterY="0.5" Angle="0"/>
                                                            </LinearGradientBrush.RelativeTransform>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.Effect>
                                                        <BlurEffect Radius="3"/>
                                                    </Border.Effect>
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetName="DashGlowRotate"
                                                                        Storyboard.TargetProperty="Angle"
                                                                        From="0" To="360" Duration="0:0:12"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                </Border>
                                                <Border x:Name="DashView3DBorder" CornerRadius="14" ClipToBounds="True"
                                                        Margin="3"
                                                        Visibility="Collapsed"
                                                        MouseLeftButtonDown="Viewport_MouseDown"
                                                        MouseLeftButtonUp="Viewport_MouseUp"
                                                        MouseMove="Viewport_MouseMove"
                                                        MouseWheel="Viewport_MouseWheel"
                                                        MouseRightButtonDown="Viewport_RightClick">
                                                    <Border.Background>
                                                        <ImageBrush x:Name="DashBgBrush"
                                                                    ImageSource="pack://application:,,,/Assets/bk1.png"
                                                                    Stretch="UniformToFill" Opacity="0.55"/>
                                                    </Border.Background>
                                                    <Viewport3D x:Name="BrainViewport" ClipToBounds="True"
                                                                IsHitTestVisible="False">
                                                        <Viewport3D.Camera>
                                                            <PerspectiveCamera x:Name="DashCam" Position="0,2,10"
                                                                               LookDirection="0,-0.2,-1"
                                                                               UpDirection="0,1,0" FieldOfView="45"/>
                                                        </Viewport3D.Camera>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <AmbientLight Color="#333355"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <DirectionalLight x:Name="DashKeyLight" Color="#00F0FF" Direction="-1,-1,-1"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <DirectionalLight x:Name="DashFillLight" Color="#8B5CF6" Direction="1,0.5,-0.5"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D x:Name="BrainModel"/>
                                                    </Viewport3D>
                                                </Border>

                                                <!-- Dashboard Universe embed — user spec evolved to
                                                     "ไม่มีตัวหนังสือบัง · ตั้งค่าไม่ได้ · ลากเลื่อนได้ด้วยเม้า".
                                                     Loads the same three.js scene the main Brain Graph uses
                                                     but with `?cameraMode=orbit&mode=wallpaper-active` →
                                                     camera auto-orbits, ALL HUD (settings panel, info card,
                                                     legend, token chip, hud-top/bottom) hidden via the
                                                     wallpaper-active body class, but pointer-events stay
                                                     enabled so OrbitControls handles user drag/zoom. Also
                                                     inherits the wallpaper's appearance settings (glow,
                                                     lightning, background) — see Dashboard universe inherits
                                                     wallpaper appearance via storage event. -->
                                                <Border x:Name="DashUniverseBorder" CornerRadius="14" ClipToBounds="True"
                                                        Margin="3" Background="#FF0a0612">
                                                    <!-- IsHitTestVisible=True so mouse drag/wheel reach the
                                                         WebView2 → OrbitControls inside scene.js handles
                                                         orbit/zoom. The wallpaper-active CSS class hides every
                                                         HUD/setting so no text overlays cover the universe,
                                                         per user spec "ไม่มีตัวหนังสือบัง · ตั้งค่าไม่ได้ ·
                                                         เลื่อนได้ด้วยเม้า". -->
                                                    <wv2:WebView2 x:Name="DashUniverseWebView"
                                                                  DefaultBackgroundColor="Black"
                                                                  IsHitTestVisible="True"/>
                                                </Border>

                                                <!-- Legacy 2D primary view — hidden; replaced by the
                                                     Universe WebView2 above. Kept in tree because
                                                     Dash2D_* handlers + DashGraph2D renderer init are
                                                     wired in code-behind. -->
                                                <Border x:Name="DashView2DBorder" CornerRadius="14" ClipToBounds="True"
                                                        Margin="3" Visibility="Collapsed"
                                                        MouseLeftButtonDown="Dash2D_MouseDown"
                                                        MouseLeftButtonUp="Dash2D_MouseUp"
                                                        MouseMove="Dash2D_MouseMove"
                                                        MouseWheel="Dash2D_MouseWheel"
                                                        MouseRightButtonDown="Dash2D_RightClick">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="pack://application:,,,/Assets/bk1.png"
                                                                    Stretch="UniformToFill" Opacity="0.35"/>
                                                    </Border.Background>
                                                    <services:Graph2DRenderer x:Name="DashGraph2D"/>
                                                </Border>

                                                <!-- Glassmorphism Expertise overlay: top-right of map, scrollable.
                                                     Faux-glass = translucent gradient + subtle white border + drop
                                                     shadow. WPF has no native backdrop blur, but the bk1 nebula
                                                     visible through the alpha sells the effect. -->
                                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="0,16,16,16" Width="320" MaxHeight="460"
                                                        CornerRadius="14" Padding="0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Offset="0" Color="#55101820"/>
                                                            <GradientStop Offset="1" Color="#33060A10"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                            <GradientStop Offset="1" Color="#11FFFFFF"/>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                                          Color="#000000" Opacity="0.45"/>
                                                    </Border.Effect>
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  Padding="16" CanContentScroll="False"
                                                                  PanningMode="VerticalOnly">
                                                        <StackPanel>
                                                            <TextBlock Text="EXPERTISE PROFILE" FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Margin="0,0,0,12"/>
                                                            <StackPanel x:Name="ExpertisePanel"/>
                                                            <Border Margin="0,16,0,0" Padding="10" CornerRadius="8"
                                                                    Background="#33000000">
                                                                <StackPanel>
                                                                    <TextBlock Text="BRAIN ADDRESS" FontSize="9"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Margin="0,0,0,4"/>
                                                                    <TextBlock x:Name="FullAddressText" Text="0xBRAIN-..."
                                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="VAULT PATH" FontSize="9"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Margin="0,8,0,4"/>
                                                                    <TextBlock x:Name="VaultPathText" Text="..."
                                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>

                                                <!-- Chips MOVED to DOM (wwwroot/universe/index.html + style.css
                                                     + app.js: handleDashStats / handleDashLoad / drawDashSpark).
                                                     WPF Border children of this Grid kept getting clobbered
                                                     by the WebView2 HwndHost surface, and WPF Popup leaked
                                                     above other apps (bleed-through). The DOM is the only
                                                     surface that ALWAYS composites correctly with the
                                                     WebView2's three.js canvas. C# pushes values via
                                                     PostDashStats / PostDashLoad → PostWebMessageAsJson.
                                                     Dummy x:Name nodes kept (Visibility=Collapsed, 0 size)
                                                     so any leftover code-behind writes don't NPE. -->
                                                <Border Visibility="Collapsed" Width="0" Height="0">
                                                    <StackPanel>
                                                        <TextBlock x:Name="DashOvNodesText"/>
                                                        <TextBlock x:Name="DashOvWordsText"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- LOAD chip MOVED to DOM. The Border below is a 0-size
                                                     shell that keeps the x:Names alive for any code-behind
                                                     write that hasn't been re-routed through PostDashLoad yet.
                                                     Once everything writes via PostDashLoad these dummies can
                                                     come out — but until then they prevent NPEs in callers. -->
                                                <Border Visibility="Collapsed" Width="0" Height="0"
                                                        IsHitTestVisible="False">
                                                    <StackPanel>
                                                        <Ellipse x:Name="DashLoadDot" Width="0" Height="0"/>
                                                        <TextBlock x:Name="DashLoadSubtitleText" Text="last 90 s"/>
                                                        <TextBlock x:Name="DashGpuValueText" Text="0%"/>
                                                        <TextBlock x:Name="DashCpuValueText" Text="0%"/>
                                                        <Canvas x:Name="DashGpuSparkCanvas" Width="0" Height="0"/>
                                                        <Canvas x:Name="DashCpuSparkCanvas" Width="0" Height="0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                                <!-- Node Info Panel (shows on click) -->
                                                <!-- Auto-hides after 15s idle · Close with × · Edit & save inline -->
                                                <Border x:Name="NodeInfoPanel" Grid.Row="1" Visibility="Collapsed"
                                                        Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                                        Padding="14,10" Margin="0,8,0,0" MaxHeight="260"
                                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                                        MouseEnter="NodeInfoPanel_MouseEnter"
                                                        MouseLeave="NodeInfoPanel_MouseLeave">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse x:Name="NodeInfoDot" Width="10" Height="10"
                                                                     Fill="{StaticResource NeonCyanBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock x:Name="NodeInfoTitle" Text="" FontSize="13"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                <TextBlock x:Name="NodeInfoDetail" Text="" FontSize="10"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Button Content="&#x26A1; Kick" Style="{StaticResource NeuralBtnGhost}"
                                                                        Padding="10,4" FontSize="11" Click="KickNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeEditBtn" Content="&#x270E; Edit"
                                                                        Style="{StaticResource NeuralBtnGhost}"
                                                                        Padding="10,4" FontSize="11" Click="EditDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeSaveBtn" Content="&#x1F4BE; Save"
                                                                        Style="{StaticResource NeuralBtnPrimary}"
                                                                        Visibility="Collapsed"
                                                                        Padding="10,4" FontSize="11" Click="SaveDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeCancelBtn" Content="Cancel"
                                                                        Style="{StaticResource NeuralBtnGhost}"
                                                                        Visibility="Collapsed"
                                                                        Padding="10,4" FontSize="11" Click="CancelDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button Content="&#x1F4D6; Open" Style="{StaticResource NeuralBtnPrimary}"
                                                                        Padding="10,4" FontSize="11" Click="OpenDashNodeFile_Click" Margin="0,0,4,0"/>
                                                                <Button Content="&#x2715;" Style="{StaticResource NeuralBtnGhost}"
                                                                        Padding="8,4" FontSize="11" ToolTip="Close"
                                                                        Click="CloseDashNode_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- Content Preview / Editor -->
                                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                                            <ScrollViewer x:Name="NodeInfoContentScroll" MaxHeight="160"
                                                                          VerticalScrollBarVisibility="Auto">
                                                                <TextBlock x:Name="NodeInfoContent" Text="" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                            </ScrollViewer>
                                                            <TextBox x:Name="NodeInfoEditor" Visibility="Collapsed"
                                                                     MinHeight="160" MaxHeight="220"
                                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     FontFamily="{StaticResource MonoFont}"
                                                                     Style="{StaticResource NeonTextBox}"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- end Map Border (Grid.Column=0). Right column below. -->

                                        <!-- ═══════════════════════════════════════════════════════════
                                             RIGHT COLUMN (Grid.Column=1)
                                             Activity Feed (top) + Recently Edited (bottom). New from the
                                             prototype right-rail; bound via DashActivityList +
                                             DashRecentNotesList in MainWindow.Dashboard.cs.
                                             ═══════════════════════════════════════════════════════════ -->
                                        <!-- RIGHT COLUMN: 3-row Grid (KPIs Auto · Activity 3* ·
                                             Recently 2*) so the Activity Feed CANNOT push the
                                             Recently Edited card off-screen. Each scrolling card
                                             handles its own overflow internally with its own
                                             ScrollViewer. Previously the column was a StackPanel
                                             in a ScrollViewer, and as the live access-log streamed
                                             rows into DashActivityList (cap 60) the feed card
                                             ballooned and pushed the Recently card below the fold
                                             — user: "activity feed มันดันจน การ์ด recently
                                             หายไปผู้ใช้ไม่รู้ถ้าไม่สกรอ". -->
                                        <Grid Grid.Column="1" Margin="8,0,0,0" MinHeight="320">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="3*" MinHeight="160"/>
                                                <RowDefinition Height="2*" MinHeight="120"/>
                                            </Grid.RowDefinitions>
                                            <!-- ── KPI mini-strip (Connections + Expertise) ──────────────
                                                 Moved here from the old Row 1 KPI band so the Universe
                                                 (Col 0) can extend up to the header and become the
                                                 tallest element on the dashboard. Compact 2-col layout. -->
                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                        Padding="16,12,16,14" Margin="0,0,5,0">
                                                    <StackPanel>
                                                        <TextBlock Text="CONNECTIONS" Style="{StaticResource TypeKpiLabel}"
                                                                   FontSize="10"/>
                                                        <TextBlock x:Name="StatLinks" Text="0"
                                                                   FontSize="26" FontWeight="Bold"
                                                                   Foreground="{StaticResource NeuralText}"
                                                                   Typography.NumeralAlignment="Tabular"
                                                                   Margin="0,4,0,4"/>
                                                        <TextBlock x:Name="StatLinksTrend"
                                                                   Text="20 wiki · 2,704 auto"
                                                                   FontSize="10.5"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                                        Padding="16,12,16,14" Margin="5,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="EXPERTISE AREAS" Style="{StaticResource TypeKpiLabel}"
                                                                   FontSize="10"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4"
                                                                    VerticalAlignment="Bottom">
                                                            <TextBlock x:Name="StatCategories" Text="0"
                                                                       FontSize="26" FontWeight="Bold"
                                                                       Foreground="{StaticResource NeuralText}"
                                                                       Typography.NumeralAlignment="Tabular"/>
                                                            <TextBlock Text=" /24" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource NeuralText3}"
                                                                       VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                                        </StackPanel>
                                                        <TextBlock x:Name="StatCategoriesTrend"
                                                                   Text="4 above 80% mastery"
                                                                   FontSize="10.5"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <!-- ── Activity Feed card ─────────────────────────────────── -->
                                            <!-- MaxHeight tuned to keep Row 2 (universe + right col) inside
                                                 the default viewport. Old DashOuterScroll context (which
                                                 measured Infinity) is gone, but the * sizing still works
                                                 fine and we keep the cap conservative so first paint shows
                                                 universe + Activity preview + Recently preview without
                                                 scrolling the dashboard at all. -->
                                            <Border Grid.Row="1" Style="{StaticResource NeuralCard}" Margin="0,0,0,12"
                                                    MaxHeight="220">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- card-head -->
                                                    <Grid Grid.Row="0" Margin="18,14,18,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="ACTIVITY FEED"
                                                                   Style="{StaticResource TypeCardTitle}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text=" · live"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Column="3" Style="{StaticResource NeuralTagAccent}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="6" Height="6" CornerRadius="3"
                                                                        Background="{StaticResource NeuralMint}"
                                                                        Effect="{StaticResource GlowMint}"
                                                                        VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <TextBlock Text="Mesh online" FontSize="11.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource NeuralViolet2}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                    <!-- divider -->
                                                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                                            Background="{StaticResource NeuralLine}"/>
                                                    <!-- activity-list (bound to DashActivityList).
                                                         Internal scroll is now Auto — the card lives in a
                                                         3* row of the right-column Grid, so growth is capped
                                                         and the user can scroll WITHIN this card without
                                                         pushing Recently Edited off the page. -->
                                                    <ScrollViewer Grid.Row="1"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  Padding="0,4"
                                                                  PanningMode="VerticalOnly"
                                                                  CanContentScroll="False">
                                                        <ItemsControl x:Name="DashActivityList">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="64"/>
                                                                            <ColumnDefinition Width="42"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding Time}"
                                                                                   Style="{StaticResource TypeMonoSmall}"
                                                                                   Margin="18,12,0,12"
                                                                                   VerticalAlignment="Top"/>
                                                                        <Border Grid.Column="1"
                                                                                Background="{Binding KindBrush}"
                                                                                CornerRadius="4"
                                                                                Width="32" Height="16"
                                                                                Margin="0,14,0,0"
                                                                                VerticalAlignment="Top"
                                                                                HorizontalAlignment="Left">
                                                                            <TextBlock Text="{Binding KindLabel}"
                                                                                       FontSize="9"
                                                                                       FontWeight="ExtraBold"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontFamily="{StaticResource FontMono}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Message}"
                                                                                   FontSize="13"
                                                                                   Foreground="{StaticResource NeuralText1}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="10,12,18,12"
                                                                                   LineHeight="18"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>

                                            <!-- ── Recently Edited card ───────────────────────────────── -->
                                            <!-- Cap to keep dashboard first paint clean. -->
                                            <Border Grid.Row="2" Style="{StaticResource NeuralCard}"
                                                    MaxHeight="160">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="18,14,18,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="RECENTLY EDITED"
                                                                   Style="{StaticResource TypeCardTitle}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" x:Name="DashRecentCountText"
                                                                   Text=" · 0 notes"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Button Grid.Column="3" Content="See all"
                                                                Style="{StaticResource NeuralBtnGhost}"
                                                                Height="26" Padding="10,0" FontSize="12"
                                                                Tag="Vault" Click="Nav_Click"/>
                                                    </Grid>
                                                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                                            Background="{StaticResource NeuralLine}"/>
                                                    <!-- Wrap the recently-edited list in its own ScrollViewer so
                                                         it doesn't overflow when its row is squeezed small. -->
                                                    <ScrollViewer Grid.Row="1"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  PanningMode="VerticalOnly"
                                                                  CanContentScroll="False">
                                                    <ItemsControl x:Name="DashRecentNotesList"
                                                                  Margin="6,4,6,10">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="8" Padding="10,9" Margin="0,1"
                                                                        Background="Transparent">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="14"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Width="10" Height="10"
                                                                                CornerRadius="5"
                                                                                Background="{Binding CategoryBrush}"
                                                                                VerticalAlignment="Top"
                                                                                Margin="0,5,0,0"/>
                                                                        <StackPanel Grid.Column="1" Margin="10,0,8,0">
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontSize="13.5"
                                                                                       FontWeight="Medium"
                                                                                       Foreground="{StaticResource NeuralText}"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding Meta}"
                                                                                       FontSize="11.5"
                                                                                       Foreground="{StaticResource NeuralText3}"
                                                                                       Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding WordsLabel}"
                                                                                   FontFamily="{StaticResource FontMono}"
                                                                                   FontSize="11.5"
                                                                                   Foreground="{StaticResource NeuralText2}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <!-- end DASH-GRID 2-col -->

                                    <!-- ═══════════════════════════════════════════════════════════
                                         PRO INSIGHTS STRIP — Row 3
                                         4 dense cards giving a "god-tier" knowledge dashboard read
                                         (user: "อยากให้รายละเอียดแดชบอร์ดเยอะครบถ้วนกว่านี้ แบบ
                                         มืออาชีพ ตัวเล็กอัดแน่นไม่เป็นไร"). Cards LTR:
                                           A · Expertise Profile — top 6 categories with % bars
                                           B · Top Tags — pill cloud, 12 tags by frequency
                                           C · MCP Activity 24 h — sparkline + total + top tool
                                           D · System Health — vault / DB / AI / peers / version
                                         All four populate from code-behind via x:Names. The Universe
                                         row above is unchanged (user: "universe เท่าเดิม").
                                         ═══════════════════════════════════════════════════════════ -->
                                    <!-- Row 3 now bundles Pro Insights + Quick Actions inside a single
                                         ScrollViewer because they're the only rows the dashboard CAN scroll
                                         safely (no WebView2 = no HwndHost airspace). Scrollbar visibility
                                         set to Visible (not Auto) so users see right away that the section
                                         can be scrolled — addresses user's "ทำไงให้ผู้ใช้รู้ว่าสกรอร์
                                         ลงได้". -->
                                    <ScrollViewer Grid.Row="3"
                                                  VerticalScrollBarVisibility="Visible"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False"
                                                  PanningMode="VerticalOnly"
                                                  Padding="0,0,4,0">
                                    <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ▼ CARD A — EXPERTISE PROFILE ▼ -->
                                        <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                Padding="16,14,16,14" Margin="0,0,7,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="EXPERTISE PROFILE" Style="{StaticResource TypeCardTitle}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="DashExpertiseCountText" Text=" · top 6"
                                                               FontSize="11" Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" x:Name="DashExpertiseSummaryText"
                                                           Text="—" FontSize="11" Margin="0,3,0,10"
                                                           Foreground="{StaticResource NeuralText3}"/>
                                                <ItemsControl Grid.Row="2" x:Name="DashExpertiseList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3,0,3">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Width="7" Height="7" CornerRadius="3.5"
                                                                            Background="{Binding CategoryBrush}"
                                                                            VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                               FontSize="11.5" FontWeight="Medium"
                                                                               Foreground="{StaticResource NeuralText1}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding PercentLabel}"
                                                                               FontSize="11" FontFamily="{StaticResource FontMono}"
                                                                               Foreground="{StaticResource NeuralText2}"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Border Grid.Row="1" Height="3" CornerRadius="2"
                                                                        Background="{StaticResource NeuralBgInset}"
                                                                        Margin="0,3,0,0">
                                                                    <Border Width="{Binding BarWidth}" Height="3"
                                                                            CornerRadius="2"
                                                                            HorizontalAlignment="Left"
                                                                            Background="{Binding CategoryBrush}"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>

                                        <!-- ▼ CARD B — NETWORK (Join Brain connection status) ▼
                                             User: "ส่วนการ์ด system load ก็แทนด้วยข้อมูลอื่น เช่น
                                             network join connect status". GPU + CPU sparklines
                                             moved to a floating overlay over the universe (see
                                             DashGpuSparkCanvas / DashCpuSparkCanvas above).
                                             This card now surfaces Join-Brain state: connection
                                             status, peer count, status dot. Updated by C# from
                                             NetworkClient.StatusChanged / PeerCountChanged via
                                             new x:Names DashNetStatusText / DashNetPeersText /
                                             DashNetDot. DashTopTagsPanel + DashTagsTotalText
                                             kept as 0-size dummies for legacy
                                             PopulateDashTopTags writes. -->
                                        <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                                Padding="16,14,16,14" Margin="3,0,4,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="NETWORK" Style="{StaticResource TypeCardTitle}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · join brain" FontSize="11"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    <Ellipse x:Name="DashNetDot" Width="7" Height="7"
                                                             Fill="{StaticResource TextMutedBrush}"
                                                             Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" x:Name="DashNetStatusText"
                                                           Text="Disconnected"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText}"
                                                           Margin="0,8,0,2"/>
                                                <TextBlock Grid.Row="2" x:Name="DashNetPeersText"
                                                           Text="0 peers connected"
                                                           FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           Margin="0,0,0,8"/>

                                                <!-- Peer-count tile + hint -->
                                                <Grid Grid.Row="3" VerticalAlignment="Bottom">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="8" Padding="10,6"
                                                            Background="#22000000" Margin="0,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <StackPanel>
                                                            <TextBlock Text="PEERS" FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource NeuralText3}"/>
                                                            <TextBlock x:Name="DashNetPeerCountText" Text="0"
                                                                       FontSize="22" FontWeight="Bold"
                                                                       FontFamily="{StaticResource FontMono}"
                                                                       Typography.NumeralAlignment="Tabular"
                                                                       Foreground="{StaticResource NeuralText}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" x:Name="DashNetSubtitle"
                                                               Text="Tap NETWORK in sidebar to join"
                                                               TextWrapping="Wrap"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>

                                                <!-- 0-size dummies — preserve x:Names for
                                                     PopulateDashTopTags (deprecated populator
                                                     kept for backwards-compat). -->
                                                <StackPanel Visibility="Collapsed">
                                                    <TextBlock x:Name="DashTagsTotalText"/>
                                                    <ItemsControl x:Name="DashTopTagsPanel"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- ▼ CARD C — MCP ACTIVITY 24 H ▼ -->
                                        <Border Grid.Column="2" Style="{StaticResource NeuralCard}"
                                                Padding="16,14,16,14" Margin="4,0,3,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="MCP ACTIVITY" Style="{StaticResource TypeCardTitle}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · 24 h" FontSize="11"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock x:Name="DashMcpCalls24hText" Text="0"
                                                               FontSize="26" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"
                                                               Typography.NumeralAlignment="Tabular"
                                                               VerticalAlignment="Bottom"/>
                                                    <TextBlock Text="calls" FontSize="11.5"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Bottom"
                                                               Margin="6,0,0,5"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,8">
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource NeuralMint}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DashMcpDeltaText" Text="+0 vs prev 24 h"
                                                               FontSize="11"
                                                               Foreground="{StaticResource NeuralMint}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- Sparkline canvas — code-behind draws 24 rect bars. -->
                                                <Canvas Grid.Row="3" x:Name="DashMcpSparkCanvas"
                                                        Background="{StaticResource NeuralBgInset}"
                                                        MinHeight="46" ClipToBounds="True"/>
                                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="top tool · " FontSize="11"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="DashMcpTopToolText" Text="—"
                                                               FontSize="11.5" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource FontMono}"
                                                               Foreground="{StaticResource NeuralViolet2}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- ▼ CARD D — CLAUDE USAGE ▼
                                             Hybrid usage panel. Four progress rows mirror the layout
                                             of claude.ai/settings/usage so the user sees the exact
                                             same numbers they'd see on the web (Current session,
                                             Weekly all-models, Sonnet only, Usage credits). The
                                             values come from a hidden WebView2 probe of that page
                                             when the user is signed in via Edge — when not, the
                                             dot turns amber and the bars stay at the last known
                                             reading while the local tally subtitle still updates
                                             in real time from ~/.claude/projects/**/*.jsonl. -->
                                        <Border Grid.Column="3" Style="{StaticResource NeuralCard}"
                                                Padding="16,14,16,14" Margin="7,0,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="CLAUDE USAGE" Style="{StaticResource TypeCardTitle}"
                                                                   VerticalAlignment="Center"/>
                                                        <Ellipse x:Name="DashClaudeDot" Width="8" Height="8"
                                                                 Fill="{StaticResource NeuralAmber}"
                                                                 VerticalAlignment="Center" Margin="8,0,0,0"
                                                                 Cursor="Hand"
                                                                 MouseLeftButtonDown="DashClaudeDot_Click"
                                                                 ToolTip="Click to sign into claude.ai · cookies stay private to BrainX"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="DashClaudePlanText" Text="Max (5x)"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource FontMono}"
                                                               Foreground="{StaticResource NeuralText3}"/>
                                                </Grid>
                                                <Grid Grid.Row="1" Margin="0,3,0,10">
                                                    <TextBlock x:Name="DashClaudeSubtitleText"
                                                               Text="plan limits · live from claude.ai"
                                                               FontSize="11"
                                                               Foreground="{StaticResource NeuralText3}"/>
                                                    <TextBlock x:Name="DashClaudeSignInLink"
                                                               Text="Sign in →"
                                                               HorizontalAlignment="Right"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralViolet2}"
                                                               Cursor="Hand"
                                                               MouseLeftButtonDown="DashClaudeDot_Click"
                                                               TextDecorations="Underline"
                                                               ToolTip="Open the claude.ai login in a private BrainX window"/>
                                                </Grid>

                                                <!-- 4 progress rows. Each is a 2-row grid: line 1 = label
                                                     + percent (right), line 2 = the actual bar + small
                                                     reset hint underneath the percent. Bars are plain
                                                     Border + nested Border so we can width-bind to a
                                                     code-set value without ProgressBar's chrome. -->
                                                <StackPanel Grid.Row="2">
                                                    <!-- Current session -->
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="Current session"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText1}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   x:Name="DashClaudeSessionPct" Text="—"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText2}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   x:Name="DashClaudeSessionReset"
                                                                   Text="Sign in to track"
                                                                   FontSize="9" Margin="0,1,0,4"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                                                Height="5" CornerRadius="3"
                                                                Background="#22FFFFFF">
                                                            <Border x:Name="DashClaudeSessionBar"
                                                                    HorizontalAlignment="Left" Width="0"
                                                                    CornerRadius="3"
                                                                    Background="{StaticResource NeuralViolet2}"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Weekly · all models -->
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="Weekly · all models"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText1}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   x:Name="DashClaudeWeeklyPct" Text="—"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText2}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   x:Name="DashClaudeWeeklyReset"
                                                                   Text="—"
                                                                   FontSize="9" Margin="0,1,0,4"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                                                Height="5" CornerRadius="3"
                                                                Background="#22FFFFFF">
                                                            <Border x:Name="DashClaudeWeeklyBar"
                                                                    HorizontalAlignment="Left" Width="0"
                                                                    CornerRadius="3"
                                                                    Background="#FFB840"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Sonnet only -->
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="Sonnet only"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText1}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   x:Name="DashClaudeSonnetPct" Text="—"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText2}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   x:Name="DashClaudeSonnetReset"
                                                                   Text="—"
                                                                   FontSize="9" Margin="0,1,0,4"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                                                Height="5" CornerRadius="3"
                                                                Background="#22FFFFFF">
                                                            <Border x:Name="DashClaudeSonnetBar"
                                                                    HorizontalAlignment="Left" Width="0"
                                                                    CornerRadius="3"
                                                                    Background="#4AE3A7"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Usage credits -->
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="Usage credits"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText1}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   x:Name="DashClaudeCreditsPct" Text="—"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText2}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   x:Name="DashClaudeCreditsReset"
                                                                   Text="—"
                                                                   FontSize="9" Margin="0,1,0,4"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                                                Height="5" CornerRadius="3"
                                                                Background="#22FFFFFF">
                                                            <Border x:Name="DashClaudeCreditsBar"
                                                                    HorizontalAlignment="Left" Width="0"
                                                                    CornerRadius="3"
                                                                    Background="#5BE9E9"/>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Local-tally subtitle. Always populated from the
                                                     transcript scanner so the card is never empty,
                                                     even before claude.ai authentication succeeds. -->
                                                <StackPanel Grid.Row="3" Orientation="Horizontal"
                                                            Margin="0,10,0,0">
                                                    <TextBlock Text="🪙"
                                                               FontSize="10" VerticalAlignment="Center"
                                                               Margin="0,0,5,0"/>
                                                    <TextBlock x:Name="DashClaudeLocalText"
                                                               Text="— · 5h"
                                                               FontSize="10.5" FontFamily="{StaticResource FontMono}"
                                                               Foreground="{StaticResource NeuralText2}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <!-- end PRO INSIGHTS STRIP -->

                                    <!-- Quick Actions — Row 4 (was Row 3 before the insights strip).
                                         NeuralCard wrapper + TypeCardTitle label + NeuralBtn / NeuralBtnPrimary
                                         buttons. Re-index Vault is the only action with a side effect on the
                                         entire knowledge graph, so it gets the primary violet treatment; the
                                         other three are secondary (ghost = no decoration, default = card-tinted). -->
                                    <Border Style="{StaticResource NeuralCard}" Padding="22,18">
                                        <!-- 2-col layout: left = original Quick Actions header + WrapPanel;
                                             right = compact SYSTEM HEALTH chip (moved here from the
                                             Pro Insights strip so its slot could host CLAUDE USAGE).
                                             Same x:Names as before so PopulateDashHealth() in the
                                             Dashboard partial keeps working unchanged. -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="QUICK ACTIONS"
                                                           Style="{StaticResource TypeCardTitle}"
                                                           Margin="0,0,0,14"/>
                                                <WrapPanel>
                                                    <!-- Primary action — only one violet button per card per
                                                         the t2.zip spec; everything else stays ghost/secondary. -->
                                                    <Button Content="&#x1F504;  Re-index Vault"
                                                            Style="{StaticResource NeuralBtnPrimary}"
                                                            Click="ReindexVault_Click" Margin="0,0,10,10"
                                                            ToolTip="Re-scan all notes, rebuild graph + expertise"/>
                                                    <Button Content="&#x1F4D6;  Open in Obsidian"
                                                            Style="{StaticResource NeuralBtn}"
                                                            Click="OpenObsidian_Click" Margin="0,0,10,10"
                                                            ToolTip="Launch Obsidian with this vault"/>
                                                    <!-- NEW: jump to OS File Explorer at vault folder -->
                                                    <Button Content="&#x1F4C1;  Reveal Vault"
                                                            Style="{StaticResource NeuralBtn}"
                                                            Click="DashRevealVault_Click" Margin="0,0,10,10"
                                                            ToolTip="Open vault folder in File Explorer"/>
                                                    <!-- NEW: copy 0xBRAIN-... so user can share -->
                                                    <Button Content="&#x1F4CB;  Copy Address"
                                                            Style="{StaticResource NeuralBtn}"
                                                            Click="DashCopyAddress_Click" Margin="0,0,10,10"
                                                            ToolTip="Copy this brain's 0xBRAIN-... address to clipboard"/>
                                                    <!-- NEW: shortcut to Settings view -->
                                                    <Button Content="&#x2699;  Settings"
                                                            Style="{StaticResource NeuralBtn}"
                                                            Click="Nav_Click" Tag="Settings" Margin="0,0,10,10"
                                                            ToolTip="Jump to Settings"/>
                                                    <!-- Wrapper: navigate to Network view first so the user
                                                         sees the connection state change there. -->
                                                    <Button Content="&#x1F310;  Join Network"
                                                            Style="{StaticResource NeuralBtnGhost}"
                                                            Click="DashJoinNetwork_Click" Margin="0,0,10,10"
                                                            ToolTip="Connect to the BrainX peer mesh"/>
                                                    <Button Content="&#x1F4CA;  Export Stats"
                                                            Style="{StaticResource NeuralBtnGhost}"
                                                            Click="ExportStats_Click" Margin="0,0,10,10"
                                                            ToolTip="Save brain_stats.json + open in File Explorer"/>
                                                </WrapPanel>
                                            </StackPanel>

                                            <!-- ▼ SYSTEM HEALTH compact chip (moved from Pro Insights) ▼
                                                 Six mono one-liners stacked vertically — VAULT, DB, INDEX,
                                                 AI, MESH, VER — with the same x:Names the previous card
                                                 used so PopulateDashHealth needs zero changes. -->
                                            <Border Grid.Column="1" VerticalAlignment="Center"
                                                    Background="#10FFFFFF"
                                                    BorderBrush="#22FFFFFF" BorderThickness="1"
                                                    CornerRadius="10" Padding="12,8" Margin="14,0,0,0"
                                                    MinWidth="170">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <Ellipse x:Name="DashHealthDot" Width="7" Height="7"
                                                                 Fill="{StaticResource NeuralMint}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="SYSTEM HEALTH"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="VAULT"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,1,8,0"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DashHealthVaultText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText1}"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DB"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,2,8,0"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DashHealthDbText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText1}" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="INDEX"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,2,8,0"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DashHealthIndexText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText1}" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="AI"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,2,8,0"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DashHealthAiText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText1}" Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MESH"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,2,8,0"/>
                                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DashHealthMeshText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText1}" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="VER"
                                                                   FontSize="8.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeuralText3}"
                                                                   Margin="0,2,8,0"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DashHealthVersionText"
                                                                   Text="—" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource NeuralText2}" Margin="0,2,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </StackPanel>
                                    </ScrollViewer>
                                <!-- end Dashboard inner 4-row Grid -->
                                </Grid>
                        </Grid>

                        <!-- Brain Graph View -->
                        <Grid x:Name="BrainGraphView" Visibility="Collapsed">
                            <Border Style="{StaticResource CardPanel}" Margin="24,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="BRAIN GRAPH" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="GraphFPS" Text="" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox x:Name="GraphSearchBox" Width="260" Margin="20,0,0,0"
                                                     Background="{StaticResource DarkPanelBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource NeonCyanBrush}"
                                                     BorderThickness="1" FontSize="11" Padding="8,3"
                                                     CaretBrush="{StaticResource NeonCyanBrush}"
                                                     VerticalAlignment="Center"
                                                     ToolTip="Ctrl+F to focus · Enter to fly to top hit · Esc to close"
                                                     TextChanged="GraphSearch_TextChanged"
                                                     KeyDown="GraphSearch_KeyDown"
                                                     GotFocus="GraphSearch_GotFocus"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="Camera" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CameraModeCombo" Width="140" FontSize="10"
                                                      Background="{StaticResource DarkPanelBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      BorderBrush="{StaticResource NeonCyanBrush}"
                                                      SelectionChanged="CameraMode_Changed" Margin="0,0,10,0">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Background" Value="#0f1420"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Padding" Value="8,4"/>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBoxItem Content="Free (drag)"/>
                                                <ComboBoxItem Content="Follow Pulse"/>
                                                <ComboBoxItem Content="Orbit"/>
                                                <ComboBoxItem Content="Overview"/>
                                                <ComboBoxItem Content="Random Walk"/>
                                                <!-- Default mode: camera follows MCP/edit activity so the
                                                     user sees the AI's attention in real time. Matches
                                                     _cameraMode = CameraMode.RealBrain in MainWindow.xaml.cs. -->
                                                <ComboBoxItem Content="Real Brain (5s dwell)" IsSelected="True"/>
                                            </ComboBox>
                                            <Button Content="&#x2B06; Up" Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10" Click="ZoomOutLevel_Click" Margin="0,0,6,0"
                                                    ToolTip="Zoom back to parent cluster"/>
                                            <Button Content="&#x1F3AF; Fit" Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10" Click="FitOverview_Click" Margin="0,0,6,0"
                                                    ToolTip="Frame the whole graph"/>
                                            <Button Content="&#x1F4A5; Shake" Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10" Click="ShakeGraph_Click" Margin="0,0,6,0"/>
                                            <Button Content="&#x1F504; Reset" Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10" Click="ResetCamera_Click" Margin="0,0,6,0"/>
                                            <!-- Toggle the expertise overlay panel inside the brain graph
                                                 view. Same data as the Dashboard's right-rail panel; hidden
                                                 by default so the graph has full width when not needed. -->
                                            <Button x:Name="GraphExpertiseToggleBtn"
                                                    Content="&#x1F4CA; Expertise"
                                                    Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="GraphExpertiseToggle_Click" Margin="0,0,6,0"
                                                    ToolTip="Toggle the expertise profile overlay"/>
                                            <!-- Live brain-activity overlay. Tails ~/.claude/tool-log.ndjson
                                                 and shows what the brain is reading / writing right now,
                                                 colour-coded by op kind. Mirrors the expertise overlay's
                                                 glassmorphism style but pinned to the LEFT of the graph. -->
                                            <Button x:Name="GraphActivityToggleBtn"
                                                    Content="&#x1F4E1; Activity"
                                                    Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="GraphActivityToggle_Click" Margin="0,0,6,0"
                                                    ToolTip="Toggle the live brain-activity overlay (reads/writes/tool calls)"/>
                                            <!-- Token savings gauge — hover for breakdown by op.
                                                 Runs Compute() on the access-log every ~5s and shows
                                                 net saved tokens. Click to toggle bypass (pauses the
                                                 brain-first hooks so trivial conversations don't
                                                 waste 160 tok/turn on reminders). -->
                                            <Border x:Name="TokenSavingsChip" Padding="8,3"
                                                    Margin="0,0,6,0" CornerRadius="3"
                                                    Background="#1A00FF88"
                                                    BorderBrush="#5500FF88" BorderThickness="1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="TokenSavingsChip_Click">
                                                <TextBlock x:Name="TokenSavingsText"
                                                           Text="&#x1F4B0; +0 tok"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="#5DFF9D"/>
                                            </Border>
                                            <Button x:Name="BrainBypassBtn"
                                                    Content="&#x1F9E0; Always"
                                                    Style="{StaticResource NeuralBtnPrimary}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="BrainBypass_Click" Margin="0,0,12,0"
                                                    ToolTip="Cycle brain-mode: Always → Auto → Off → Always.&#x0a;Always = inject reminder every turn (best for long sessions, deep debug)&#x0a;Auto = skip reminder when prompt &lt; 60 chars (best general use)&#x0a;Off = no reminders (best for trivial chat / greenfield)"/>
                                            <!-- 3D toggle hidden (legacy Viewport3D path soft-disabled).
                                                 Universe view replaces 3D BrainGraph; 2D path stays as the
                                                 primary Graph view with MCP pulse + flash overlay. -->
                                            <Button x:Name="GraphView3DBtn" Content="3D"
                                                    Style="{StaticResource NeuralBtnGhost}"
                                                    Padding="10,3" FontSize="10"
                                                    Tag="3D" Click="GraphViewMode_Click" Margin="0,0,4,0"
                                                    Visibility="Collapsed"/>
                                            <Button x:Name="GraphView2DBtn" Content="2D"
                                                    Style="{StaticResource NeuralBtnPrimary}"
                                                    Padding="10,3" FontSize="10"
                                                    Tag="2D" Click="GraphViewMode_Click"
                                                    Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Transparent border catches mouse on empty space.
                                         bk2 nebula paints the skybox behind the graph viewport. -->
                                    <Border x:Name="GraphView3DBorder" Grid.Row="1" CornerRadius="6" ClipToBounds="True"
                                            Visibility="Collapsed"
                                            MouseLeftButtonDown="FullGraph_MouseDown"
                                            MouseLeftButtonUp="FullGraph_MouseUp"
                                            MouseMove="FullGraph_MouseMove"
                                            MouseWheel="FullGraph_MouseWheel"
                                            MouseRightButtonDown="FullGraph_RightClick">
                                        <Border.Background>
                                            <ImageBrush x:Name="GraphBgBrush"
                                                        ImageSource="pack://application:,,,/Assets/bk2.png"
                                                        Stretch="UniformToFill" Opacity="0.55"/>
                                        </Border.Background>
                                    <Grid>
                                    <Viewport3D x:Name="FullGraphViewport" ClipToBounds="True"
                                                IsHitTestVisible="False">
                                        <Viewport3D.Camera>
                                            <PerspectiveCamera x:Name="GraphCam" Position="0,3,14"
                                                               LookDirection="0,-0.2,-1"
                                                               UpDirection="0,1,0" FieldOfView="50"/>
                                        </Viewport3D.Camera>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><AmbientLight Color="#444466"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight x:Name="GraphKeyLight" Color="#00F0FF" Direction="-1,-1,-1"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight x:Name="GraphFillLight" Color="#FF006E" Direction="1,1,-0.5"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D x:Name="FullGraphModel"/>
                                    </Viewport3D>

                                    <!-- Activity labels — HUD tags that float next to nodes being read/written -->
                                    <Canvas x:Name="ActivityLabels" IsHitTestVisible="False" Panel.ZIndex="8"/>

                                    <!-- Hover tooltip — floats next to the bubble/node under the mouse -->
                                    <Border x:Name="HoverLabel" Visibility="Collapsed"
                                            IsHitTestVisible="False" Panel.ZIndex="11"
                                            Background="#E60B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,5"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                              BlurRadius="12" Opacity="0.4" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="HoverTitle" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock x:Name="HoverSubtitle" FontSize="10" Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- HUD CORNER BRACKETS (sci-fi frame) -->
                                    <Canvas IsHitTestVisible="False" Panel.ZIndex="9">
                                        <!-- Top-left bracket -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M 8,30 L 8,8 L 30,8"
                                              Canvas.Left="0" Canvas.Top="0"/>
                                        <!-- Top-right bracket -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M -30,8 L -8,8 L -8,30"
                                              Canvas.Right="0" Canvas.Top="0"/>
                                        <!-- Bottom-left -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M 8,-30 L 8,-8 L 30,-8"
                                              Canvas.Left="0" Canvas.Bottom="0"/>
                                        <!-- Bottom-right -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M -30,-8 L -8,-8 L -8,-30"
                                              Canvas.Right="0" Canvas.Bottom="0"/>
                                    </Canvas>

                                    <!-- Center reticle (holographic crosshair) -->
                                    <Grid IsHitTestVisible="False" Panel.ZIndex="9"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="40" Height="40"
                                                 Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                                 Opacity="0.25" StrokeDashArray="2 4"/>
                                        <Ellipse Width="80" Height="80"
                                                 Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                                 Opacity="0.12" StrokeDashArray="1 6"/>
                                        <Line X1="-8" Y1="0" X2="8" Y2="0"
                                              Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                              Opacity="0.4" VerticalAlignment="Center"/>
                                        <Line X1="0" Y1="-8" X2="0" Y2="8"
                                              Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                              Opacity="0.4" HorizontalAlignment="Center"/>
                                    </Grid>

                                    <!-- Horizontal scanline (animated via code-behind) -->
                                    <Rectangle x:Name="Scanline" Height="1"
                                               VerticalAlignment="Top" Opacity="0.5"
                                               IsHitTestVisible="False" Panel.ZIndex="9">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush x:Name="ScanlineBrush" StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="{DynamicResource NeonCyanColor}" Offset="0.5"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Search results dropdown -->
                                    <Border x:Name="GraphSearchResults" Visibility="Collapsed"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,48,12,0" Panel.ZIndex="20"
                                            Background="#F00B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="6" MaxWidth="420">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                              BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="GraphSearchSummary" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Padding="10,6,10,4"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <ListBox x:Name="GraphSearchList" MaxHeight="320"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     MouseDoubleClick="GraphSearchList_DoubleClick"
                                                     KeyDown="GraphSearchList_KeyDown"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Depth indicator + breadcrumb overlay -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                            Background="#B30B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,6"
                                            Margin="12" Panel.ZIndex="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="DepthIndicator" Text="Depth 0 / 5"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="·" Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="BreadcrumbText" Text="Brain"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                                        </StackPanel>
                                    </Border>
                                    </Grid>
                                    </Border>

                                    <!-- 2D primary for the full brain graph. WriteableBitmap renderer, default. -->
                                    <Border x:Name="GraphView2DBorder" Grid.Row="1" CornerRadius="6" ClipToBounds="True"
                                            MouseLeftButtonDown="Graph2D_MouseDown"
                                            MouseLeftButtonUp="Graph2D_MouseUp"
                                            MouseMove="Graph2D_MouseMove"
                                            MouseWheel="Graph2D_MouseWheel"
                                            MouseRightButtonDown="Graph2D_RightClick">
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Assets/bk2.png"
                                                        Stretch="UniformToFill" Opacity="0.35"/>
                                        </Border.Background>
                                        <services:Graph2DRenderer x:Name="FullGraph2D"/>
                                    </Border>

                                    <!-- Glassmorphism Activity overlay for Brain Graph view.
                                         Tails the tool-log NDJSON + indexer events; shows the
                                         brain's live read/write/tool ops, colour-coded. Pinned
                                         LEFT (mirror of the Expertise overlay on the right).
                                         Toggled by the "📡 Activity" toolbar button. -->
                                    <Border x:Name="GraphActivityHost" Grid.Row="1"
                                            HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                            Margin="16,16,0,16" Width="380" MaxHeight="760"
                                            CornerRadius="14" Padding="0"
                                            Visibility="Collapsed" IsHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#55101820"/>
                                                <GradientStop Offset="1" Color="#33060A10"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                <GradientStop Offset="1" Color="#11FFFFFF"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                              Color="#000000" Opacity="0.45"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>      <!-- 0: title -->
                                                <RowDefinition Height="Auto"/>      <!-- 1: filter bar -->
                                                <RowDefinition Height="Auto"/>      <!-- 2: compact summary (capped) -->
                                                <RowDefinition Height="Auto"/>      <!-- 3: console section header -->
                                                <RowDefinition Height="*"/>         <!-- 4: console feed (scroll) -->
                                                <RowDefinition Height="Auto"/>      <!-- 5: footer -->
                                            </Grid.RowDefinitions>
                                            <!-- Header row: title + close button -->
                                            <Grid Grid.Row="0" Margin="16,14,16,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse x:Name="ActivityPulse" Width="8" Height="8"
                                                             Fill="#5DFF9D" Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                                              Color="#5DFF9D" Opacity="0.9"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <TextBlock Text="BRAIN ACTIVITY" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;"
                                                        FontSize="11" Padding="6,2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Click="GraphActivityToggle_Click"
                                                        ToolTip="Hide activity overlay"/>
                                            </Grid>
                                            <!-- Filter bar: read | write | other  +  per-second rate -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                        Margin="16,0,16,8">
                                                <CheckBox x:Name="ActivityFilterRead" Content="📖 read"
                                                          IsChecked="True" FontSize="10"
                                                          Foreground="#5DFF9D" Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <CheckBox x:Name="ActivityFilterWrite" Content="✏ write"
                                                          IsChecked="True" FontSize="10"
                                                          Foreground="#FFB347" Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <CheckBox x:Name="ActivityFilterOther" Content="🔧 other"
                                                          IsChecked="False" FontSize="10"
                                                          Foreground="{StaticResource TextMutedBrush}"
                                                          Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <TextBlock x:Name="ActivityRateText"
                                                           Text="0/min"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                            <!-- Compact summary (capped to ~30 most recent, newest on top).
                                                 Good for at-a-glance "what's the brain busy with right now?" -->
                                            <ScrollViewer Grid.Row="2"
                                                          MaxHeight="180"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Padding="8,0,8,4" CanContentScroll="False"
                                                          PanningMode="VerticalOnly">
                                                <StackPanel x:Name="GraphActivityPanel"/>
                                            </ScrollViewer>

                                            <!-- Section divider + collapse toggle for the detailed console.
                                                 The console is the "live tail" — chronological, monospace,
                                                 sticky-bottom auto-scroll. Cap at 300 lines for perf. -->
                                            <Grid Grid.Row="3" Margin="16,8,16,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="📜 DETAILED CONSOLE" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ActivityConsoleCount"
                                                               Text="0 lines"
                                                               FontSize="9"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                               Opacity="0.7"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <CheckBox x:Name="ActivityConsoleStickyBottom"
                                                              Content="📌 stick to bottom"
                                                              IsChecked="True" FontSize="9"
                                                              Foreground="{StaticResource TextMutedBrush}"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                                              ToolTip="When checked, new lines auto-scroll into view. Uncheck to read history without being yanked back."/>
                                                    <Button x:Name="ActivityConsolePauseBtn"
                                                            Content="⏸ Pause"
                                                            FontSize="9" Padding="6,2"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            Click="GraphActivityConsolePause_Click"
                                                            ToolTip="Pause the live tail (file polling stops; resume to catch up)"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- The console itself. ScrollViewer wraps a StackPanel that we
                                                 APPEND to (no full rebuild per tick, no virtualization
                                                 needed for 300 cap). ScrollChanged tracks whether the user
                                                 has detached from the bottom so we don't yank them back. -->
                                            <Border Grid.Row="4" Margin="14,0,14,4" CornerRadius="6"
                                                    Background="#0D000208" BorderThickness="1"
                                                    BorderBrush="#22FFFFFF">
                                                <ScrollViewer x:Name="GraphActivityConsoleScroll"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Padding="6,4,6,4"
                                                              CanContentScroll="False"
                                                              PanningMode="VerticalOnly"
                                                              ScrollChanged="GraphActivityConsoleScroll_Changed">
                                                    <StackPanel x:Name="GraphActivityConsolePanel"/>
                                                </ScrollViewer>
                                            </Border>
                                            <!-- Footer: clear + path tooltip -->
                                            <Grid Grid.Row="5" Margin="14,4,14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Clear" FontSize="9" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Click="GraphActivityClear_Click"
                                                        ToolTip="Clear the displayed log (does not touch the file)"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="~/.claude/tool-log.ndjson"
                                                           FontSize="9"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Source of brain tool-call activity"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Glassmorphism Expertise overlay for Brain Graph view.
                                         Same data as Dashboard's panel, populated by
                                         BuildExpertiseBars() into GraphExpertisePanel. Toggled
                                         off by default; the toolbar button "📊 Expertise"
                                         flips Visibility. Sits in Grid.Row="1" alongside the
                                         2D/3D borders so it floats over the graph viewport. -->
                                    <Border x:Name="GraphExpertiseHost" Grid.Row="1"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,16,16,16" Width="320" MaxHeight="460"
                                            CornerRadius="14" Padding="0"
                                            Visibility="Collapsed" IsHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#55101820"/>
                                                <GradientStop Offset="1" Color="#33060A10"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                <GradientStop Offset="1" Color="#11FFFFFF"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                              Color="#000000" Opacity="0.45"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="16" CanContentScroll="False"
                                                      PanningMode="VerticalOnly">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="EXPERTISE PROFILE" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="&#x2715;"
                                                            FontSize="11" Padding="6,2"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            Click="GraphExpertiseToggle_Click"
                                                            ToolTip="Hide expertise overlay"/>
                                                </Grid>
                                                <StackPanel x:Name="GraphExpertisePanel"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Selected Node Info — auto-hides after 15s idle, × closes, edit+save inline -->
                                    <Border x:Name="GraphNodeInfo" Grid.Row="2" Visibility="Collapsed"
                                            Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                            Padding="14,10" Margin="0,8,0,0" MaxHeight="300"
                                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                            MouseEnter="GraphNodeInfo_MouseEnter"
                                            MouseLeave="GraphNodeInfo_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse x:Name="GraphNodeDot" Width="12" Height="12"
                                                         Fill="{StaticResource NeonCyanBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock x:Name="GraphNodeTitle" Text="" FontSize="14"
                                                               FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock x:Name="GraphNodeMeta" Text="" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="&#x26A1; Kick" Style="{StaticResource NeuralBtnGhost}"
                                                            Padding="10,4" FontSize="11" Click="KickGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeEditBtn" Content="&#x270E; Edit"
                                                            Style="{StaticResource NeuralBtnGhost}"
                                                            Padding="10,4" FontSize="11" Click="EditGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeSaveBtn" Content="&#x1F4BE; Save"
                                                            Style="{StaticResource NeuralBtnPrimary}"
                                                            Visibility="Collapsed"
                                                            Padding="10,4" FontSize="11" Click="SaveGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeCancelBtn" Content="Cancel"
                                                            Style="{StaticResource NeuralBtnGhost}"
                                                            Visibility="Collapsed"
                                                            Padding="10,4" FontSize="11" Click="CancelGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button Content="&#x1F4D6; Open" Style="{StaticResource NeuralBtnPrimary}"
                                                            Padding="10,4" FontSize="11" Click="OpenNodeFile_Click" Margin="0,0,6,0"/>
                                                    <Button Content="&#x2715;" Style="{StaticResource NeuralBtnGhost}"
                                                            Padding="8,4" FontSize="11" ToolTip="Close"
                                                            Click="CloseGraphNode_Click"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                <ScrollViewer x:Name="GraphNodeContentScroll" MaxHeight="180"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <TextBlock x:Name="GraphNodeContent" Text="" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                </ScrollViewer>
                                                <TextBox x:Name="GraphNodeEditor" Visibility="Collapsed"
                                                         MinHeight="180" MaxHeight="240"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         FontFamily="{StaticResource MonoFont}"
                                                         Style="{StaticResource NeonTextBox}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ═══ NETWORK VIEW (Join Brain) ═══
                             Constellation redesign:
                             - Left card 1fr: mini-galaxy (central server star +
                               peer stars + live links) + ONLINE/OFFLINE + verified
                               HUD + host + BRAINS/KNOWLEDGE/WORDS + "KNOWLEDGE
                               JOINED" topic chips. Driven by RefreshNetworkStats →
                               GetNetworkStatsAsync (TotalPeers/Knowledge/Words/
                               Categories) + DrawNetworkConstellation/BuildNetworkTopics.
                             - Right card 2fr: "TOP EXPERTISE MATCHES" + MatchResultsList.
                             Handlers preserved: JoinNetwork_Click, LeaveNetwork_Click,
                             MatchCategoryCombo, FindExperts_Click, MatchResultsList. -->
                        <Grid x:Name="NetworkView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Network" Style="{StaticResource TypeViewTitle}"/>
                                        <TextBlock Text="Connect to the BrainX mesh · find brains by overlapping expertise"
                                                   Style="{StaticResource TypeViewSubtitle}"/>
                                    </StackPanel>
                                    <!-- Reconnect = Join button rebadged so it lives in the title row per screenshot. -->
                                    <Button Grid.Column="1" x:Name="JoinNetworkBtn"
                                            Content="&#x2728;  Reconnect"
                                            Click="JoinNetwork_Click"
                                            Style="{StaticResource NeuralBtnPrimary}"
                                            Padding="14,7" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- LEFT CARD — pulse + 3-stat grid. -->
                                    <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                            Padding="26" Margin="0,0,7,0">
                                        <StackPanel>
                                            <!-- CONSTELLATION — central server star + peer stars + live
                                                 links (mini-galaxy, matches the 3D Universe). Code-behind
                                                 DrawNetworkConstellation() fills the canvas from the live
                                                 peer list; the core breathes via the Loaded trigger. -->
                                            <Grid Height="206" Margin="0,8,0,14">
                                                <Canvas x:Name="NetworkConstellationCanvas" ClipToBounds="False"/>
                                                <Grid x:Name="NetworkCoreStar" Width="64" Height="64"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform x:Name="NetworkCoreScale" ScaleX="1" ScaleY="1"/>
                                                    </Grid.RenderTransform>
                                                    <Grid.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetName="NetworkCoreHalo"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     From="0.45" To="0.14" Duration="0:0:1.7"/>
                                                                    <DoubleAnimation Storyboard.TargetName="NetworkCoreScale"
                                                                                     Storyboard.TargetProperty="ScaleX"
                                                                                     From="1" To="1.09" Duration="0:0:1.7"/>
                                                                    <DoubleAnimation Storyboard.TargetName="NetworkCoreScale"
                                                                                     Storyboard.TargetProperty="ScaleY"
                                                                                     From="1" To="1.09" Duration="0:0:1.7"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Grid.Triggers>
                                                    <Ellipse x:Name="NetworkCoreHalo" Width="64" Height="64" Opacity="0.4">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop x:Name="NetworkCoreHaloStop" Color="#9d7bff" Offset="0"/>
                                                                <GradientStop Color="#009d7bff" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Border Width="34" Height="34" CornerRadius="17"
                                                            BorderBrush="#55FFFFFF" BorderThickness="1"
                                                            Effect="{StaticResource ShadowAccent}">
                                                        <Border.Background>
                                                            <RadialGradientBrush>
                                                                <GradientStop x:Name="NetworkCoreStopA" Color="#C9B5FF" Offset="0"/>
                                                                <GradientStop x:Name="NetworkCoreStopB" Color="#6a48d6" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Grid>

                                            <!-- STATUS HUD — online/offline + verified badge -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse x:Name="NetStatusDot" Width="9" Height="9" Fill="#ff6b6b"
                                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                <TextBlock x:Name="NetStatusText" Text="OFFLINE" FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText}" VerticalAlignment="Center"/>
                                                <Border x:Name="NetVerifiedBadge" Background="#1A4AE3A7" CornerRadius="5"
                                                        Padding="7,2,7,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                                        Visibility="Collapsed"
                                                        ToolTip="TLS-verified genuine server — not redirected to a fake host">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F6E1;" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="verified" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#4AE3A7" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="NetHostText" Text="—" FontSize="11.5"
                                                       FontFamily="{StaticResource FontMono}"
                                                       Foreground="{StaticResource NeuralText3}"
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>

                                            <!-- Divider -->
                                            <Border Height="1" Background="{StaticResource NeuralLine}" Margin="0,20,0,16"/>

                                            <!-- Auto-match toggle row -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Auto-match by expertise" FontSize="13.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock Text="Surface peers when overlap &gt; 60%" FontSize="12"
                                                               FontWeight="Medium" Margin="0,2,0,0"
                                                               Foreground="{StaticResource NeuralText3}"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1" x:Name="AutoMatchToggle"
                                                          VerticalAlignment="Center" IsChecked="True"/>
                                            </Grid>

                                            <!-- Divider -->
                                            <Border Height="1" Background="{StaticResource NeuralLine}" Margin="0,16,0,18"/>

                                            <!-- KNOWLEDGE STATS — brains joined / knowledge nodes / words. -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetBrainsText" Text="0" FontSize="22" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"
                                                               HorizontalAlignment="Center"
                                                               Typography.NumeralAlignment="Tabular"/>
                                                    <TextBlock Text="BRAINS" FontSize="10.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetKnowledgeText" Text="0" FontSize="22" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"
                                                               HorizontalAlignment="Center"
                                                               Typography.NumeralAlignment="Tabular"/>
                                                    <TextBlock Text="KNOWLEDGE" FontSize="10.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetWordsText" Text="0" FontSize="22" FontWeight="Bold"
                                                               Foreground="#4AE3A7"
                                                               HorizontalAlignment="Center"
                                                               Typography.NumeralAlignment="Tabular"/>
                                                    <TextBlock Text="WORDS" FontSize="10.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Divider -->
                                            <Border Height="1" Background="{StaticResource NeuralLine}" Margin="0,16,0,14"/>

                                            <!-- KNOWLEDGE JOINED — topic chips from the hub's Categories map.
                                                 Code-behind BuildNetworkTopics() fills this WrapPanel. -->
                                            <TextBlock Text="KNOWLEDGE JOINED" FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeuralText3}" Margin="0,0,0,9"/>
                                            <WrapPanel x:Name="NetworkTopicsPanel">
                                                <TextBlock x:Name="NetworkTopicsEmpty"
                                                           Text="Join the network to see shared topics"
                                                           FontSize="12" Foreground="{StaticResource NeuralText3}"/>
                                            </WrapPanel>

                                            <!-- Disconnect button — collapsed by default; shown when connected. -->
                                            <Button x:Name="LeaveNetworkBtn" Content="Disconnect"
                                                    Click="LeaveNetwork_Click" Visibility="Collapsed"
                                                    Style="{StaticResource NeuralBtnGhost}" HorizontalAlignment="Center"
                                                    Margin="0,22,0,0"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    BorderBrush="{StaticResource DangerBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- RIGHT CARD — TOP EXPERTISE MATCHES list. -->
                                    <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                            Padding="22" Margin="7,0,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header row -->
                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                    <TextBlock Text="TOP EXPERTISE MATCHES" FontSize="12.5" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText1}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · brains with overlap &gt; 60%" FontSize="12.5"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="See all peers" FontSize="12"
                                                           FontWeight="Medium" Foreground="#9d7bff"
                                                           VerticalAlignment="Center" Cursor="Hand"
                                                           MouseLeftButtonUp="SeeAllPeers_Click"/>
                                            </Grid>

                                            <!-- Category combo + Find Experts (compact row, kept from
                                                 original — code-behind FindExperts_Click populates the list). -->
                                            <Grid Grid.Row="1" Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="MatchCategoryCombo" Grid.Column="0"
                                                          Background="{StaticResource NeuralBgInset}"
                                                          Foreground="{StaticResource NeuralText1}"
                                                          FontSize="12"/>
                                                <Button Grid.Column="1" Content="&#x1F50E; Find Experts"
                                                        Click="FindExperts_Click"
                                                        Style="{StaticResource NavButton}"
                                                        Padding="14,6" Margin="8,0,0,0"/>
                                            </Grid>

                                            <!-- Results list -->
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel x:Name="MatchResultsList">
                                                    <TextBlock Text="Click ✦ Reconnect to discover expert brains, or pick a category and ⌕ Find Experts."
                                                               FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               FontStyle="Italic" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- AI Chat View (formerly "Claude AI") — per t2.zip 07-assistant.png
                             + README §4. Surgical chrome migration: title + subtitle row to
                             match other views, AiChatModeCombo moved into the toolbar row,
                             outer margins 28,24,28,16 to align. Inner chat machinery
                             (CluadeXBridgePanel, SoloChatPanel, CoPilotArenaPanel, redirect
                             card) preserved verbatim. -->
                        <Grid x:Name="ClaudeView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="AI Brain Assistant" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock x:Name="ClaudeViewSubtitle"
                                               Text="Chat with local or cloud models · vault = system prompt"
                                               Style="{StaticResource TypeViewSubtitle}"/>
                                    <!-- Mode selector — moved here from the inline title row so the
                                         title stays clean. Style preserved. -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="MODE" FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeuralText3}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="AiChatModeCombo" Width="220" FontSize="11"
                                                  VerticalAlignment="Center" SelectedIndex="0"
                                                  Background="{StaticResource NeuralBgInset}"
                                                  Foreground="{StaticResource NeuralText1}"
                                                  SelectionChanged="AiChatMode_Changed"
                                                  ToolTip="Solo: chat with one model. Co-Pilot Arena: delegate to CluadeX worker via named pipe.">
                                            <ComboBoxItem Content="Solo (one model)"/>
                                            <ComboBoxItem Content="🤝 Co-Pilot Arena (CluadeX bridge)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <!-- ─── CluadeX bridge tester ───────────────────────────
                                         Smoke-test the named-pipe connection before sending a
                                         real task. Status dot reflects last ping; "Ping" hits
                                         the server's `ping` method (no agent run, cheap), and
                                         "Send test prompt" runs cluadex.write_code with a tiny
                                         spec so the user can verify a chat session pops up in
                                         CluadeX's UI. The chip is hidden when CluadeX isn't
                                         installed (auth-token file missing). -->
                                    <Border x:Name="CluadeXBridgePanel"
                                            Background="{StaticResource NeuralBgInset}"
                                            BorderBrush="{StaticResource NeuralLineAccent}"
                                            BorderThickness="1" CornerRadius="9"
                                            Margin="0,10,0,0" Padding="14,9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <Ellipse x:Name="CluadeXBridgeDot" Width="8" Height="8"
                                                         Fill="#664444" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="&#x1F309; CluadeX bridge" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeuralText1}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="CluadeXBridgeStatusText"
                                                       Text="not connected — click Ping to probe \\.\pipe\cluadex-mcp"
                                                       FontSize="11"
                                                       Foreground="{StaticResource NeuralText3}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                                       FontFamily="{StaticResource FontMono}"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button x:Name="CluadeXBridgePingBtn"
                                                        Content="📡 Ping"
                                                        Style="{StaticResource NeuralBtnGhost}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgePing_Click"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Send a no-op ping to verify the CluadeX named-pipe is reachable + auth token matches"/>
                                                <Button x:Name="CluadeXBridgeAlignBtn"
                                                        Content="🎯 Align"
                                                        Style="{StaticResource NeuralBtnGhost}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgeAlign_Click"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Force CluadeX to load the same provider+model as BrainX — frees the previous GGUF weights from VRAM if needed"/>
                                                <Button x:Name="CluadeXBridgeTestBtn"
                                                        Content="🧪 Test prompt"
                                                        Style="{StaticResource NeuralBtnGhost}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgeTest_Click"
                                                        ToolTip="Send a tiny test spec via cluadex.write_code — a new chat session should pop up in CluadeX's UI"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="ClaudeViewStatus" Text="Checking..." FontSize="11.5"
                                               Foreground="{StaticResource NeuralText3}" Margin="0,8,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="BACKEND" VerticalAlignment="Center" FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeuralText3}" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="AiBackendCombo" Width="160" FontSize="12"
                                                  Background="{StaticResource NeuralBgInset}"
                                                  Foreground="{StaticResource NeuralText1}"
                                                  SelectionChanged="AiBackend_Changed" Margin="0,0,14,0"/>
                                        <TextBlock Text="MODEL" VerticalAlignment="Center" FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeuralText3}" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="AiModelCombo" Width="200" FontSize="12"
                                                  Background="{StaticResource NeuralBgInset}"
                                                  Foreground="{StaticResource NeuralText1}" Margin="0,0,14,0"/>
                                        <Button Content="&#x21BB; Refresh" Style="{StaticResource NeuralBtnGhost}" Padding="12,4" FontSize="11.5"
                                                Click="RefreshAiBackends_Click" Margin="0,0,6,0"/>
                                        <Button Content="&#x2699; Models" Style="{StaticResource NeuralBtnGhost}" Padding="12,4" FontSize="11.5"
                                                Click="ToggleModelManager_Click" Margin="0,0,0,0"/>
                                        <TextBlock x:Name="AiLatencyText" FontSize="11" Margin="14,0,0,0"
                                                   FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource NeuralText3}"/>
                                    </StackPanel>

                                    <!-- 🔀 REDIRECT CLAUDE DESKTOP TOGGLE — magenta-tinted card per
                                         spec §4 ("magenta-tinted card with bolt icon 36 px gradient
                                         square"). Background uses a violet→magenta tint, bolt icon
                                         in a gradient square on the left. -->
                                    <Border Style="{StaticResource NeuralCard}" Margin="0,12,0,0" Padding="18">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#321A35" Offset="0"/>
                                                <GradientStop Color="#1A1535" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 36 px bolt icon gradient square per spec. -->
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="9" Margin="0,0,14,0"
                                                    Effect="{StaticResource ShadowAccent}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FF4F9E" Offset="0"/>
                                                        <GradientStop Color="#9d7bff" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="&#x26A1;" FontSize="18"
                                                           Foreground="White" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Redirect Claude Desktop &#x2192; Local AI"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText}"/>
                                                <TextBlock x:Name="RedirectStatusText" FontSize="12"
                                                           Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="OFF — Claude Desktop talks to api.anthropic.com (cloud)"/>
                                                <TextBlock x:Name="RedirectTrafficText" FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           FontFamily="{StaticResource FontMono}" Margin="0,6,0,0"
                                                           Text="Traffic: 0 requests · 0 B in · 0 B out"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                                <ToggleButton x:Name="RedirectToggle" Width="90" Height="34"
                                                              Checked="RedirectToggle_Checked"
                                                              Unchecked="RedirectToggle_Unchecked"
                                                              HorizontalAlignment="Right">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="#1A1A2E"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Content" Value="● OFF"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="17">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource NeonCyanBrush}"/>
                                                                    <Setter Property="Foreground" Value="#0B0B1A"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
                                                                    <Setter Property="Content" Value="● ON"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <Button x:Name="RedirectShowTrafficBtn" Content="📡 Show live traffic"
                                                        Style="{StaticResource NeuralBtnGhost}" Padding="6,3" FontSize="10"
                                                        Click="ToggleRedirectTraffic_Click" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Live traffic feed -->
                                    <Border x:Name="RedirectTrafficPanel" Visibility="Collapsed"
                                            Background="{StaticResource DarkPanelBrush}"
                                            BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,6,0,0" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="RECENT REDIRECTED REQUESTS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                            <ListBox x:Name="RedirectTrafficList" Height="140"
                                                     Background="{StaticResource DeepSpaceBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="10"/>
                                            <Button Content="Reset counters" Style="{StaticResource NeuralBtnGhost}"
                                                    Click="ResetRedirectStats_Click" Padding="10,3" FontSize="10"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Model Manager (collapsed by default) -->
                                    <Border x:Name="ModelManagerPanel" Visibility="Collapsed"
                                            Background="{StaticResource DarkPanelBrush}"
                                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,10,0,0" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="OLLAMA MODEL MANAGER" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                                            <TextBlock Text="Installed models" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ListBox x:Name="InstalledModelsList" Height="100"
                                                     Background="{StaticResource DeepSpaceBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                     Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="Use as default" Style="{StaticResource NeuralBtnGhost}"
                                                        Click="UseSelectedModel_Click" Padding="10,4" FontSize="10" Margin="0,0,6,0"/>
                                                <Button Content="Remove" Style="{StaticResource NeuralBtnGhost}"
                                                        Click="RemoveModel_Click" Padding="10,4" FontSize="10"/>
                                            </StackPanel>

                                            <TextBlock Text="Pull new model (e.g. qwen2.5:7b, mistral, phi3, typhoon)" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBox x:Name="ModelPullBox" Width="260" FontSize="11" Padding="6,3"
                                                         Background="{StaticResource DeepSpaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}"
                                                         CaretBrush="{StaticResource NeonCyanBrush}"
                                                         FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                                                <Button x:Name="PullModelBtn" Content="↓ Pull" Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="PullModel_Click" Padding="10,4" FontSize="10"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="ModelPullProgress" Height="6" Minimum="0" Maximum="100"
                                                         Foreground="{StaticResource NeonCyanBrush}"
                                                         Background="{StaticResource SurfaceLightBrush}"
                                                         BorderThickness="0" Visibility="Collapsed"/>
                                            <TextBlock x:Name="ModelPullStatus" FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="Currently loaded in RAM (warm)" FontSize="11" Margin="0,12,0,4"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="RunningModelsText" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- Body row holds two panels stacked Z-order; only one is
                                     visible at a time depending on the AiChatModeCombo selection.
                                     Solo = the simple text-based chat we've always had.
                                     Co-Pilot Arena = bubble feed driven by CoPilotOrchestrator. -->
                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Border x:Name="SoloChatPanel" Style="{StaticResource CardPanel}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="ClaudeOutput" TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="Welcome to BrainX AI Chat.&#x0A;&#x0A;Solo mode: chat with the selected model (Ollama / NIM / OpenRouter / DeepSeek), grounded on your vault.&#x0A;&#x0A;Co-Pilot Arena (Phase 1) will let a local model and Claude collaborate on tasks here, with both wired into the brain MCP."/>
                                        </ScrollViewer>
                                    </Border>
                                    <!-- ─── Co-Pilot Arena ─────────────────────────────────────
                                         Hidden by default, surfaced when the user picks the
                                         🤝 mode. Three rows: header with working-directory input,
                                         the bubble feed (intern plan / worker reply / errors),
                                         and a budget gauge footer showing wall-clock + spend. -->
                                    <Border x:Name="CoPilotArenaPanel" Visibility="Collapsed"
                                            Style="{StaticResource CardPanel}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Header: where the worker should run + reset feed -->
                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Working dir" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" x:Name="ArenaWorkingDirBox"
                                                         Style="{StaticResource NeonTextBox}" FontSize="11"
                                                         FontFamily="{StaticResource MonoFont}"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Repo path the CluadeX worker should run inside. Leave empty to use CluadeX's current dir."/>
                                                <Button Grid.Column="2" x:Name="ArenaClearBtn"
                                                        Content="Clear feed" Style="{StaticResource NeuralBtnGhost}"
                                                        Padding="10,3" FontSize="10" Margin="8,0,0,0"
                                                        Click="ArenaClear_Click"
                                                        ToolTip="Wipe the bubble feed. Worker history stays in CluadeX's codex.db."/>
                                            </Grid>
                                            <!-- Bubble feed. StackPanel children are appended in
                                                 code-behind, matching the project's existing
                                                 imperative-rendering style. -->
                                            <Border Grid.Row="1" Background="#220B0B1A"
                                                    BorderBrush="{StaticResource SurfaceLightBrush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <ScrollViewer x:Name="ArenaBubbleScroll" VerticalScrollBarVisibility="Auto"
                                                              ScrollChanged="ArenaBubbleScroll_ScrollChanged"
                                                              Padding="10">
                                                    <StackPanel x:Name="ArenaBubbleFeed">
                                                        <TextBlock x:Name="ArenaEmptyHint"
                                                                   Text="🤝 Co-Pilot Arena is idle. Type a coding task below — the local intern will plan it and CluadeX will write the code in a visible session."
                                                                   FontSize="12" FontStyle="Italic"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" Margin="6,12,6,12"/>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                            <!-- Budget gauge: wall-clock + nominal USD ceiling.
                                                 Updated as orchestrator events flow in. -->
                                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" x:Name="ArenaBudgetGauge"
                                                           Text="idle"
                                                           FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="ArenaCancelBtn"
                                                        Content="✕ Stop" Style="{StaticResource NeuralBtnGhost}"
                                                        Padding="10,3" FontSize="10"
                                                        IsEnabled="False" Click="ArenaCancel_Click"
                                                        ToolTip="Cancel the running orchestration. Worker stops at its next checkpoint."/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ClaudeInput" Style="{StaticResource NeonTextBox}"
                                             KeyDown="ClaudeInput_KeyDown" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="36" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <Button Grid.Column="1" x:Name="AskClaudeBtn" Content="Ask Claude"
                                            Style="{StaticResource NeuralBtnPrimary}"
                                            Click="AskClaude_Click"/>
                                    <Button Grid.Column="2" x:Name="SendToArenaBtn" Content="🤝 Send to Arena"
                                            Style="{StaticResource NeuralBtnPrimary}" Visibility="Collapsed"
                                            Margin="8,0,0,0"
                                            Click="SendToArena_Click"
                                            ToolTip="Plan with the local intern, then delegate to CluadeX. A new chat session pops up in CluadeX's sidebar."/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- ═══ VAULT EXPLORER ═══
                             Per t2.zip screenshot 05-vault.png + README §6:
                             header (title + path subtitle + right-aligned
                             "New note / New folder / Re-index" actions), then
                             2-col body (320 px folders tree + 1fr list table).
                             Existing VaultTree x:Name + handlers preserved;
                             the new VaultListPane on the right is populated
                             by code-behind on tree selection change. -->
                        <Grid x:Name="VaultView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Vault Explorer" Style="{StaticResource TypeViewTitle}"/>
                                        <TextBlock x:Name="VaultViewSubtitle"
                                                   Text="C:\xman\vault · auto-watched"
                                                   Style="{StaticResource TypeViewSubtitle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="&#x002B;  New note" Style="{StaticResource NavButton}"
                                                Click="VaultNewNote_Click" Padding="14,6" Margin="0,0,4,0" FontSize="12.5"/>
                                        <Button Content="&#x1F4C1;  New folder" Style="{StaticResource NavButton}"
                                                Click="VaultNewFolder_Click" Padding="14,6" Margin="0,0,4,0" FontSize="12.5"/>
                                        <Button Content="&#x21BB;  Re-index" Style="{StaticResource NavButton}"
                                                Click="VaultRefresh_Click" Padding="14,6" FontSize="12.5"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FOLDERS TREE CARD -->
                                    <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                            Padding="18" Margin="0,0,12,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="FOLDERS" FontSize="12.5" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText1}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" · tree" FontSize="12.5"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TreeView Grid.Row="1" x:Name="VaultTree" Background="Transparent"
                                                      Foreground="{StaticResource NeuralText1}" BorderThickness="0"
                                                      MouseDoubleClick="VaultTree_DoubleClick">
                                                <TreeView.ContextMenu>
                                                    <ContextMenu Background="{StaticResource NeuralBgCard}"
                                                                 Foreground="{StaticResource NeuralText1}"
                                                                 BorderBrush="{StaticResource NeuralLine}">
                                                        <MenuItem Header="Open in Editor" Click="VaultOpenInEditor_Click"/>
                                                        <MenuItem Header="Rename" Click="VaultRename_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="Delete" Click="VaultDelete_Click" Foreground="#FF4444"/>
                                                    </ContextMenu>
                                                </TreeView.ContextMenu>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <!-- LISTING CARD (right wider) -->
                                    <Border Grid.Column="1" Style="{StaticResource NeuralCard}" Padding="22">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <!-- Header row: breadcrumb + List/Grid segmented -->
                                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock x:Name="VaultBreadcrumbText"
                                                               Text="ROOT · 0 notes" FontSize="13" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText1}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{StaticResource NeuralBgInset}"
                                                        BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                        CornerRadius="9" Padding="3" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border CornerRadius="7" Padding="12,4"
                                                                Background="{StaticResource NeuralBgCard2}">
                                                            <TextBlock Text="List" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource NeuralText}"/>
                                                        </Border>
                                                        <Border CornerRadius="7" Padding="12,4">
                                                            <TextBlock Text="Grid" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource NeuralText2}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Column headers -->
                                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="NAME" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeuralText3}"/>
                                                <TextBlock Grid.Column="1" Text="CATEGORY" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="2" Text="WORDS" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="3" Text="MODIFIED" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- File rows — populated by code-behind on tree selection. -->
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel x:Name="VaultListPane">
                                                    <TextBlock Text="Select a folder in the tree to list its notes."
                                                               FontSize="12.5"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               FontStyle="Italic" Margin="0,12,0,0"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- ═══ PEERS VIEW ═══ -->
                        <Grid x:Name="PeersView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Peers view header per t2.zip 09-peers.png:
                                     title + count subtitle (left) + Rescan ghost + All/Online/Offline
                                     segmented (right). PeersSubtitle x:Name preserved so
                                     RefreshPeersList can keep updating the count line. -->
                                <Grid Grid.Row="0" Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Peers" Style="{StaticResource TypeViewTitle}"/>
                                        <TextBlock x:Name="PeersSubtitle" Text="Join the network to see peers"
                                                   Style="{StaticResource TypeViewSubtitle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Style="{StaticResource NeuralBtnGhost}"
                                                Click="RefreshPeers_Click" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x21BB;" FontSize="13" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Rescan" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Border Background="{StaticResource NeuralBgInset}"
                                                BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                CornerRadius="9" Padding="3">
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="7" Padding="10,4"
                                                        Background="{StaticResource NeuralPrimaryBtn}">
                                                    <TextBlock Text="All" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                                <Border CornerRadius="7" Padding="10,4">
                                                    <TextBlock Text="Online" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"/>
                                                </Border>
                                                <Border CornerRadius="7" Padding="10,4">
                                                    <TextBlock Text="Offline" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <!-- Peer cards list — no outer card wrapper (per t2.zip,
                                     each peer is its own NeuralCard, gap between them). -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PeersList"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- ═══ SHARING VIEW ═══
                             Per t2.zip screenshot 10-sharing.png + README §10.
                             The redesign's 2-column "Incoming Requests | History"
                             layout is overlaid on the existing wider feature set
                             (My Address / Demo / Peers with Access kept as
                             preamble cards above the spec-shaped 2-column row). -->
                        <Grid x:Name="SharingView" Visibility="Collapsed">
                            <!-- Main scrollable content. The Add/Edit dialog at the
                                 bottom of this Grid is positioned as a full-area
                                 overlay (separate Z-layer) so it floats over the
                                 scroll content when Visible. -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="28,24,28,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- header -->
                                        <RowDefinition Height="Auto"/> <!-- my address -->
                                        <RowDefinition Height="Auto"/> <!-- demo peer join -->
                                        <RowDefinition Height="Auto"/> <!-- peers list card -->
                                        <RowDefinition Height="Auto"/> <!-- incoming + history 2-col -->
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,22">
                                        <TextBlock Text="Sharing" Style="{StaticResource TypeViewTitle}"/>
                                        <TextBlock x:Name="SharingSubtitle"
                                                   Text="Review and act on incoming share requests · default-deny, you grant per-peer"
                                                   Style="{StaticResource TypeViewSubtitle}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- ─── MY ADDRESS ─── -->
                                    <Border Grid.Row="1" Style="{StaticResource NeuralCard}"
                                            Padding="22" Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,14">
                                                <TextBlock Text="My brain address" FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText}"/>
                                                <TextBlock Text="Share this with peers who want to request access to your knowledge."
                                                           FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource NeuralBgInset}" CornerRadius="6"
                                                        BorderBrush="{StaticResource NeuralLine}" BorderThickness="1" Padding="12,8">
                                                    <TextBlock x:Name="SharingMyAddressText" Text="—" FontFamily="{StaticResource FontMono}"
                                                               FontSize="12" Foreground="{StaticResource NeuralText1}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Button x:Name="SharingCopyAddrBtn" Grid.Column="1" Content="&#x1F4CB; Copy"
                                                        Style="{StaticResource NavButton}" Click="SharingCopyAddrBtn_Click"
                                                        Margin="8,0,0,0" Padding="10,6"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── DEMO: simulate peers joining ───
                                         No-op without a hub: the button fakes three
                                         PeerJoined events locally so the user can
                                         see how the Universe view reacts when peers
                                         appear on the orbit ring. Auto-switches to
                                         the Universe tab so the visual effect is
                                         immediately visible. Self-cleaning — fake
                                         peers fade out after 8 seconds. -->
                                    <Border Grid.Row="2" Style="{StaticResource NeuralCard}"
                                            Padding="22" Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,14">
                                                <TextBlock Text="Live preview" FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText}"/>
                                                <TextBlock Text="Visualize how peers appear on the orbit ring around your galaxy."
                                                           FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="3 simulated peers appear on the orbit ring, then fade out after 8 seconds. No hub required."
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{StaticResource NeuralText2}"
                                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <Button Grid.Column="1" x:Name="SharingDemoPeersBtn"
                                                        Content="&#x1F3AC;  Demo peer join"
                                                        Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="SharingDemoPeersBtn_Click" Padding="14,6"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── PEERS WITH ACCESS ─── -->
                                    <Border Grid.Row="3" Style="{StaticResource NeuralCard}"
                                            Padding="22" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Peers with access" FontSize="16" FontWeight="Bold"
                                                                   Foreground="{StaticResource NeuralText}" VerticalAlignment="Center"/>
                                                        <Border Background="{StaticResource NeuralBgInset}" CornerRadius="999"
                                                                BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                                Padding="8,2" Margin="10,2,0,0" VerticalAlignment="Center">
                                                            <TextBlock x:Name="SharingScopeCountBadge" Text="0" FontSize="11"
                                                                       FontWeight="Bold" Foreground="{StaticResource NeuralText1}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="Default-deny — peers see nothing until you explicitly grant access."
                                                               FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" x:Name="SharingAddScopeBtn" Content="&#x2795;  Grant access"
                                                        Style="{StaticResource NeuralBtnPrimary}" Click="SharingAddScopeBtn_Click"
                                                        Padding="10,5" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Empty state -->
                                            <Border x:Name="SharingEmptyState" Background="{StaticResource NeuralBgInset}"
                                                    BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                    CornerRadius="9" Padding="18" Margin="0,4,0,0">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="&#x1F510;" FontSize="28" HorizontalAlignment="Center"
                                                               Foreground="{StaticResource NeuralTextDim}" Margin="0,0,0,6"/>
                                                    <TextBlock Text="No peers granted access yet"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Default-deny is on. Peers can request, but they see nothing until you grant access."
                                                               FontSize="11.5" TextWrapping="Wrap" TextAlignment="Center"
                                                               Foreground="{StaticResource NeuralText3}" Margin="0,4,0,0"
                                                               MaxWidth="420"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Populated list (filled by RefreshScopesView) -->
                                            <StackPanel x:Name="SharingScopesList"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── 2-COLUMN ROW: INCOMING (left wider) + HISTORY (right) ─── -->
                                    <Grid Grid.Row="4" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- INCOMING REQUESTS — left wider per spec §10. -->
                                        <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,7,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                    <TextBlock Text="INCOMING REQUESTS" FontSize="12.5" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText1}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · consent-gated" FontSize="12.5"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel x:Name="IncomingSharesList">
                                                    <TextBlock Text="No incoming requests" FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}" FontStyle="Italic"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- HISTORY — right narrower per spec §10. -->
                                        <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="7,0,0,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                    <TextBlock Text="HISTORY" FontSize="12.5" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText1}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · last 30 days" FontSize="12.5"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel x:Name="ShareHistoryList">
                                                    <TextBlock Text="No sharing activity yet" FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}" FontStyle="Italic"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </ScrollViewer>

                            <!-- ═════════════════════════════════════════════════ -->
                            <!-- ADD / EDIT SCOPE DIALOG (overlay)                   -->
                            <!-- ═════════════════════════════════════════════════ -->
                            <Border x:Name="ScopeDialogOverlay" Visibility="Collapsed"
                                    Background="#CC000000">
                                <Border Width="560" MaxHeight="700" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource ElectricPurpleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="0" Effect="{StaticResource PurpleGlow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="10,10,0,0" Padding="20,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="ScopeDialogTitle" Text="Grant access"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Choose what this peer is allowed to see. Empty means deny everything (default)."
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;" Style="{StaticResource NavButton}"
                                                        Click="ScopeDialogClose_Click" Padding="8,2" FontSize="14"/>
                                            </Grid>
                                        </Border>

                                        <!-- Body (scrollable) -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                                            <StackPanel>
                                                <!-- Peer address -->
                                                <TextBlock Text="Peer brain address" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ScopeDialogPeerAddress" FontFamily="{StaticResource MonoFont}"
                                                             Padding="8,6" Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                             FontSize="12"/>
                                                    <Button Grid.Column="1" Content="Pick online&#x2026;" Style="{StaticResource NavButton}"
                                                            Click="ScopeDialogPickPeer_Click" Margin="6,0,0,0" Padding="8,4" FontSize="11"/>
                                                </Grid>
                                                <TextBlock x:Name="ScopeDialogPeerHint" Text="" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Visibility level -->
                                                <TextBlock Text="Visibility level" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <StackPanel x:Name="ScopeDialogLevelPanel" Margin="0,0,0,12">
                                                    <RadioButton x:Name="ScopeLevelNone" Tag="None" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Paused (None)" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Peer keeps saved filters but sees nothing."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelMetadata" Tag="MetadataOnly" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Metadata only" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Title + category + word count. No content."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelPreview" Tag="Preview" GroupName="ScopeLevel"
                                                                 IsChecked="True"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Preview" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Metadata + first 480 chars (mirrors brain_search preview)."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelFull" Tag="Full" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Full" FontWeight="SemiBold"/>
                                                                <Border Background="#33FF5566" CornerRadius="3" Padding="4,0" Margin="6,0,0,0">
                                                                    <TextBlock Text="HIGH EXPOSURE" FontSize="9"
                                                                               Foreground="{StaticResource DangerBrush}" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                </StackPanel>

                                                <!-- Allow categories -->
                                                <TextBlock Text="Allow categories" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="Toggle each category the peer may see. None selected = no category-level allow (still works via tag/folder/note-id rules below)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                <WrapPanel x:Name="ScopeDialogCategoryChips" Margin="0,0,0,12"/>

                                                <!-- Allow tags -->
                                                <TextBlock Text="Allow tags (comma-separated)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScopeDialogAllowTags" Padding="8,6" Margin="0,0,0,12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         FontSize="12"/>

                                                <!-- Allow folders -->
                                                <TextBlock Text="Allow folders (comma-separated, path prefixes)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScopeDialogAllowFolders" Padding="8,6" Margin="0,0,0,12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         FontSize="12"/>

                                                <!-- Advanced expander -->
                                                <Expander x:Name="ScopeDialogAdvanced" Header="Advanced filters &#x25BC;"
                                                          Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"
                                                          FontSize="11" FontWeight="SemiBold">
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock Text="Deny tags (override allow)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogDenyTags" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Deny folders (override allow)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogDenyFolders" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Per-note allowlist (note IDs, comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogNoteAllowlist" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Per-note blocklist (highest priority)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogNoteBlocklist" Padding="8,6"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>
                                                    </StackPanel>
                                                </Expander>

                                                <!-- Expiry -->
                                                <TextBlock Text="Expiry" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ScopeDialogExpiry" Padding="8,4" Margin="0,0,0,12"
                                                          Background="{StaticResource SurfaceBrush}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource SurfaceLightBrush}" FontSize="12">
                                                    <ComboBoxItem Content="7 days" Tag="7"/>
                                                    <ComboBoxItem Content="30 days" Tag="30" IsSelected="True"/>
                                                    <ComboBoxItem Content="90 days" Tag="90"/>
                                                    <ComboBoxItem Content="Never (not recommended)" Tag="0"/>
                                                </ComboBox>

                                                <!-- Per-note approval -->
                                                <CheckBox x:Name="ScopeDialogPerNote" IsChecked="True"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2">
                                                    <CheckBox.Content>
                                                        <StackPanel>
                                                            <TextBlock Text="Require per-note approval (recommended)" FontWeight="SemiBold"/>
                                                            <TextBlock Text="Every share request still pops up Accept/Reject even when the scope allows it."
                                                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                                       TextWrapping="Wrap" MaxWidth="460"/>
                                                        </StackPanel>
                                                    </CheckBox.Content>
                                                </CheckBox>
                                                <TextBlock x:Name="ScopeDialogAutoApproveWarn" Visibility="Collapsed"
                                                           Text="&#x26A0; Auto-accept ON — matching notes will be sent without prompting."
                                                           FontSize="10" Foreground="{StaticResource DangerBrush}"
                                                           Margin="22,0,0,12"/>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Footer -->
                                        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="0,0,10,10" Padding="20,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="ScopeDialogError" Text="" Grid.Column="0"
                                                           Foreground="{StaticResource DangerBrush}" FontSize="11"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource NavButton}"
                                                        Click="ScopeDialogClose_Click" Margin="8,0" Padding="14,6"/>
                                                <Button Grid.Column="2" x:Name="ScopeDialogSaveBtn" Content="Save"
                                                        Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="ScopeDialogSave_Click" Padding="18,6"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>

                        <!-- ═══ IMPORT / SCAN VIEW ═══
                             Moved out of the Universe Settings panel so the
                             import / scan flows live in their own first-class
                             tab. Phase 1: Obsidian vault import + indeterminate
                             progress + last-run summary. Phase 2 (deferred):
                             generic folder scan, recent imports history. -->
                        <Grid x:Name="ImportView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,22">
                                    <TextBlock Text="Import / Scan" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock Text="Bring external knowledge into this BrainX vault — originals stay untouched"
                                               Style="{StaticResource TypeViewSubtitle}"/>
                                </StackPanel>

                                <!-- Obsidian Vault Import card -->
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#x1F5C2;" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Foreground="{StaticResource NeonCyanBrush}"/>
                                            <TextBlock Text="OBSIDIAN VAULT" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12">
                                            Pick an existing Obsidian vault folder. Markdown notes and attachments will
                                            be copied into <Run FontWeight="SemiBold">Imported/&lt;vault-name&gt;</Run> here,
                                            preserving folder structure. <Run FontStyle="Italic">[[Wikilinks]]</Run> remain valid.
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="ImportObsidianButton" Content="&#x1F4C2;  Pick Obsidian vault…"
                                                    Style="{StaticResource NeuralBtnPrimary}" Click="ImportObsidianButton_Click"
                                                    Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                                            <Button x:Name="ImportCancelButton" Content="&#x2715;  Cancel"
                                                    Style="{StaticResource NavButton}" Click="ImportCancelButton_Click"
                                                    Padding="14,8" FontSize="12" IsEnabled="False" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Progress card — visible only while an import is running. -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12"
                                        x:Name="ImportProgressCard" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="IN PROGRESS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="ImportProgressText" Text="Working…" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <ProgressBar x:Name="ImportProgressBar" Height="6" IsIndeterminate="True"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     Foreground="{StaticResource NeonCyanBrush}" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Last summary card — populated after each import. -->
                                <Border Grid.Row="3" Style="{StaticResource CardPanel}" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="LAST IMPORT" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="ImportLastSummary">
                                            <TextBlock Text="No imports yet." FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ GROWTH CHART VIEW ═══
                             Per t2.zip 03-growth.png + README §3:
                             header (already migrated) → 3-col KPI row
                             (Cumulative notes / Avg per day / Fastest category)
                             → chart card with sub-title + magenta "leading"
                             chip → staircase canvas → legend swatches. -->
                        <Grid x:Name="GrowthView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,32">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- View header per t2.zip 03-growth.png: title + subtitle + time-range
                                     segmented (14d/30d/90d/All) + Export CSV ghost button -->
                                <Grid Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Knowledge Growth" Style="{StaticResource TypeViewTitle}"/>
                                        <TextBlock Text="Cumulative notes over real time — top categories tracked separately"
                                                   Style="{StaticResource TypeViewSubtitle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Border Background="{StaticResource NeuralBgInset}"
                                                BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                CornerRadius="9" Padding="3" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="7" Padding="10,4"
                                                        Background="{StaticResource NeuralPrimaryBtn}">
                                                    <TextBlock Text="14 d" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                                <Border CornerRadius="7" Padding="10,4">
                                                    <TextBlock Text="30 d" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"/>
                                                </Border>
                                                <Border CornerRadius="7" Padding="10,4">
                                                    <TextBlock Text="90 d" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"/>
                                                </Border>
                                                <Border CornerRadius="7" Padding="10,4">
                                                    <TextBlock Text="All" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText2}"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <Button Style="{StaticResource NeuralBtnGhost}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x2B07;" FontSize="13" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <!-- 3-col KPI row per spec §3 -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                            Padding="20,16" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="CUMULATIVE NOTES" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeuralText3}"/>
                                            <TextBlock x:Name="GrowthKpiCumulative" Text="0" FontSize="36" FontWeight="Bold"
                                                       Foreground="{StaticResource NeuralText}"
                                                       Typography.NumeralAlignment="Tabular" Margin="0,8,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="+" FontSize="13" FontWeight="Bold"
                                                           Foreground="#4AE3A7" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="GrowthKpiCumulativeBurst" Text="0" FontSize="13"
                                                           FontWeight="Bold" Foreground="#4AE3A7"
                                                           Typography.NumeralAlignment="Tabular"
                                                           VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                <TextBlock x:Name="GrowthKpiCumulativeMeta"
                                                           Text="in burst" FontSize="12" FontWeight="Medium"
                                                           Foreground="{StaticResource NeuralText2}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                            Padding="20,16" Margin="4,0,4,0">
                                        <StackPanel>
                                            <TextBlock Text="AVG / DAY" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeuralText3}"/>
                                            <TextBlock x:Name="GrowthKpiAvgDay" Text="0" FontSize="36" FontWeight="Bold"
                                                       Foreground="{StaticResource NeuralText}"
                                                       Typography.NumeralAlignment="Tabular" Margin="0,8,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="GrowthKpiAvgDayDelta" Text="+0%" FontSize="13"
                                                           FontWeight="Bold" Foreground="#4AE3A7"
                                                           Typography.NumeralAlignment="Tabular"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="GrowthKpiAvgDayMeta"
                                                           Text="vs prior 14 days" FontSize="12" FontWeight="Medium"
                                                           Foreground="{StaticResource NeuralText2}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource NeuralCard}"
                                            Padding="20,16" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="FASTEST CATEGORY" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeuralText3}"/>
                                            <TextBlock x:Name="GrowthKpiFastestCat" Text="—" FontSize="32" FontWeight="Bold"
                                                       Foreground="{StaticResource NeuralText}" Margin="0,8,0,4"/>
                                            <TextBlock x:Name="GrowthKpiFastestMeta"
                                                       Text="—" FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource NeuralText2}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="2" Style="{StaticResource NeuralCard}" Padding="22,18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Chart sub-title row -->
                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CUMULATIVE NOTES — LAST 14 DAYS"
                                                           FontSize="12.5" FontWeight="Bold"
                                                           Foreground="{StaticResource NeuralText1}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{StaticResource NeuralBgInset}"
                                                    BorderBrush="{StaticResource NeuralLineAccent}" BorderThickness="1"
                                                    CornerRadius="999" Padding="10,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#4AE3A7" Margin="0,1,6,0"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="GrowthLeadingChip" Text="Programming leading"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText1}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <!-- Staircase chart drawn in code-behind -->
                                        <Canvas x:Name="GrowthCanvas" Grid.Row="1" Margin="0,0,0,12"/>
                                        <StackPanel x:Name="GrowthLegend" Grid.Row="2" Orientation="Horizontal"
                                                    HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ TOKEN ECONOMY VIEW ═══
                             Side-by-side comparison of "actual usage with brain" vs
                             "projection without brain". Both lines are HEURISTIC
                             estimates based on access-log.ndjson + tool-log.ndjson.
                             We don't see real Anthropic API tokens. -->
                        <Grid x:Name="TokensView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,22">
                                    <TextBlock Text="Token Economy" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock Text="Per-hour comparison: actual tokens (with brain) vs projected without brain — heuristic from local logs"
                                               Style="{StaticResource TypeViewSubtitle}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <!-- Top-line stat cards -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="ACTUAL SPENT" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensActualText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="tokens, last 14 days" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="WITHOUT BRAIN (PROJECTION)" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensProjectionText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonPinkBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="if no brain shortcuts" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="SAVED" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensSavedText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="#5DFF9D"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock x:Name="TokensSavedPctText" Text="0%" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="8,0,0,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="CALLS" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensCallsText" Text="0 / 0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="brain / other" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Comparison chart -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                    <Border.Resources>
                                        <!-- Pill-style toggle used by range + view-mode buttons. -->
                                        <Style x:Key="TokensChip" TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#1A1A2E"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,4"/>
                                            <Setter Property="Margin" Value="0,0,4,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}"
                                                                CornerRadius="11">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource NeonCyanBrush}"/>
                                                    <Setter Property="Foreground" Value="#0B0B1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Resources>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Toolbar: time range + view mode -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock Text="Range" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ToggleButton x:Name="TokensRange1d" Content="1d"
                                                              Style="{StaticResource TokensChip}" Tag="24"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange7d" Content="7d"
                                                              Style="{StaticResource TokensChip}" Tag="168"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange14d" Content="14d"
                                                              Style="{StaticResource TokensChip}" Tag="336" IsChecked="True"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange30d" Content="30d"
                                                              Style="{StaticResource TokensChip}" Tag="720"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRangeAll" Content="All"
                                                              Style="{StaticResource TokensChip}" Tag="43800"
                                                              Click="TokensRange_Click"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="View" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ToggleButton x:Name="TokensViewBucket" Content="Per-bucket" IsChecked="True"
                                                              Style="{StaticResource TokensChip}"
                                                              Click="TokensViewMode_Click"/>
                                                <ToggleButton x:Name="TokensViewCumulative" Content="Cumulative"
                                                              Style="{StaticResource TokensChip}"
                                                              Click="TokensViewMode_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Chart canvas + hover overlay (overlay is hit-test invisible
                                             so MouseMove falls through to TokensCanvas). -->
                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Canvas x:Name="TokensCanvas" Background="Transparent"
                                                    MouseMove="TokensCanvas_MouseMove"
                                                    MouseLeave="TokensCanvas_MouseLeave"/>
                                            <Canvas x:Name="TokensOverlay" IsHitTestVisible="False">
                                                <Line x:Name="TokensCrosshair" Visibility="Collapsed"
                                                      Stroke="#88FFFFFF" StrokeThickness="1"
                                                      StrokeDashArray="2,2"/>
                                                <Border x:Name="TokensTooltip" Visibility="Collapsed"
                                                        Background="#EE0F1A2E"
                                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                                        CornerRadius="4" Padding="10,8" MaxWidth="240">
                                                    <StackPanel>
                                                        <TextBlock x:Name="TokensTooltipTime" FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontFamily="{StaticResource MonoFont}" Margin="0,0,0,4"/>
                                                        <TextBlock x:Name="TokensTooltipMode" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="actual " FontSize="10"
                                                                       Foreground="#5DFF9D" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TokensTooltipActual"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="saved " FontSize="10"
                                                                       Foreground="#FF6B9D" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TokensTooltipSaved"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="proj. " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TokensTooltipProj"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="brain " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,4,8,0"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TokensTooltipBrainCalls"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="tools " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TokensTooltipOtherCalls"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Canvas>
                                        </Grid>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Width="14" Height="3" Background="#5DFF9D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="actual (with brain)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                            <Border Width="14" Height="3" Background="#FF6B9D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="saved (vs no-brain projection)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                            <Border Width="14" Height="3" Background="#FFC040" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="bypass-mode bucket" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ INSIGHTS VIEW ═══
                             Active learning loop surfaced in the UI. Reads
                             access-log.ndjson via QueryGapAnalyzer (same
                             code as the brain_suggest_topics MCP tool) and
                             lists queries the user kept asking but the
                             brain didn't answer well — candidates for new
                             notes. -->
                        <Grid x:Name="InsightsView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,22">
                                    <TextBlock Text="Brain Insights" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock Text="Topics you keep searching for but the brain isn't answering well — candidates for a new note"
                                               Style="{StaticResource TypeViewSubtitle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <!-- Top-line stat cards -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="WINDOW" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsWindowText" Text="14 days" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="of search history" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="SEARCHES / UNIQUE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsSearchesText" Text="0 / 0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="total / distinct queries" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="GAPS DETECTED" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsGapCountText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="#FFC040"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="topics worth a note" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Grid.Column="3" x:Name="InsightsRefreshBtn"
                                            Content="↻  Refresh"
                                            Style="{StaticResource NavButton}"
                                            VerticalAlignment="Center"
                                            Padding="14,8"
                                            Click="InsightsRefresh_Click"/>
                                </Grid>
                                <!-- Suggestion list -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="InsightsList" Margin="8"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ EDITOR VIEW ═══ -->
                        <Grid x:Name="EditorView" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Editor toolbar -->
                                <Border Grid.Row="0" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,0,0,1"
                                        Padding="8,4">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="EditorFileTitle" Text="No file open" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock x:Name="EditorDirtyIndicator" Text="" FontSize="13"
                                                       FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="EditorSaveBtn" Content="&#x1F4BE; Save"
                                                    Style="{StaticResource NeuralBtnPrimary}" Click="EditorSave_Click"
                                                    Padding="12,4" FontSize="11" Margin="2,0,8,0"
                                                    ToolTip="Save current note (Ctrl+S)"/>
                                            <Button Content="New" Style="{StaticResource NavButton}" Click="EditorNew_Click"
                                                    Padding="10,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H1" Style="{StaticResource NavButton}" Click="EditorH1_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H2" Style="{StaticResource NavButton}" Click="EditorH2_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="B" Style="{StaticResource NavButton}" Click="EditorBold_Click"
                                                    Padding="8,4" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                            <Button Content="I" Style="{StaticResource NavButton}" Click="EditorItalic_Click"
                                                    Padding="8,4" FontSize="11" FontStyle="Italic" Margin="2,0"/>
                                            <Button Content="[[]]" Style="{StaticResource NavButton}" Click="EditorLink_Click"
                                                    Padding="8,4" FontSize="11" Foreground="{StaticResource NeonCyanBrush}" Margin="2,0"/>
                                            <Button Content="`code`" Style="{StaticResource NavButton}" Click="EditorCode_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="[ ]" Style="{StaticResource NavButton}" Click="EditorTask_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Split: Editor + Preview -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Code editor -->
                                    <ae:TextEditor x:Name="MarkdownEditorControl" Grid.Column="0"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                   FontSize="14" ShowLineNumbers="True" WordWrap="True"
                                                   Background="{StaticResource DeepSpaceBrush}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Padding="8"/>

                                    <!-- Splitter -->
                                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                                  Background="{StaticResource SurfaceLightBrush}" Cursor="SizeWE"/>

                                    <!-- Preview -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{StaticResource DeepSpaceBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,0,0,0">
                                            <FlowDocumentScrollViewer x:Name="MarkdownPreview"
                                                                       VerticalScrollBarVisibility="Auto"
                                                                       IsToolBarVisible="False"/>
                                        </Border>

                                        <!-- Backlinks panel -->
                                        <Border Grid.Row="1" Background="{StaticResource DarkPanelBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,1,0,0"
                                                MaxHeight="160">
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="BACKLINKS" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                <ScrollViewer MaxHeight="110" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="BacklinksPanel"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Editor status bar -->
                                <Border Grid.Row="2" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0"
                                        Padding="12,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="EditorCursorPos" Text="Ln 1, Col 1" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock x:Name="EditorWordCount" Text="0 words" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Ctrl+S Save | Ctrl+B Bold | Ctrl+I Italic | Ctrl+K WikiLink | Ctrl+F Search"
                                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}" Opacity="0.5"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ SEARCH VIEW ═══
                             Per t2.zip 06-search.png + README §7. Centered
                             max-width 920 px layout, 50 px tall search box with
                             a magnifier on the left + ⌘F kbd on the right,
                             filter pills row, then stacked result cards. -->
                        <Grid x:Name="SearchView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16" MaxWidth="980" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,22">
                                    <TextBlock Text="Search" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock x:Name="SearchSubtitle"
                                               Text="Full-text search across all notes"
                                               Style="{StaticResource TypeViewSubtitle}"/>
                                </StackPanel>

                                <!-- 50 px tall search box with magnifier + kbd chip -->
                                <Border Grid.Row="1" Margin="0,0,0,16"
                                        Background="{StaticResource NeuralBgInset}"
                                        BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                        CornerRadius="10" MinHeight="50">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#x1F50E;" FontSize="16"
                                                   Foreground="{StaticResource NeuralText3}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource NeuralText}"
                                                 CaretBrush="#9d7bff"
                                                 FontSize="14.5"
                                                 Padding="0,12" VerticalAlignment="Center"
                                                 KeyDown="SearchBox_KeyDown"
                                                 Tag="Search notes... (Enter to search)"/>
                                        <Border Grid.Column="2" Margin="0,0,14,0" VerticalAlignment="Center"
                                                Background="{StaticResource NeuralBgCard2}"
                                                BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                                CornerRadius="6" Padding="8,3">
                                            <TextBlock Text="&#x2318; F" FontSize="10.5"
                                                       FontFamily="{StaticResource FontMono}"
                                                       Foreground="{StaticResource NeuralText3}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Filter pills row + result count meta -->
                                <Grid Grid.Row="2" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <Button Content="All" Style="{StaticResource NavButtonActive}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="All"
                                                Click="SearchFilter_Click"/>
                                        <Button Style="{StaticResource NavButton}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="Programming"
                                                Click="SearchFilter_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#5be9e9" Margin="0,1,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Programming"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource NavButton}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="DataScience"
                                                Click="SearchFilter_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#ffc23c" Margin="0,1,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="DataScience"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource NavButton}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="Design"
                                                Click="SearchFilter_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#ff4f9e" Margin="0,1,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Design / Art"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource NavButton}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="Engineering"
                                                Click="SearchFilter_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#4ae3a7" Margin="0,1,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Engineering"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource NavButton}"
                                                Padding="14,5" Margin="0,0,4,0" Tag="AI"
                                                Click="SearchFilter_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#9d7bff" Margin="0,1,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="AI / MachineLearning"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" x:Name="SearchMetaText"
                                               Text="" FontSize="11.5"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource NeuralText3}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="SearchResults"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- ═══ UNIVERSE VIEW (WebView2 + three.js + embedded 2D) ═══
                             Available from sidebar; Dashboard is the default startup
                             view again. WebView2 lives inside this content cell so the
                             WPF chrome (sidebar/title/status) stays visible and
                             interactive — the airspace rule keeps the WebView out of
                             the chrome's area. InitializeUniverseAsync is triggered on
                             first nav click to this view, not on app startup, so the
                             WebView2 spin-up cost is paid only when the user asks for
                             it. -->
                        <Grid x:Name="UniverseView" Visibility="Collapsed">
                            <!-- User: "เอาแถบบนออกทั้งแถบ" — Brain Graph view header
                                 (title + subtitle + 3D/2D + Filter + Re-layout) removed.
                                 The Universe galaxy is now full-bleed — no chrome eating
                                 vertical space. Sidebar still tells the user which view
                                 they're on, and 3D/2D can still be toggled from the
                                 floating WPF pill (UniverseViewToggle) below. -->

                            <!-- 3D Universe (WebView2 + three.js) — default visible -->
                            <Border x:Name="UniverseWebBorder" Background="#FF000308" ClipToBounds="True">
                                <wv2:WebView2 x:Name="UniverseWebView" DefaultBackgroundColor="Black"/>
                            </Border>

                            <!-- ═══ MINI LOADING OVERLAY (v2.6.1+) ═══
                                 Sits ON TOP of the WebView while the three.js
                                 scene boots. Hides after JS posts {type:"ready"}
                                 and we've pushed the brain snapshot. Pattern
                                 matches the splash screen aesthetic for
                                 visual continuity — neon ring spinning around
                                 a static diamond, mono-font status lines.
                                 Backdrop is 88% opaque so the empty WebView's
                                 black void is masked but the WebView still
                                 receives the navigation paint underneath. -->
                            <Border x:Name="UniverseLoadingOverlay"
                                    Background="#DD000308"
                                    Panel.ZIndex="50"
                                    Visibility="Visible">
                                <Border Background="#FF0E0C24"
                                        BorderBrush="#886CF0FF" BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="24,18"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        MinWidth="280">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FF6CF0FF" BlurRadius="24"
                                                          ShadowDepth="0" Opacity="0.45"/>
                                    </Border.Effect>
                                    <StackPanel HorizontalAlignment="Center">
                                        <!-- Spinning neon ring -->
                                        <Grid Width="44" Height="44" Margin="0,0,0,8"
                                              HorizontalAlignment="Center">
                                            <Ellipse Width="44" Height="44"
                                                     Stroke="#226CF0FF" StrokeThickness="2"/>
                                            <Ellipse Width="44" Height="44"
                                                     Stroke="#FF6CF0FF" StrokeThickness="2"
                                                     StrokeDashArray="2 8"
                                                     RenderTransformOrigin="0.5,0.5">
                                                <Ellipse.RenderTransform>
                                                    <RotateTransform x:Name="UniverseLoadingRotate" Angle="0"/>
                                                </Ellipse.RenderTransform>
                                                <Ellipse.Triggers>
                                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingRotate"
                                                                    Storyboard.TargetProperty="Angle"
                                                                    From="0" To="360"
                                                                    Duration="0:0:1.8"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Ellipse.Triggers>
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#FF6CF0FF" BlurRadius="12"
                                                                      ShadowDepth="0" Opacity="0.9"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Text="◆" FontSize="16"
                                                       Foreground="#FFFF2E94"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FFFF2E94" BlurRadius="10"
                                                                      ShadowDepth="0" Opacity="0.8"/>
                                                </TextBlock.Effect>
                                                <TextBlock.RenderTransform>
                                                    <ScaleTransform x:Name="UniverseLoadingDiamondScale"
                                                                    ScaleX="1" ScaleY="1"/>
                                                </TextBlock.RenderTransform>
                                                <TextBlock.Triggers>
                                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingDiamondScale"
                                                                    Storyboard.TargetProperty="ScaleX"
                                                                    From="1.0" To="1.25" Duration="0:0:0.9"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingDiamondScale"
                                                                    Storyboard.TargetProperty="ScaleY"
                                                                    From="1.0" To="1.25" Duration="0:0:0.9"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock x:Name="UniverseLoadingText"
                                                   Text="Initializing Universe galaxy..."
                                                   FontSize="11"
                                                   FontFamily="Consolas, JetBrains Mono, Cascadia Mono"
                                                   Foreground="#FFE8E6FF"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="UniverseLoadingSubText"
                                                   Text="three.js + WebView2"
                                                   FontSize="9"
                                                   FontFamily="Consolas, JetBrains Mono, Cascadia Mono"
                                                   Foreground="#88A0A8C8"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <!-- 2D Graph (WriteableBitmap renderer) — collapsed by default.
                                 Shares _graphPhysics with the (hidden) BrainGraphView so
                                 MCP pulse flashes here too. -->
                            <Border x:Name="UniverseGraph2DBorder" CornerRadius="0" ClipToBounds="True"
                                    Visibility="Collapsed"
                                    MouseLeftButtonDown="Graph2D_MouseDown"
                                    MouseLeftButtonUp="Graph2D_MouseUp"
                                    MouseMove="Graph2D_MouseMove"
                                    MouseWheel="Graph2D_MouseWheel"
                                    MouseRightButtonDown="Graph2D_RightClick">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Assets/bk1.png"
                                                Stretch="UniformToFill" Opacity="0.3"/>
                                </Border.Background>
                                <services:Graph2DRenderer x:Name="UniverseGraph2D"/>
                            </Border>

                            <!-- WPF floating 3D/2D toggle — restored now that the Brain
                                 Graph view header is gone. Pinned top-right corner of
                                 the Universe view, sits on top of the WebView via
                                 Panel.ZIndex=100. Tiny pill, doesn't crowd the galaxy. -->
                            <Border x:Name="UniverseViewToggle"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,18,18,0" Padding="0"
                                    Panel.ZIndex="100"
                                    CornerRadius="999"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="UniverseViewToggle_Click">
                                <Border.Background>
                                    <SolidColorBrush Color="#CC0A081C"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#446CF0FF"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                                      Color="#000000" Opacity="0.55"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" Margin="4,3">
                                    <TextBlock x:Name="UniverseViewLabel3D" Text="3D"
                                               Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF6CF0FF" />
                                    <TextBlock Text="·" Padding="2,4" FontSize="11"
                                               Foreground="#665A5680"/>
                                    <TextBlock x:Name="UniverseViewLabel2D" Text="2D"
                                               Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF8A86B8" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ═══ SSH VIEW ═══
                             Owner-realm SSH gateway settings. The brain holds
                             whitelisted SSH profiles + audit log; this page
                             shows what's configured AND teaches the owner how
                             to set up the server side step by step.

                             3-realm model:
                               • Owner-Claude (this MCP server)  → guarded run
                               • Owner-interactive (future)      → no guard
                               • Peers (BrainHub)                → no SSH at all
                             See [[Join Brain v2 + Brain-as-SSH-Gateway —
                             realm separation threat surface]] in the brain. -->
                        <Grid x:Name="SshView" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="24,16,24,40" MaxWidth="980" HorizontalAlignment="Left">

                                    <!-- HEADER -->
                                    <TextBlock Text="SSH Tools" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Owner-realm SSH gateway so Claude (via MCP) can grep server logs, check Exim queue, read WP config — whitelisted commands only"
                                               Style="{StaticResource TypeViewSubtitle}" Margin="0,2,0,22"/>

                                    <!-- STATUS CARD -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock x:Name="SshStatusLine" Text="Loading profiles…" FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="SshConfigPathText" Text="—" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFont}" TextWrapping="NoWrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#x1F4DD; Open profiles.json" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenProfiles_Click" Margin="0,0,8,0"/>
                                                <Button Content="&#x1F511; Open known_hosts" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenKnownHosts_Click" Margin="0,0,8,0"/>
                                                <Button Content="&#x1F4DC; Open audit log" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenAuditLog_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- REGISTERED PROFILES -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="REGISTERED PROFILES" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="SshAddProfileBtn" Content="&#x2795;  Add profile"
                                                        Style="{StaticResource NeuralBtnPrimary}" Click="SshAddProfile_Click"
                                                        Padding="14,6" FontSize="11"/>
                                            </Grid>
                                            <StackPanel x:Name="SshProfilesList"/>
                                            <Border x:Name="SshProfilesEmpty" Background="{StaticResource SurfaceBrush}"
                                                    Padding="20" CornerRadius="6" Visibility="Collapsed">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="No profiles yet" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center"
                                                               Text="Follow the 7-step setup below to register your first host. A template will be created automatically on first MCP call."
                                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                               TextAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- HOW IT WORKS -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="HOW IT WORKS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"
                                                       Text="Claude (running through brainx-mcp) asks the brain to run a command on your behalf. The brain checks the profile's allow_patterns. If the command matches, it dials the host using the profile's SSH key and returns the output. If it doesn't match, the request is denied without dialing. Every call — allowed, denied, or MITM-flagged — is logged to .obsidianx/access-log.ndjson and pulses on the Universe graph."/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"
                                                       Text="Defense in depth: the client-side allow_patterns catch programmer mistakes; the server-side command=&quot;...&quot; pin in authorized_keys (Step 3-4 below) catches MCP-server compromise. Use both — they protect against different attacker models."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- SETUP GUIDE HEADER -->
                                    <TextBlock Text="Server setup — 7 steps" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,16,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                                               Text="Do these once per server. Steps 1, 5, 6 are local (your laptop). Steps 2, 3, 4 are on the remote host. Copy buttons next to each block."
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>

                                    <!-- STEP 1 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 1" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Generate a dedicated SSH key (local — PowerShell)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="One key per (host, intent). Don't reuse your personal SSH key — if Claude's key leaks, you want a small blast radius. ED25519 is small, fast, and modern."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode1" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="ssh-keygen -t ed25519 -f $HOME\.ssh\claude_myserver_readonly_ed25519 -C &quot;claude-readonly-myserver&quot; -N &quot;&quot;"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode1"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 2 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 2" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Upload public key to the server (local — PowerShell)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Pipe the public key over your existing SSH connection. Replace HOST/USER. If you already use ssh-copy-id (WSL/Git Bash), that works too."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode2" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="type $HOME\.ssh\claude_myserver_readonly_ed25519.pub | ssh admin@YOUR_SERVER_IP &quot;mkdir -p ~/.ssh; chmod 700 ~/.ssh; tee -a ~/.ssh/authorized_keys; chmod 600 ~/.ssh/authorized_keys&quot;"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode2"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 3 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonPinkBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 3" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="Pin the key to a forced command (remote — SSH in and edit)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="SSH into the server and edit ~/.ssh/authorized_keys. Find the line you just appended (it ends with the comment claude-readonly-myserver) and prepend the restrictions below. This is the second layer of defense — even if the brain's allow_patterns are bypassed, the server itself refuses unlisted commands."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode3" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="command=&quot;/home/admin/bin/claude-readonly-shell&quot;,no-port-forwarding,no-X11-forwarding,no-agent-forwarding,no-pty ssh-ed25519 AAAA...PASTE_PUBLIC_KEY... claude-readonly-myserver"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode3"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 4 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonPinkBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 4" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="Create the server-side allowlist shell (remote)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="The pinned `command=` from Step 3 points here. This script reads $SSH_ORIGINAL_COMMAND (what Claude tried to run) and re-checks it against the same allowlist on the server. Add new case patterns when you grow the profile."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode4" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="mkdir -p ~/bin&#x0A;cat &gt; ~/bin/claude-readonly-shell &lt;&lt;'SHELL'&#x0A;#!/bin/bash&#x0A;case &quot;$SSH_ORIGINAL_COMMAND&quot; in&#x0A;  &quot;exim -bpc&quot;|&quot;df -h&quot;|&quot;free -m&quot;|&quot;uptime&quot;) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  &quot;tail -n &quot;[0-9]*&quot; /var/log/&quot;*) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  &quot;wp option get &quot;*&quot; --path=/home/admin/domains/&quot;*) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  *) echo &quot;denied by claude-readonly-shell: $SSH_ORIGINAL_COMMAND&quot; &gt;&amp;2; exit 1 ;;&#x0A;esac&#x0A;SHELL&#x0A;chmod +x ~/bin/claude-readonly-shell"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode4"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 5 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 5" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Register the profile in ssh-profiles.json (local)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Click 'Open profiles.json' at the top, then paste this profile object inside the &quot;profiles&quot; array (replace the example-readonly placeholder if it's still there). The allow_patterns here MUST be a subset of (or equal to) the server-side cases in Step 4 — keep them in sync or you'll get unexpected denies."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode5" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="{}{&#x0A;  &quot;id&quot;: &quot;myserver-readonly&quot;,&#x0A;  &quot;description&quot;: &quot;DirectAdmin host — log tails, exim queue, WP option reads. command= pinned on server.&quot;,&#x0A;  &quot;host&quot;: &quot;YOUR_SERVER_IP&quot;,&#x0A;  &quot;port&quot;: 22,&#x0A;  &quot;user&quot;: &quot;admin&quot;,&#x0A;  &quot;key_path&quot;: &quot;C:\\\\Users\\\\YOU\\\\.ssh\\\\claude_myserver_readonly_ed25519&quot;,&#x0A;  &quot;allow_patterns&quot;: [&#x0A;    &quot;^exim -bpc$&quot;,&#x0A;    &quot;^df -h$&quot;,&#x0A;    &quot;^free -m$&quot;,&#x0A;    &quot;^uptime$&quot;,&#x0A;    &quot;^tail -n \\\\d+ /var/log/[\\\\w./-]+$&quot;,&#x0A;    &quot;^wp option get [\\\\w_-]+ --path=/home/admin/domains/[\\\\w.-]+/public_html$&quot;&#x0A;  ],&#x0A;  &quot;deny_patterns&quot;: [&quot;;&quot;, &quot;&amp;&amp;&quot;, &quot;\\\\|&quot;, &quot;&gt;&quot;, &quot;&gt;&gt;&quot;, &quot;\\\\$\\\\(&quot;, &quot;`&quot;, &quot;\\\\\\\\&quot;],&#x0A;  &quot;max_runtime_sec&quot;: 30,&#x0A;  &quot;audit_to_brain&quot;: true&#x0A;}"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode5"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 6 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 6" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Restart Claude Code so the new MCP binary loads" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Close all Claude Code / Claude Desktop / CluadeX windows that have brainx-mcp running. Then open a fresh Claude Code session — it'll spawn brainx-mcp v2.5.0 which has the SSH tools registered."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode6" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="Get-Process brainx-mcp -ErrorAction SilentlyContinue | Stop-Process -Force"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode6"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 7 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 7" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Smoke test — ask Claude these 5 things in order" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Send these to a fresh Claude session. The 4th MUST be denied (proves the guard works); the 5th MUST be rejected by ssh_tail's path validator (proves shell-injection is impossible)."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode7" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="1) ดู SSH profile ที่มีให้หน่อย                  → ssh_profiles_list ต้องเจอ myserver-readonly&#x0A;2) เช็คคิว mail ของเซิฟ myserver                    → ssh_run exim -bpc ต้องคืนตัวเลข&#x0A;3) tail mainlog 50 บรรทัด                         → ssh_tail /var/log/exim/mainlog lines=50&#x0A;4) ลอง rm /tmp/test ดู                            → ssh_run rm ต้องได้ allowed:false reason=NotInAllowList&#x0A;5) เช็ค path: /var/log/x; rm -rf /                → ssh_tail ต้อง reject ที่ TailPathSafe"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode7"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- AUDIT FOOTNOTE -->
                                    <Border Background="{StaticResource SurfaceBrush}" Padding="16" CornerRadius="6" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="VERIFY AUDIT AFTER SMOKE TEST" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Click 'Open audit log' at the top — you should see new lines with node_id starting 'ssh:myserver-readonly' and op fields ssh_ok / ssh_denied / ssh_mitm matching what you exercised."/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="If a future connect ever returns host_key_mismatch=true, STOP. That means the server's host key changed — possible MITM, or someone reinstalled the box. Verify the new fingerprint manually before clearing the entry from ssh-known-hosts.txt."/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═════════════════════════════════════════════════ -->
                            <!-- SSH PROFILE ADD / EDIT DIALOG (overlay)             -->
                            <!-- Mirrors the Sharing tab's ScopeDialogOverlay        -->
                            <!-- modal pattern. Visibility flipped from              -->
                            <!-- MainWindow.Ssh.cs via OpenSshDialog().              -->
                            <!-- ═════════════════════════════════════════════════ -->
                            <Border x:Name="SshDialogOverlay" Visibility="Collapsed"
                                    Background="#CC000000">
                                <Border Width="620" MaxHeight="780" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource ElectricPurpleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="0" Effect="{StaticResource PurpleGlow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="10,10,0,0" Padding="20,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="SshDialogTitle" Text="Add SSH profile"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Register a server Claude can dial. The key path stays local — only the connection metadata is written to ssh-profiles.json."
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;" Style="{StaticResource NavButton}"
                                                        Click="SshDialogClose_Click" Padding="8,2" FontSize="14"/>
                                            </Grid>
                                        </Border>

                                        <!-- Body -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                                            <StackPanel>
                                                <!-- Profile Id -->
                                                <TextBlock Text="Profile id (kebab-case, e.g. myserver-readonly)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogId" Padding="8,6" Margin="0,0,0,12"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Description -->
                                                <TextBlock Text="Description (one line — shown in tool result + audit context)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogDescription" Padding="8,6" Margin="0,0,0,12"
                                                         FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Host + Port -->
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Host (IP or DNS)" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogHost" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <TextBlock Text="Port" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogPort" Text="22" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- User -->
                                                <TextBlock Text="SSH username" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogUser" Padding="8,6" Margin="0,0,0,12"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Key path + Browse -->
                                                <TextBlock Text="Private key path (absolute — never copied into the JSON, only the path)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="SshDialogKeyPath" Padding="8,6"
                                                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                             Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    <Button Grid.Column="1" Content="Browse&#x2026;" Style="{StaticResource NavButton}"
                                                            Click="SshDialogBrowseKey_Click" Padding="14,6" Margin="6,0,0,0" FontSize="11"/>
                                                </Grid>

                                                <!-- Passphrase -->
                                                <TextBlock Text="Key passphrase (if the key is encrypted — masked)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <PasswordBox x:Name="SshDialogPassphrase" Padding="8,6" Margin="0,0,0,4"
                                                             FontSize="12"
                                                             Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="&#x26A0; Stored plaintext in ssh-profiles.json for Phase 1. Prefer a passphrase-less key with on-disk perms 600 + a command= pin on the server (see setup guide)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Allow patterns (multiline) -->
                                                <TextBlock Text="Allow patterns (one regex per line, anchored ^...$ recommended)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogAllowPatterns" Padding="8,6" Margin="0,0,0,4"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" Height="110"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="A command MUST fully match at least one pattern. Empty = no command allowed (default-deny)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Deny patterns (multiline) -->
                                                <TextBlock Text="Deny patterns (one per line — match anywhere → block)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogDenyPatterns" Padding="8,6" Margin="0,0,0,4"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" Height="80"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="Defaults are pre-filled with shell metacharacter blocks. Keep them — they catch foot-guns like `tail … ; rm -rf /`."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Runtime + checkboxes -->
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Max runtime (seconds)" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogMaxRuntime" Text="30" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Bottom">
                                                        <CheckBox x:Name="SshDialogRequireConfirm"
                                                                  Content="Require confirmation every call (for destructive profiles)"
                                                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                        <CheckBox x:Name="SshDialogAuditToBrain" IsChecked="True"
                                                                  Content="Audit every call to brain access-log"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Footer -->
                                        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="0,0,10,10" Padding="20,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="SshDialogError" Text="" Grid.Column="0"
                                                           Foreground="{StaticResource DangerBrush}" FontSize="11"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource NavButton}"
                                                        Click="SshDialogClose_Click" Margin="8,0" Padding="14,6"/>
                                                <Button Grid.Column="2" x:Name="SshDialogSaveBtn" Content="Save"
                                                        Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="SshDialogSave_Click" Padding="18,6"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>

                        <!-- ═══ SETTINGS VIEW ═══
                             Per t2.zip screenshot 11-settings.png + README §11:
                             - 220 px sticky left nav (Identity / Vault / Ai Keys /
                               Network / Mcp / Storage / About) → clicks BringIntoView
                               the matching section anchor in the right-side scroller.
                             - Right column is the existing settings stack restyled
                               with NeuralCard surfaces + mixed-case 16 px titles +
                               13 px gray subtitles (instead of the old UPPERCASE
                               11 px gray label).
                             All existing x:Name and Click handlers are preserved —
                             only chrome changed, no functional regression. -->
                        <Grid x:Name="SettingsView" Visibility="Collapsed">
                            <Grid Margin="28,24,28,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,22">
                                    <TextBlock Text="Settings" Style="{StaticResource TypeViewTitle}"/>
                                    <TextBlock Text="Identity · vault · AI keys · network · system"
                                               Style="{StaticResource TypeViewSubtitle}"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- LEFT NAV — clicks jump the right scroller to anchor. -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <Button x:Name="SettingsNavIdentity" Content="Identity"
                                                Style="{StaticResource NavButtonActive}"
                                                Click="SettingsJump_Click" Tag="Identity"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavVault" Content="Vault"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="Vault"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavAiKeys" Content="Ai Keys"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="AiKeys"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavNetwork" Content="Network"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="Network"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavMcp" Content="Mcp"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="Mcp"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavStorage" Content="Storage"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="Storage"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                        <Button x:Name="SettingsNavAbout" Content="About"
                                                Style="{StaticResource NavButton}"
                                                Click="SettingsJump_Click" Tag="About"
                                                HorizontalContentAlignment="Left" Padding="14,8"
                                                Margin="0,0,0,2"/>
                                    </StackPanel>
                                    <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="8,0,4,8">
                                        <StackPanel>
                                        <!-- Brain Identity — violet-tinted Identity card per spec §11. -->
                                        <Border x:Name="SettingsAnchorIdentity"
                                                Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#251D44" Offset="0"/>
                                                    <GradientStop Color="#1A1535" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Brain identity" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock Text="ECDSA wallet-style address used to sign your shared knowledge."
                                                               FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="Display Name" FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}" Margin="0,0,0,4"
                                                           FontWeight="SemiBold"/>
                                                <TextBox x:Name="SettingsBrainName" Style="{StaticResource NeonTextBox}"
                                                         Margin="0,0,0,12"/>
                                                <TextBlock Text="Brain Address (read-only)" FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}" Margin="0,0,0,4"
                                                           FontWeight="SemiBold"/>
                                                <TextBox x:Name="SettingsBrainAddress" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Save Name" Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="SaveBrainName_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Vault Path -->
                                        <Border x:Name="SettingsAnchorVault"
                                                Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Vault" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock Text="Where BrainX watches your Markdown files."
                                                               FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="VAULT PATH" FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}" Margin="0,0,0,4"
                                                           FontWeight="SemiBold"/>
                                                <TextBox x:Name="SettingsVaultPath" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Change Vault Path" Style="{StaticResource NeuralBtnGhost}"
                                                        Click="ChangeVaultPath_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                                <TextBlock Text="Auto-detects changes via FileSystemWatcher"
                                                           FontSize="11" Margin="0,12,0,0"
                                                           Foreground="{StaticResource NeuralText3}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Network -->
                                        <Border x:Name="SettingsAnchorNetwork"
                                                Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Network" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock Text="Mesh server endpoint that brokers peer connections."
                                                               FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="SERVER URL" FontSize="11"
                                                           Foreground="{StaticResource NeuralText3}" Margin="0,0,0,4"
                                                           FontWeight="SemiBold"/>
                                                <TextBox x:Name="SettingsServerUrl" Style="{StaticResource NeonTextBox}"
                                                         Text="https://serverbrain.myserver.com/brain-hub" Margin="0,0,0,12"/>
                                                <Button Content="Save Server URL" Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="SaveServerUrl_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto-Import Scanner -->
                                        <Border Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Auto-import scanner" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0"
                                                               TextWrapping="Wrap">
                                                        Scans paths for CLAUDE.md, README.md, *.md using a priority-queue walk with
                                                        archetype-aware descent and 64-bit SimHash near-duplicate detection.
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Text="Scan paths" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ListBox x:Name="ScanPathsList" Height="80"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         Margin="0,0,0,8"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Button Content="+ Add folder" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="AddScanPath_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="− Remove" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="RemoveScanPath_Click" Padding="12,6"/>
                                                </StackPanel>

                                                <CheckBox x:Name="ScanWholeMachineCheck" Content="Scan whole machine (all fixed drives — slower)"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                                                          Checked="ScanWholeMachineCheck_Changed" Unchecked="ScanWholeMachineCheck_Changed"/>
                                                <CheckBox x:Name="AutoScanOnStartupCheck" Content="Auto-scan + import on startup"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"
                                                          Checked="AutoScanOnStartup_Changed" Unchecked="AutoScanOnStartup_Changed"/>

                                                <TextBlock Text="File patterns (semicolon-separated, supports *, ?)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScanPatternsBox" Style="{StaticResource NeonTextBox}"
                                                         Text="CLAUDE.md;README.md;*.md" Margin="0,0,0,8"/>

                                                <TextBlock Text="Import mode" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ImportModeCombo" Margin="0,0,0,12"
                                                          Background="{StaticResource SurfaceBrush}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          SelectionChanged="ImportMode_Changed">
                                                    <ComboBoxItem Content="Reference — stub + wiki-link to original (safer)" IsSelected="True"/>
                                                    <ComboBoxItem Content="Copy — full content copied into vault"/>
                                                </ComboBox>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button x:Name="PreviewScanButton" Content="Preview Scan"
                                                            Style="{StaticResource NeuralBtnGhost}"
                                                            Click="PreviewScan_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button x:Name="ImportScanButton" Content="Import Now"
                                                            Style="{StaticResource NeuralBtnPrimary}"
                                                            Click="ImportScan_Click" Padding="16,8"
                                                            Margin="0,0,8,0" IsEnabled="False"/>
                                                    <Button Content="Save Patterns" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="SaveScanPatterns_Click" Padding="16,8"/>
                                                </StackPanel>
                                                <TextBlock x:Name="ScanStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>
                                                <ListBox x:Name="ScanResultsList" Height="140"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Brain Export -->
                                        <Border Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Brain export" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap">
                                                        Machine-readable fingerprint of this brain. Claude &amp; external tools
                                                        pull your expertise without understanding BrainX internals.
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-export.json</Run> — full index (schema brain-export/v1)
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-export.md</Run> — human-readable card
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-manifest.json</Run> — tiny fingerprint
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • REST endpoints on server: <Run FontFamily="{StaticResource MonoFont}">/api/brain/export</Run>, <Run FontFamily="{StaticResource MonoFont}">/api/brain/search?q=</Run>, <Run FontFamily="{StaticResource MonoFont}">/api/brain/expertise</Run>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button Content="Export Brain Now" Style="{StaticResource NeuralBtnPrimary}"
                                                            Click="ExportBrain_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Open .obsidianx folder" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="OpenExportFolder_Click" Padding="16,8"/>
                                                </StackPanel>
                                                <TextBlock x:Name="ExportStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Custom Knowledge Categories -->
                                        <Border Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="Custom knowledge categories" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap">
                                                        Teach BrainX new subjects beyond the 25 built-in domains. Matches notes
                                                        by Thai + English keywords; outscoring a built-in wins the node.
                                                    </TextBlock>
                                                </StackPanel>

                                                <ListBox x:Name="CustomCategoryList" Height="140"
                                                         Background="{StaticResource DarkPanelBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Button Content="+ New" Style="{StaticResource NeuralBtnPrimary}"
                                                            Click="NewCategory_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="Edit" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="EditCategory_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="Delete" Style="{StaticResource NeuralBtnGhost}"
                                                            Click="DeleteCategory_Click" Padding="12,6"/>
                                                </StackPanel>

                                                <Border BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                                    <StackPanel x:Name="CategoryEditor" Visibility="Collapsed">
                                                        <TextBlock Text="Display name (e.g. Thai Classical Literature)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryNameBox" Style="{StaticResource NeonTextBox}" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Color (hex, e.g. #FF00F0FF)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryColorBox" Style="{StaticResource NeonTextBox}"
                                                                 Text="#FF00F0FF" FontFamily="{StaticResource MonoFont}" Margin="0,0,0,8"/>

                                                        <TextBlock Text="English keywords (comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryEnBox" Style="{StaticResource NeonTextBox}"
                                                                 AcceptsReturn="True" Height="40" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Thai keywords (comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryThBox" Style="{StaticResource NeonTextBox}"
                                                                 AcceptsReturn="True" Height="40" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Description (optional)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryDescBox" Style="{StaticResource NeonTextBox}"
                                                                 Margin="0,0,0,8"/>

                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Save" Style="{StaticResource NeuralBtnPrimary}"
                                                                    Click="SaveCategory_Click" Padding="16,6" Margin="0,0,8,0"/>
                                                            <Button Content="Cancel" Style="{StaticResource NeuralBtnGhost}"
                                                                    Click="CancelCategoryEdit_Click" Padding="16,6"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock x:Name="CategoryStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Graph Performance -->
                                        <Border Style="{StaticResource NeuralCard}"
                                                Padding="22" Margin="0,0,0,14">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,16">
                                                    <TextBlock Text="3D graph performance" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralText}"/>
                                                    <TextBlock FontSize="12.5" FontWeight="Medium"
                                                               Foreground="{StaticResource NeuralText2}" Margin="0,3,0,0" TextWrapping="Wrap">
                                                        Barnes-Hut octree (O(N log N)) + Fruchterman-Reingold forces with
                                                        per-community gravity. Distant + low-importance nodes are culled.
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Text="Max visible nodes (0 = unlimited)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
