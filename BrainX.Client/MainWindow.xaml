<Window x:Class="BrainX.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:services="clr-namespace:BrainX.Client.Services"
        mc:Ignorable="d"
        Title="BrainX — Neural Knowledge Engine"
        Width="1400" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/Logo.ico"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- WindowStyle=None + AllowsTransparency=True strips native chrome,
         which also kills the invisible resize edges. WindowChrome restores
         them via DWM hit-testing without bringing back the Aero title bar.
         CaptionHeight=0 because we have a custom title bar (line 64+) with
         TitleBar_MouseLeftButtonDown for drag-to-move — letting WindowChrome
         claim the caption would double-handle drag. ResizeBorderThickness=6
         gives 6px grabbable on every edge / corner; the user sees the cursor
         flip to ↔ ↕ ⤡ as expected. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0.2" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="RotateBrain" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BrainRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:30"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource DeepSpaceBrush}"
            BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <!-- Subtle full-window nebula texture — barely visible but adds depth -->
            <Image x:Name="WindowBgTexture" Source="pack://application:,,,/Assets/bk2.png"
                   Stretch="UniformToFill" Opacity="0.09" IsHitTestVisible="False"/>

            <!-- (Static snapshot of Universe removed — user wanted live, not a
                 still image. Universe live = use the Wallpaper button instead,
                 which spawns a real-time WebView2 reparented to WorkerW.) -->
            <!-- Background ambient glow -->
            <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" Opacity="0.03">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource ElectricPurpleColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0.04">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource NeonCyanColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Phase 3 (Universe-as-full-window-bg) reverted: WebView2 is a
                 native HWND that ALWAYS paints over WPF chrome regardless of
                 z-order (Win32 airspace rule). Hosting it at outer level
                 hides sidebar / title bar / status bar → can't navigate or
                 drag. The WebView now lives back inside UniverseView's
                 content cell where it only covers the area where chrome
                 doesn't reach. -->

            <Grid x:Name="RootShellGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TitleBarRow" Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="StatusBarRow" Height="32"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR
                     Phase 1B (partial): swap background to the new neural gradient
                     + add a 1px hairline bottom. Interior controls (hamburger /
                     logo / theme picker / window buttons) keep their cyberpunk
                     skins for now — they'll move to Neural* tokens in a later
                     pass that also restyles the popup and dim sliders.
                     The brand-mark + identity-pill rebuild from the prototype
                     spec is also deferred to that pass. -->
                <Border x:Name="TitleBarBorder" Grid.Row="0"
                        Background="{StaticResource NeuralTitlebarBg}"
                        BorderBrush="{StaticResource NeuralLine}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <!-- Hamburger: collapses the sidebar (SidebarColumn.Width 220 ↔ 0).
                                 Crucial when the sidebar is glass-translucent + sits over Universe —
                                 user may want to hide it entirely. Esc or click again restores. -->
                            <Button x:Name="SidebarToggleBtn" Width="28" Height="28"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Click="SidebarToggle_Click" Margin="0,0,8,0"
                                    ToolTip="Hide / show sidebar menu">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="4" Background="Transparent">
                                            <TextBlock Text="&#x2630;" FontSize="16"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#226CF0FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Title-bar logo — seamless (no frame, no clip) so the glow bleeds into the bg -->
                            <Image Source="pack://application:,,,/Assets/Logo.png"
                                   Width="30" Height="30" Margin="0,0,10,0"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="BrainX" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" — Neural Knowledge Engine" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                       Margin="4,2,0,0"/>
                            <!-- Brain name in parens, populated from code-behind (ex: "(My Brain)") -->
                            <TextBlock x:Name="BrainTitleLabel" Text="" FontSize="11"
                                       Foreground="{StaticResource NeonCyanBrush}"
                                       VerticalAlignment="Center" Margin="8,2,0,0"
                                       FontFamily="{StaticResource MonoFont}"
                                       Cursor="Hand" MouseLeftButtonDown="CopyAddress_Click"
                                       ToolTip="Click to copy brain address"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                            <!-- Theme/palette picker — opens a popup with color swatches + dim sliders.
                                 Tinted with accent + glow so it's easy to spot in the title bar. -->
                            <Button x:Name="ThemeButton" Width="40" Height="28"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="UI theme + background dim"
                                    Click="ThemeButton_Click" Margin="4,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="6,2"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource SurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F3A8;" FontSize="13" Margin="0,0,2,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Theme" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NeonCyanBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=ThemeButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                   HorizontalOffset="-220" VerticalOffset="4">
                                <Border Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="10" MinWidth="280">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                          BlurRadius="22" Opacity="0.55" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="UI COLOR THEME" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Margin="2,0,0,8"/>
                                        <ItemsControl x:Name="ThemeList">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <Border Margin="0,8,0,0" Padding="0,8,0,0"
                                                BorderBrush="{StaticResource SurfaceLightBrush}"
                                                BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <TextBlock Text="BACKGROUND DIM" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Margin="2,0,0,6"/>

                                                <Grid Margin="2,0,2,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Brain graph" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="GraphBgDimSlider"
                                                            Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                                            Value="0.55" ValueChanged="GraphBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="GraphBgDimLabel" Text="55%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>

                                                <Grid Margin="2,0,2,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Dashboard 3D" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="DashBgDimSlider"
                                                            Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                                            Value="0.55" ValueChanged="DashBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="DashBgDimLabel" Text="55%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>

                                                <Grid Margin="2,0,2,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Window texture" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Slider Grid.Column="1" x:Name="WindowBgDimSlider"
                                                            Minimum="0" Maximum="0.5" SmallChange="0.02" LargeChange="0.05"
                                                            Value="0.09" ValueChanged="WindowBgDimSlider_Changed"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" x:Name="WindowBgDimLabel" Text="9%"
                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                               VerticalAlignment="Center" TextAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <Button Content="—" Click="Minimize_Click" Width="36" Height="28"
                                    Style="{StaticResource NavButton}" FontSize="12"/>
                            <Button Content="□" Click="Maximize_Click" Width="36" Height="28"
                                    Style="{StaticResource NavButton}" FontSize="12"/>
                            <Button Content="✕" Click="Close_Click" Width="36" Height="28"
                                    FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="36" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MAIN CONTENT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR (Neural redesign — Phase 1B)
                         Background → NeuralSidebarBg (#14102a → #0e0a22 violet gradient
                         matching the design handoff spec). Right edge → NeuralLine
                         (subtle 8% violet hairline, replaces the loud cyan glow gradient).
                         Width stays at 220 px for now; bumping to 240 per the spec is a
                         later commit alongside the brand-crest + nav-item migration. -->
                    <Border x:Name="SidebarBorder" Grid.Column="0"
                            Background="{StaticResource NeuralSidebarBg}"
                            BorderBrush="{StaticResource NeuralLine}"
                            BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Brain badge — just the logo. Name/address live in the title bar.
                                 Uses a radial opacity mask so the logo's dark edges fade seamlessly
                                 into the sidebar gradient instead of showing a hard square crop. -->
                            <Grid Grid.Row="0" Margin="8,12,8,12" HorizontalAlignment="Center">
                                <Ellipse x:Name="PulseRing" Width="190" Height="190" Opacity="0.35"
                                         StrokeThickness="1.5" Stroke="{StaticResource NeonCyanBrush}"
                                         Effect="{StaticResource LogoGlow}"/>
                                <Image Source="pack://application:,,,/Assets/Logo.png"
                                       Width="180" Height="180" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.OpacityMask>
                                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5"
                                                             RadiusX="0.55" RadiusY="0.55">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#FFFFFFFF" Offset="0.6"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Image.OpacityMask>
                                </Image>
                            </Grid>

                            <!-- Nav -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly">
                                <StackPanel Margin="0,8,0,8">
                                    <!-- ═══════════════════════════════════════════════════════════
                                         SIDEBAR NAV — 5 groups per t2.zip screenshot 01-dashboard.png:
                                         WORKSPACE / VAULT / INTELLIGENCE / NETWORK / SYSTEM.
                                         Nav items not shown in the screenshot (Tokens / Insights /
                                         SSH / Import) keep their x:Name + handlers but are hidden so
                                         existing code-behind references stay intact. NavBrainGraph
                                         (legacy WPF viewport) stays hidden because the sidebar
                                         "Brain Graph" item now routes to Tag=Universe per the
                                         "brain graph = univers" rule.
                                         ═══════════════════════════════════════════════════════════ -->

                                    <!-- ── WORKSPACE ─────────────────────────────────── -->
                                    <TextBlock Text="WORKSPACE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="22,8,0,8" FontWeight="SemiBold" Opacity="0.7"/>
                                    <Button x:Name="NavDashboard" Content="&#x2B21;  Dashboard"
                                            Style="{StaticResource NavButtonActive}" Click="Nav_Click" Tag="Dashboard"/>
                                    <Button x:Name="NavUniverse" Content="&#x25C9;  Brain Graph"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Universe"/>
                                    <Button x:Name="NavGrowth" Content="&#x1F4C8;  Knowledge Growth"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Growth"/>

                                    <!-- ── VAULT ─────────────────────────────────────── -->
                                    <TextBlock Text="VAULT" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="22,16,0,8" FontWeight="SemiBold" Opacity="0.7"/>
                                    <Button x:Name="NavEditor" Content="&#x270F;  Editor"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Editor"/>
                                    <Button x:Name="NavVault" Content="&#x1F4C1;  Vault Explorer"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Vault"/>
                                    <Button x:Name="NavSearch" Content="&#x1F50D;  Search"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Search"/>

                                    <!-- ── INTELLIGENCE ─────────────────────────────── -->
                                    <TextBlock Text="INTELLIGENCE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="22,16,0,8" FontWeight="SemiBold" Opacity="0.7"/>
                                    <Button x:Name="NavClaude" Content="&#x2728;  AI Brain Assistant"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Claude"/>

                                    <!-- ── NETWORK ──────────────────────────────────── -->
                                    <TextBlock Text="NETWORK" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="22,16,0,8" FontWeight="SemiBold" Opacity="0.7"/>
                                    <Button x:Name="NavNetwork" Content="&#x2B22;  Network"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Network"/>
                                    <Button x:Name="NavPeers" Content="&#x1F465;  Peers"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Peers"/>
                                    <Button x:Name="NavSharing" Content="&#x1F504;  Sharing"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Sharing"/>

                                    <!-- ── SYSTEM ───────────────────────────────────── -->
                                    <TextBlock Text="SYSTEM" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="22,16,0,8" FontWeight="SemiBold" Opacity="0.7"/>
                                    <Button x:Name="NavSettings" Content="&#x2699;  Settings"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Settings"/>

                                    <!-- Hidden nav buttons — kept in tree so existing code-behind
                                         references (NavBrainGraph, NavTokens, NavInsights, NavSsh,
                                         NavImport) don't break. Re-show by removing Visibility=Collapsed. -->
                                    <Button x:Name="NavBrainGraph" Content="Brain Graph (legacy)"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="BrainGraph"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="NavTokens" Content="Tokens"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Tokens"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="NavInsights" Content="Insights"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Insights"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="NavSsh" Content="SSH"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Ssh"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="NavImport" Content="Import / Scan"
                                            Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Import"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Mesh online chip (sidebar bottom) per t2.zip screenshot.
                                 Preserves x:Names NetworkDot / NetworkStatusText / PeerCountText so
                                 existing code-behind (RefreshNetworkStats etc) keeps updating them. -->
                            <Border Grid.Row="2" Margin="14,0,14,14" Padding="12,10" CornerRadius="10"
                                    Background="{StaticResource NeuralBgCard}"
                                    BorderBrush="{StaticResource NeuralLine}" BorderThickness="1"
                                    Effect="{StaticResource Shadow1}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" x:Name="NetworkDot" Width="8" Height="8"
                                             Fill="{StaticResource NeuralMint}"
                                             Effect="{StaticResource GlowMint}"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="NetworkStatusText" Text="Mesh online"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeuralText1}"/>
                                        <TextBlock x:Name="PeerCountText" Text="0 peers · :5142"
                                                   FontSize="11" Margin="0,2,0,0"
                                                   Foreground="{StaticResource NeuralText3}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Column="1">
                        <!-- Dashboard — default startup view (the at-a-glance stats
                             overview). Universe view is still available from the sidebar. -->
                        <Grid x:Name="DashboardView" Visibility="Visible">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,32">
                                <StackPanel>
                                    <!-- ═══════════════════════════════════════════════════════════════
                                         VIEW HEADER per t2.zip screenshots/01-dashboard.png:
                                         left = title + subtitle, right = Refresh (ghost) + New note (primary)
                                         ═══════════════════════════════════════════════════════════════ -->
                                    <Grid Margin="0,0,0,22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Dashboard" Style="{StaticResource TypeViewTitle}"/>
                                            <TextBlock Text="Your neural knowledge overview · auto-ingested 4 minutes ago"
                                                       Style="{StaticResource TypeViewSubtitle}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <Button Style="{StaticResource NeuralBtnGhost}"
                                                    Click="ReindexVault_Click" Margin="0,0,10,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x21BB;" FontSize="14" Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource NeuralBtnPrimary}"
                                                    Click="Nav_Click" Tag="Editor">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x002B;" FontSize="14" FontWeight="Bold"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="New note" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ═══════════════════════════════════════════════════════════════
                                         KPI GRID — 4 cards, 16 px gap (Neural redesign Phase 2)
                                         Each card: 18 px padding, NeuralCard surface (shadow-2 + edge-top),
                                         3 px colored thumb on the LEFT EDGE TOP (the prototype's ::before
                                         pseudo, recreated here as an actual <Border> with the accent glow),
                                         uppercase label + 36 px tabular value.
                                         Preserves: x:Name = StatNotes / StatWords / StatLinks / StatCategories
                                         (the Window_Loaded → IndexVault populates these from _graph).
                                         ═══════════════════════════════════════════════════════════════ -->
                                    <Grid Margin="0,0,0,22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- KPI cards per t2.zip screenshot — no left thumb, label TOP,
                                             big white value, trend line at bottom (mint delta + gray label) -->
                                        <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                Padding="22,16,22,18" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="KNOWLEDGE NODES" Style="{StaticResource TypeKpiLabel}"/>
                                                <TextBlock x:Name="StatNotes" Text="0"
                                                           Style="{StaticResource TypeKpiValue}" Margin="0,6,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="+" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralMint}"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="StatNotesDelta" Text="63" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralMint}"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="this week" FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource NeuralCard}"
                                                Padding="22,16,22,18" Margin="4,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="TOTAL WORDS" Style="{StaticResource TypeKpiLabel}"/>
                                                <TextBlock x:Name="StatWords" Text="0"
                                                           Style="{StaticResource TypeKpiValue}" Margin="0,6,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="+" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralMint}"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="StatWordsDelta" Text="41.2K" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource NeuralMint}"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="last 14 days" FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Style="{StaticResource NeuralCard}"
                                                Padding="22,16,22,18" Margin="4,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="CONNECTIONS" Style="{StaticResource TypeKpiLabel}"/>
                                                <TextBlock x:Name="StatLinks" Text="0"
                                                           Style="{StaticResource TypeKpiValue}" Margin="0,6,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="StatLinksTrend"
                                                               Text="20 wiki · 2,704 auto-detected" FontSize="12"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="3" Style="{StaticResource NeuralCard}"
                                                Padding="22,16,22,18" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="EXPERTISE AREAS" Style="{StaticResource TypeKpiLabel}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,8" VerticalAlignment="Bottom">
                                                    <TextBlock x:Name="StatCategories" Text="0"
                                                               Style="{StaticResource TypeKpiValue}"/>
                                                    <TextBlock Text=" /24" FontSize="20" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeuralText3}"
                                                               VerticalAlignment="Bottom" Margin="6,0,0,5"/>
                                                </StackPanel>
                                                <TextBlock x:Name="StatCategoriesTrend"
                                                           Text="4 above 80% mastery" FontSize="12"
                                                           Foreground="{StaticResource NeuralText3}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- ═══════════════════════════════════════════════════════════════
                                         DASH-GRID — 2 columns (1.6fr Neural Map · 1fr Activity + Recent).
                                         Mirrors the prototype's DashboardView main grid exactly
                                         (design_handoff_brainx_redesign/design/views-a.jsx::DashboardView).
                                         The Map Border in Column 0 wraps the existing 3D viewport, 2D
                                         renderer, Expertise overlay, and NodeInfoPanel UNCHANGED — their
                                         renderers are tied to FullGraph / DashGraph2D / EditDashNode
                                         handlers in code-behind, so touching them risks the Universe
                                         pulse + click-to-edit flow. Column 1 is brand-new from the
                                         prototype: Activity Feed (kind-badge rows) + Recently Edited
                                         (real vault data). See MainWindow.Dashboard.cs for the data
                                         populate.
                                         ═══════════════════════════════════════════════════════════════ -->
                                    <Grid Margin="0,0,0,20" MinHeight="520">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.6*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource NeuralCard}"
                                                Margin="0,0,8,0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="NEURAL KNOWLEDGE MAP"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" x:Name="DashHintText"
                                                           Text="Drag = rotate · Wheel = zoom · Click = info · Right-click = kick"
                                                           FontSize="11" FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource NeuralText3}" Opacity="0.7"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <!-- 3D / 2D segmented toggle per screenshot — 3D active = violet -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button x:Name="DashView3DBtn" Content="3D"
                                                            Style="{StaticResource NeonButton}"
                                                            Padding="10,3" FontSize="10"
                                                            Tag="3D" Click="DashViewMode_Click"/>
                                                    <Button x:Name="DashView2DBtn" Content="2D"
                                                            Style="{StaticResource NeonButtonFilled}"
                                                            Padding="10,3" FontSize="10" Margin="4,0,0,0"
                                                            Tag="2D" Click="DashViewMode_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Map area: viewport + transparent glass overlay sit in same Grid cell.
                                                 Mouse wheel only zooms when cursor is over the viewport background;
                                                 the overlay's ScrollViewer captures wheel for its own scroll. -->
                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                <Border x:Name="DashView3DBorder" CornerRadius="8" ClipToBounds="True"
                                                        Visibility="Collapsed"
                                                        MouseLeftButtonDown="Viewport_MouseDown"
                                                        MouseLeftButtonUp="Viewport_MouseUp"
                                                        MouseMove="Viewport_MouseMove"
                                                        MouseWheel="Viewport_MouseWheel"
                                                        MouseRightButtonDown="Viewport_RightClick">
                                                    <Border.Background>
                                                        <ImageBrush x:Name="DashBgBrush"
                                                                    ImageSource="pack://application:,,,/Assets/bk1.png"
                                                                    Stretch="UniformToFill" Opacity="0.55"/>
                                                    </Border.Background>
                                                    <Viewport3D x:Name="BrainViewport" ClipToBounds="True"
                                                                IsHitTestVisible="False">
                                                        <Viewport3D.Camera>
                                                            <PerspectiveCamera x:Name="DashCam" Position="0,2,10"
                                                                               LookDirection="0,-0.2,-1"
                                                                               UpDirection="0,1,0" FieldOfView="45"/>
                                                        </Viewport3D.Camera>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <AmbientLight Color="#333355"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <DirectionalLight x:Name="DashKeyLight" Color="#00F0FF" Direction="-1,-1,-1"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D>
                                                            <ModelVisual3D.Content>
                                                                <DirectionalLight x:Name="DashFillLight" Color="#8B5CF6" Direction="1,0.5,-0.5"/>
                                                            </ModelVisual3D.Content>
                                                        </ModelVisual3D>
                                                        <ModelVisual3D x:Name="BrainModel"/>
                                                    </Viewport3D>
                                                </Border>

                                                <!-- 2D primary view — WriteableBitmap renderer, default.
                                                     Interaction restored per t2.zip screenshot which shows the
                                                     full controls hint ("Drag = rotate · Wheel = zoom · Click =
                                                     info · Right-click = kick") + 3D/2D toggle visible. -->
                                                <Border x:Name="DashView2DBorder" CornerRadius="8" ClipToBounds="True"
                                                        MouseLeftButtonDown="Dash2D_MouseDown"
                                                        MouseLeftButtonUp="Dash2D_MouseUp"
                                                        MouseMove="Dash2D_MouseMove"
                                                        MouseWheel="Dash2D_MouseWheel"
                                                        MouseRightButtonDown="Dash2D_RightClick">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="pack://application:,,,/Assets/bk1.png"
                                                                    Stretch="UniformToFill" Opacity="0.35"/>
                                                    </Border.Background>
                                                    <services:Graph2DRenderer x:Name="DashGraph2D"/>
                                                </Border>

                                                <!-- Glassmorphism Expertise overlay: top-right of map, scrollable.
                                                     Faux-glass = translucent gradient + subtle white border + drop
                                                     shadow. WPF has no native backdrop blur, but the bk1 nebula
                                                     visible through the alpha sells the effect. -->
                                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="0,16,16,16" Width="320" MaxHeight="460"
                                                        CornerRadius="14" Padding="0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Offset="0" Color="#55101820"/>
                                                            <GradientStop Offset="1" Color="#33060A10"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                            <GradientStop Offset="1" Color="#11FFFFFF"/>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                                          Color="#000000" Opacity="0.45"/>
                                                    </Border.Effect>
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  Padding="16" CanContentScroll="False"
                                                                  PanningMode="VerticalOnly">
                                                        <StackPanel>
                                                            <TextBlock Text="EXPERTISE PROFILE" FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Margin="0,0,0,12"/>
                                                            <StackPanel x:Name="ExpertisePanel"/>
                                                            <Border Margin="0,16,0,0" Padding="10" CornerRadius="8"
                                                                    Background="#33000000">
                                                                <StackPanel>
                                                                    <TextBlock Text="BRAIN ADDRESS" FontSize="9"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Margin="0,0,0,4"/>
                                                                    <TextBlock x:Name="FullAddressText" Text="0xBRAIN-..."
                                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                                               Foreground="{StaticResource NeonCyanBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="VAULT PATH" FontSize="9"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Margin="0,8,0,4"/>
                                                                    <TextBlock x:Name="VaultPathText" Text="..."
                                                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>

                                                <!-- Node Info Panel (shows on click) -->
                                                <!-- Auto-hides after 15s idle · Close with × · Edit & save inline -->
                                                <Border x:Name="NodeInfoPanel" Grid.Row="2" Visibility="Collapsed"
                                                        Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                                        Padding="14,10" Margin="0,8,0,0" MaxHeight="260"
                                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                                        MouseEnter="NodeInfoPanel_MouseEnter"
                                                        MouseLeave="NodeInfoPanel_MouseLeave">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse x:Name="NodeInfoDot" Width="10" Height="10"
                                                                     Fill="{StaticResource NeonCyanBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock x:Name="NodeInfoTitle" Text="" FontSize="13"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                <TextBlock x:Name="NodeInfoDetail" Text="" FontSize="10"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Button Content="&#x26A1; Kick" Style="{StaticResource NeonButton}"
                                                                        Padding="10,4" FontSize="11" Click="KickNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeEditBtn" Content="&#x270E; Edit"
                                                                        Style="{StaticResource NeonButton}"
                                                                        Padding="10,4" FontSize="11" Click="EditDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeSaveBtn" Content="&#x1F4BE; Save"
                                                                        Style="{StaticResource NeonButtonFilled}"
                                                                        Visibility="Collapsed"
                                                                        Padding="10,4" FontSize="11" Click="SaveDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button x:Name="DashNodeCancelBtn" Content="Cancel"
                                                                        Style="{StaticResource NeonButton}"
                                                                        Visibility="Collapsed"
                                                                        Padding="10,4" FontSize="11" Click="CancelDashNode_Click" Margin="0,0,4,0"/>
                                                                <Button Content="&#x1F4D6; Open" Style="{StaticResource NeonButtonFilled}"
                                                                        Padding="10,4" FontSize="11" Click="OpenDashNodeFile_Click" Margin="0,0,4,0"/>
                                                                <Button Content="&#x2715;" Style="{StaticResource NeonButton}"
                                                                        Padding="8,4" FontSize="11" ToolTip="Close"
                                                                        Click="CloseDashNode_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- Content Preview / Editor -->
                                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                                            <ScrollViewer x:Name="NodeInfoContentScroll" MaxHeight="160"
                                                                          VerticalScrollBarVisibility="Auto">
                                                                <TextBlock x:Name="NodeInfoContent" Text="" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                            </ScrollViewer>
                                                            <TextBox x:Name="NodeInfoEditor" Visibility="Collapsed"
                                                                     MinHeight="160" MaxHeight="220"
                                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     FontFamily="{StaticResource MonoFont}"
                                                                     Style="{StaticResource NeonTextBox}"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- end Map Border (Grid.Column=0). Right column below. -->

                                        <!-- ═══════════════════════════════════════════════════════════
                                             RIGHT COLUMN (Grid.Column=1)
                                             Activity Feed (top) + Recently Edited (bottom). New from the
                                             prototype right-rail; bound via DashActivityList +
                                             DashRecentNotesList in MainWindow.Dashboard.cs.
                                             ═══════════════════════════════════════════════════════════ -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <!-- ── Activity Feed card ─────────────────────────────────── -->
                                            <Border Style="{StaticResource NeuralCard}" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- card-head -->
                                                    <Grid Grid.Row="0" Margin="18,14,18,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="ACTIVITY FEED"
                                                                   Style="{StaticResource TypeCardTitle}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text=" · live"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Border Grid.Column="3" Style="{StaticResource NeuralTagAccent}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="6" Height="6" CornerRadius="3"
                                                                        Background="{StaticResource NeuralMint}"
                                                                        Effect="{StaticResource GlowMint}"
                                                                        VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <TextBlock Text="Mesh online" FontSize="11.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource NeuralViolet2}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                    <!-- divider -->
                                                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                                            Background="{StaticResource NeuralLine}"/>
                                                    <!-- activity-list (bound to DashActivityList) -->
                                                    <ScrollViewer Grid.Row="1" MaxHeight="320"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  Padding="0,4">
                                                        <ItemsControl x:Name="DashActivityList">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="64"/>
                                                                            <ColumnDefinition Width="42"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding Time}"
                                                                                   Style="{StaticResource TypeMonoSmall}"
                                                                                   Margin="18,12,0,12"
                                                                                   VerticalAlignment="Top"/>
                                                                        <Border Grid.Column="1"
                                                                                Background="{Binding KindBrush}"
                                                                                CornerRadius="4"
                                                                                Width="32" Height="16"
                                                                                Margin="0,14,0,0"
                                                                                VerticalAlignment="Top"
                                                                                HorizontalAlignment="Left">
                                                                            <TextBlock Text="{Binding KindLabel}"
                                                                                       FontSize="9"
                                                                                       FontWeight="ExtraBold"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontFamily="{StaticResource FontMono}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Message}"
                                                                                   FontSize="13"
                                                                                   Foreground="{StaticResource NeuralText1}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="10,12,18,12"
                                                                                   LineHeight="18"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>

                                            <!-- ── Recently Edited card ───────────────────────────────── -->
                                            <Border Style="{StaticResource NeuralCard}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="18,14,18,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="RECENTLY EDITED"
                                                                   Style="{StaticResource TypeCardTitle}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" x:Name="DashRecentCountText"
                                                                   Text=" · 0 notes"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource NeuralText3}"/>
                                                        <Button Grid.Column="3" Content="See all"
                                                                Style="{StaticResource NeuralBtnGhost}"
                                                                Height="26" Padding="10,0" FontSize="12"
                                                                Tag="Vault" Click="Nav_Click"/>
                                                    </Grid>
                                                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                                            Background="{StaticResource NeuralLine}"/>
                                                    <ItemsControl Grid.Row="1" x:Name="DashRecentNotesList"
                                                                  Margin="6,4,6,10">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="8" Padding="10,9" Margin="0,1"
                                                                        Background="Transparent">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="14"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Width="10" Height="10"
                                                                                CornerRadius="5"
                                                                                Background="{Binding CategoryBrush}"
                                                                                VerticalAlignment="Top"
                                                                                Margin="0,5,0,0"/>
                                                                        <StackPanel Grid.Column="1" Margin="10,0,8,0">
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontSize="13.5"
                                                                                       FontWeight="Medium"
                                                                                       Foreground="{StaticResource NeuralText}"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding Meta}"
                                                                                       FontSize="11.5"
                                                                                       Foreground="{StaticResource NeuralText3}"
                                                                                       Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding WordsLabel}"
                                                                                   FontFamily="{StaticResource FontMono}"
                                                                                   FontSize="11.5"
                                                                                   Foreground="{StaticResource NeuralText2}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <!-- end DASH-GRID 2-col -->

                                    <!-- Quick Actions (Neural redesign — Phase 2)
                                         NeuralCard wrapper + TypeCardTitle label + NeuralBtn / NeuralBtnPrimary
                                         buttons. Re-index Vault is the only action with a side effect on the
                                         entire knowledge graph, so it gets the primary violet treatment; the
                                         other three are secondary (ghost = no decoration, default = card-tinted). -->
                                    <Border Style="{StaticResource NeuralCard}" Padding="22,18">
                                        <StackPanel>
                                            <TextBlock Text="QUICK ACTIONS"
                                                       Style="{StaticResource TypeCardTitle}"
                                                       Margin="0,0,0,14"/>
                                            <WrapPanel>
                                                <Button Content="&#x1F504;  Re-index Vault"
                                                        Style="{StaticResource NeuralBtnPrimary}"
                                                        Click="ReindexVault_Click" Margin="0,0,10,10"/>
                                                <Button Content="&#x1F4D6;  Open in Obsidian"
                                                        Style="{StaticResource NeuralBtn}"
                                                        Click="OpenObsidian_Click" Margin="0,0,10,10"/>
                                                <Button Content="&#x1F310;  Join Network"
                                                        Style="{StaticResource NeuralBtn}"
                                                        Click="JoinNetwork_Click" Margin="0,0,10,10"/>
                                                <Button Content="&#x1F4CA;  Export Stats"
                                                        Style="{StaticResource NeuralBtnGhost}"
                                                        Click="ExportStats_Click" Margin="0,0,10,10"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Brain Graph View -->
                        <Grid x:Name="BrainGraphView" Visibility="Collapsed">
                            <Border Style="{StaticResource CardPanel}" Margin="24,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="BRAIN GRAPH" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="GraphFPS" Text="" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox x:Name="GraphSearchBox" Width="260" Margin="20,0,0,0"
                                                     Background="{StaticResource DarkPanelBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource NeonCyanBrush}"
                                                     BorderThickness="1" FontSize="11" Padding="8,3"
                                                     CaretBrush="{StaticResource NeonCyanBrush}"
                                                     VerticalAlignment="Center"
                                                     ToolTip="Ctrl+F to focus · Enter to fly to top hit · Esc to close"
                                                     TextChanged="GraphSearch_TextChanged"
                                                     KeyDown="GraphSearch_KeyDown"
                                                     GotFocus="GraphSearch_GotFocus"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="Camera" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CameraModeCombo" Width="140" FontSize="10"
                                                      Background="{StaticResource DarkPanelBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      BorderBrush="{StaticResource NeonCyanBrush}"
                                                      SelectionChanged="CameraMode_Changed" Margin="0,0,10,0">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Background" Value="#0f1420"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Padding" Value="8,4"/>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBoxItem Content="Free (drag)"/>
                                                <ComboBoxItem Content="Follow Pulse"/>
                                                <ComboBoxItem Content="Orbit"/>
                                                <ComboBoxItem Content="Overview"/>
                                                <ComboBoxItem Content="Random Walk"/>
                                                <!-- Default mode: camera follows MCP/edit activity so the
                                                     user sees the AI's attention in real time. Matches
                                                     _cameraMode = CameraMode.RealBrain in MainWindow.xaml.cs. -->
                                                <ComboBoxItem Content="Real Brain (5s dwell)" IsSelected="True"/>
                                            </ComboBox>
                                            <Button Content="&#x2B06; Up" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="ZoomOutLevel_Click" Margin="0,0,6,0"
                                                    ToolTip="Zoom back to parent cluster"/>
                                            <Button Content="&#x1F3AF; Fit" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="FitOverview_Click" Margin="0,0,6,0"
                                                    ToolTip="Frame the whole graph"/>
                                            <Button Content="&#x1F4A5; Shake" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="ShakeGraph_Click" Margin="0,0,6,0"/>
                                            <Button Content="&#x1F504; Reset" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="ResetCamera_Click" Margin="0,0,6,0"/>
                                            <!-- Toggle the expertise overlay panel inside the brain graph
                                                 view. Same data as the Dashboard's right-rail panel; hidden
                                                 by default so the graph has full width when not needed. -->
                                            <Button x:Name="GraphExpertiseToggleBtn"
                                                    Content="&#x1F4CA; Expertise"
                                                    Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="GraphExpertiseToggle_Click" Margin="0,0,6,0"
                                                    ToolTip="Toggle the expertise profile overlay"/>
                                            <!-- Live brain-activity overlay. Tails ~/.claude/tool-log.ndjson
                                                 and shows what the brain is reading / writing right now,
                                                 colour-coded by op kind. Mirrors the expertise overlay's
                                                 glassmorphism style but pinned to the LEFT of the graph. -->
                                            <Button x:Name="GraphActivityToggleBtn"
                                                    Content="&#x1F4E1; Activity"
                                                    Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="GraphActivityToggle_Click" Margin="0,0,6,0"
                                                    ToolTip="Toggle the live brain-activity overlay (reads/writes/tool calls)"/>
                                            <!-- Token savings gauge — hover for breakdown by op.
                                                 Runs Compute() on the access-log every ~5s and shows
                                                 net saved tokens. Click to toggle bypass (pauses the
                                                 brain-first hooks so trivial conversations don't
                                                 waste 160 tok/turn on reminders). -->
                                            <Border x:Name="TokenSavingsChip" Padding="8,3"
                                                    Margin="0,0,6,0" CornerRadius="3"
                                                    Background="#1A00FF88"
                                                    BorderBrush="#5500FF88" BorderThickness="1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="TokenSavingsChip_Click">
                                                <TextBlock x:Name="TokenSavingsText"
                                                           Text="&#x1F4B0; +0 tok"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="#5DFF9D"/>
                                            </Border>
                                            <Button x:Name="BrainBypassBtn"
                                                    Content="&#x1F9E0; Always"
                                                    Style="{StaticResource NeonButtonFilled}"
                                                    Padding="10,3" FontSize="10"
                                                    Click="BrainBypass_Click" Margin="0,0,12,0"
                                                    ToolTip="Cycle brain-mode: Always → Auto → Off → Always.&#x0a;Always = inject reminder every turn (best for long sessions, deep debug)&#x0a;Auto = skip reminder when prompt &lt; 60 chars (best general use)&#x0a;Off = no reminders (best for trivial chat / greenfield)"/>
                                            <!-- 3D toggle hidden (legacy Viewport3D path soft-disabled).
                                                 Universe view replaces 3D BrainGraph; 2D path stays as the
                                                 primary Graph view with MCP pulse + flash overlay. -->
                                            <Button x:Name="GraphView3DBtn" Content="3D"
                                                    Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10"
                                                    Tag="3D" Click="GraphViewMode_Click" Margin="0,0,4,0"
                                                    Visibility="Collapsed"/>
                                            <Button x:Name="GraphView2DBtn" Content="2D"
                                                    Style="{StaticResource NeonButtonFilled}"
                                                    Padding="10,3" FontSize="10"
                                                    Tag="2D" Click="GraphViewMode_Click"
                                                    Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Transparent border catches mouse on empty space.
                                         bk2 nebula paints the skybox behind the graph viewport. -->
                                    <Border x:Name="GraphView3DBorder" Grid.Row="1" CornerRadius="6" ClipToBounds="True"
                                            Visibility="Collapsed"
                                            MouseLeftButtonDown="FullGraph_MouseDown"
                                            MouseLeftButtonUp="FullGraph_MouseUp"
                                            MouseMove="FullGraph_MouseMove"
                                            MouseWheel="FullGraph_MouseWheel"
                                            MouseRightButtonDown="FullGraph_RightClick">
                                        <Border.Background>
                                            <ImageBrush x:Name="GraphBgBrush"
                                                        ImageSource="pack://application:,,,/Assets/bk2.png"
                                                        Stretch="UniformToFill" Opacity="0.55"/>
                                        </Border.Background>
                                    <Grid>
                                    <Viewport3D x:Name="FullGraphViewport" ClipToBounds="True"
                                                IsHitTestVisible="False">
                                        <Viewport3D.Camera>
                                            <PerspectiveCamera x:Name="GraphCam" Position="0,3,14"
                                                               LookDirection="0,-0.2,-1"
                                                               UpDirection="0,1,0" FieldOfView="50"/>
                                        </Viewport3D.Camera>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><AmbientLight Color="#444466"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight x:Name="GraphKeyLight" Color="#00F0FF" Direction="-1,-1,-1"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight x:Name="GraphFillLight" Color="#FF006E" Direction="1,1,-0.5"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D x:Name="FullGraphModel"/>
                                    </Viewport3D>

                                    <!-- Activity labels — HUD tags that float next to nodes being read/written -->
                                    <Canvas x:Name="ActivityLabels" IsHitTestVisible="False" Panel.ZIndex="8"/>

                                    <!-- Hover tooltip — floats next to the bubble/node under the mouse -->
                                    <Border x:Name="HoverLabel" Visibility="Collapsed"
                                            IsHitTestVisible="False" Panel.ZIndex="11"
                                            Background="#E60B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,5"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                              BlurRadius="12" Opacity="0.4" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="HoverTitle" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock x:Name="HoverSubtitle" FontSize="10" Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- HUD CORNER BRACKETS (sci-fi frame) -->
                                    <Canvas IsHitTestVisible="False" Panel.ZIndex="9">
                                        <!-- Top-left bracket -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M 8,30 L 8,8 L 30,8"
                                              Canvas.Left="0" Canvas.Top="0"/>
                                        <!-- Top-right bracket -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M -30,8 L -8,8 L -8,30"
                                              Canvas.Right="0" Canvas.Top="0"/>
                                        <!-- Bottom-left -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M 8,-30 L 8,-8 L 30,-8"
                                              Canvas.Left="0" Canvas.Bottom="0"/>
                                        <!-- Bottom-right -->
                                        <Path Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1.5"
                                              Opacity="0.8"
                                              Data="M -30,-8 L -8,-8 L -8,-30"
                                              Canvas.Right="0" Canvas.Bottom="0"/>
                                    </Canvas>

                                    <!-- Center reticle (holographic crosshair) -->
                                    <Grid IsHitTestVisible="False" Panel.ZIndex="9"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="40" Height="40"
                                                 Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                                 Opacity="0.25" StrokeDashArray="2 4"/>
                                        <Ellipse Width="80" Height="80"
                                                 Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                                 Opacity="0.12" StrokeDashArray="1 6"/>
                                        <Line X1="-8" Y1="0" X2="8" Y2="0"
                                              Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                              Opacity="0.4" VerticalAlignment="Center"/>
                                        <Line X1="0" Y1="-8" X2="0" Y2="8"
                                              Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="1"
                                              Opacity="0.4" HorizontalAlignment="Center"/>
                                    </Grid>

                                    <!-- Horizontal scanline (animated via code-behind) -->
                                    <Rectangle x:Name="Scanline" Height="1"
                                               VerticalAlignment="Top" Opacity="0.5"
                                               IsHitTestVisible="False" Panel.ZIndex="9">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush x:Name="ScanlineBrush" StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="{DynamicResource NeonCyanColor}" Offset="0.5"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Search results dropdown -->
                                    <Border x:Name="GraphSearchResults" Visibility="Collapsed"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,48,12,0" Panel.ZIndex="20"
                                            Background="#F00B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="6" MaxWidth="420">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource NeonCyanColor}"
                                                              BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="GraphSearchSummary" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Padding="10,6,10,4"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <ListBox x:Name="GraphSearchList" MaxHeight="320"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     MouseDoubleClick="GraphSearchList_DoubleClick"
                                                     KeyDown="GraphSearchList_KeyDown"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Depth indicator + breadcrumb overlay -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                            Background="#B30B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,6"
                                            Margin="12" Panel.ZIndex="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="DepthIndicator" Text="Depth 0 / 5"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="·" Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="BreadcrumbText" Text="Brain"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                                        </StackPanel>
                                    </Border>
                                    </Grid>
                                    </Border>

                                    <!-- 2D primary for the full brain graph. WriteableBitmap renderer, default. -->
                                    <Border x:Name="GraphView2DBorder" Grid.Row="1" CornerRadius="6" ClipToBounds="True"
                                            MouseLeftButtonDown="Graph2D_MouseDown"
                                            MouseLeftButtonUp="Graph2D_MouseUp"
                                            MouseMove="Graph2D_MouseMove"
                                            MouseWheel="Graph2D_MouseWheel"
                                            MouseRightButtonDown="Graph2D_RightClick">
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Assets/bk2.png"
                                                        Stretch="UniformToFill" Opacity="0.35"/>
                                        </Border.Background>
                                        <services:Graph2DRenderer x:Name="FullGraph2D"/>
                                    </Border>

                                    <!-- Glassmorphism Activity overlay for Brain Graph view.
                                         Tails the tool-log NDJSON + indexer events; shows the
                                         brain's live read/write/tool ops, colour-coded. Pinned
                                         LEFT (mirror of the Expertise overlay on the right).
                                         Toggled by the "📡 Activity" toolbar button. -->
                                    <Border x:Name="GraphActivityHost" Grid.Row="1"
                                            HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                            Margin="16,16,0,16" Width="380" MaxHeight="760"
                                            CornerRadius="14" Padding="0"
                                            Visibility="Collapsed" IsHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#55101820"/>
                                                <GradientStop Offset="1" Color="#33060A10"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                <GradientStop Offset="1" Color="#11FFFFFF"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                              Color="#000000" Opacity="0.45"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>      <!-- 0: title -->
                                                <RowDefinition Height="Auto"/>      <!-- 1: filter bar -->
                                                <RowDefinition Height="Auto"/>      <!-- 2: compact summary (capped) -->
                                                <RowDefinition Height="Auto"/>      <!-- 3: console section header -->
                                                <RowDefinition Height="*"/>         <!-- 4: console feed (scroll) -->
                                                <RowDefinition Height="Auto"/>      <!-- 5: footer -->
                                            </Grid.RowDefinitions>
                                            <!-- Header row: title + close button -->
                                            <Grid Grid.Row="0" Margin="16,14,16,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse x:Name="ActivityPulse" Width="8" Height="8"
                                                             Fill="#5DFF9D" Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                                              Color="#5DFF9D" Opacity="0.9"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <TextBlock Text="BRAIN ACTIVITY" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;"
                                                        FontSize="11" Padding="6,2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Click="GraphActivityToggle_Click"
                                                        ToolTip="Hide activity overlay"/>
                                            </Grid>
                                            <!-- Filter bar: read | write | other  +  per-second rate -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                        Margin="16,0,16,8">
                                                <CheckBox x:Name="ActivityFilterRead" Content="📖 read"
                                                          IsChecked="True" FontSize="10"
                                                          Foreground="#5DFF9D" Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <CheckBox x:Name="ActivityFilterWrite" Content="✏ write"
                                                          IsChecked="True" FontSize="10"
                                                          Foreground="#FFB347" Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <CheckBox x:Name="ActivityFilterOther" Content="🔧 other"
                                                          IsChecked="False" FontSize="10"
                                                          Foreground="{StaticResource TextMutedBrush}"
                                                          Margin="0,0,8,0"
                                                          Click="GraphActivityFilterChanged"/>
                                                <TextBlock x:Name="ActivityRateText"
                                                           Text="0/min"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                            <!-- Compact summary (capped to ~30 most recent, newest on top).
                                                 Good for at-a-glance "what's the brain busy with right now?" -->
                                            <ScrollViewer Grid.Row="2"
                                                          MaxHeight="180"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Padding="8,0,8,4" CanContentScroll="False"
                                                          PanningMode="VerticalOnly">
                                                <StackPanel x:Name="GraphActivityPanel"/>
                                            </ScrollViewer>

                                            <!-- Section divider + collapse toggle for the detailed console.
                                                 The console is the "live tail" — chronological, monospace,
                                                 sticky-bottom auto-scroll. Cap at 300 lines for perf. -->
                                            <Grid Grid.Row="3" Margin="16,8,16,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="📜 DETAILED CONSOLE" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ActivityConsoleCount"
                                                               Text="0 lines"
                                                               FontSize="9"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                               Opacity="0.7"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <CheckBox x:Name="ActivityConsoleStickyBottom"
                                                              Content="📌 stick to bottom"
                                                              IsChecked="True" FontSize="9"
                                                              Foreground="{StaticResource TextMutedBrush}"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                                              ToolTip="When checked, new lines auto-scroll into view. Uncheck to read history without being yanked back."/>
                                                    <Button x:Name="ActivityConsolePauseBtn"
                                                            Content="⏸ Pause"
                                                            FontSize="9" Padding="6,2"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            Click="GraphActivityConsolePause_Click"
                                                            ToolTip="Pause the live tail (file polling stops; resume to catch up)"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- The console itself. ScrollViewer wraps a StackPanel that we
                                                 APPEND to (no full rebuild per tick, no virtualization
                                                 needed for 300 cap). ScrollChanged tracks whether the user
                                                 has detached from the bottom so we don't yank them back. -->
                                            <Border Grid.Row="4" Margin="14,0,14,4" CornerRadius="6"
                                                    Background="#0D000208" BorderThickness="1"
                                                    BorderBrush="#22FFFFFF">
                                                <ScrollViewer x:Name="GraphActivityConsoleScroll"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Padding="6,4,6,4"
                                                              CanContentScroll="False"
                                                              PanningMode="VerticalOnly"
                                                              ScrollChanged="GraphActivityConsoleScroll_Changed">
                                                    <StackPanel x:Name="GraphActivityConsolePanel"/>
                                                </ScrollViewer>
                                            </Border>
                                            <!-- Footer: clear + path tooltip -->
                                            <Grid Grid.Row="5" Margin="14,4,14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Clear" FontSize="9" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Click="GraphActivityClear_Click"
                                                        ToolTip="Clear the displayed log (does not touch the file)"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="~/.claude/tool-log.ndjson"
                                                           FontSize="9"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Source of brain tool-call activity"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Glassmorphism Expertise overlay for Brain Graph view.
                                         Same data as Dashboard's panel, populated by
                                         BuildExpertiseBars() into GraphExpertisePanel. Toggled
                                         off by default; the toolbar button "📊 Expertise"
                                         flips Visibility. Sits in Grid.Row="1" alongside the
                                         2D/3D borders so it floats over the graph viewport. -->
                                    <Border x:Name="GraphExpertiseHost" Grid.Row="1"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,16,16,16" Width="320" MaxHeight="460"
                                            CornerRadius="14" Padding="0"
                                            Visibility="Collapsed" IsHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#55101820"/>
                                                <GradientStop Offset="1" Color="#33060A10"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#55FFFFFF"/>
                                                <GradientStop Offset="1" Color="#11FFFFFF"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                              Color="#000000" Opacity="0.45"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="16" CanContentScroll="False"
                                                      PanningMode="VerticalOnly">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="EXPERTISE PROFILE" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="&#x2715;"
                                                            FontSize="11" Padding="6,2"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            Click="GraphExpertiseToggle_Click"
                                                            ToolTip="Hide expertise overlay"/>
                                                </Grid>
                                                <StackPanel x:Name="GraphExpertisePanel"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Selected Node Info — auto-hides after 15s idle, × closes, edit+save inline -->
                                    <Border x:Name="GraphNodeInfo" Grid.Row="2" Visibility="Collapsed"
                                            Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                            Padding="14,10" Margin="0,8,0,0" MaxHeight="300"
                                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                            MouseEnter="GraphNodeInfo_MouseEnter"
                                            MouseLeave="GraphNodeInfo_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse x:Name="GraphNodeDot" Width="12" Height="12"
                                                         Fill="{StaticResource NeonCyanBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock x:Name="GraphNodeTitle" Text="" FontSize="14"
                                                               FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock x:Name="GraphNodeMeta" Text="" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="&#x26A1; Kick" Style="{StaticResource NeonButton}"
                                                            Padding="10,4" FontSize="11" Click="KickGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeEditBtn" Content="&#x270E; Edit"
                                                            Style="{StaticResource NeonButton}"
                                                            Padding="10,4" FontSize="11" Click="EditGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeSaveBtn" Content="&#x1F4BE; Save"
                                                            Style="{StaticResource NeonButtonFilled}"
                                                            Visibility="Collapsed"
                                                            Padding="10,4" FontSize="11" Click="SaveGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button x:Name="GraphNodeCancelBtn" Content="Cancel"
                                                            Style="{StaticResource NeonButton}"
                                                            Visibility="Collapsed"
                                                            Padding="10,4" FontSize="11" Click="CancelGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button Content="&#x1F4D6; Open" Style="{StaticResource NeonButtonFilled}"
                                                            Padding="10,4" FontSize="11" Click="OpenNodeFile_Click" Margin="0,0,6,0"/>
                                                    <Button Content="&#x2715;" Style="{StaticResource NeonButton}"
                                                            Padding="8,4" FontSize="11" ToolTip="Close"
                                                            Click="CloseGraphNode_Click"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                <ScrollViewer x:Name="GraphNodeContentScroll" MaxHeight="180"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <TextBlock x:Name="GraphNodeContent" Text="" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                </ScrollViewer>
                                                <TextBox x:Name="GraphNodeEditor" Visibility="Collapsed"
                                                         MinHeight="180" MaxHeight="240"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         FontFamily="{StaticResource MonoFont}"
                                                         Style="{StaticResource NeonTextBox}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Network View -->
                        <Grid x:Name="NetworkView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Network — BrainX Brain Mesh" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Connect your brain to the collective knowledge network"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="NETWORK STATUS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20"/>
                                            <Border HorizontalAlignment="Center" Width="200" Height="200" CornerRadius="100"
                                                    Margin="0,20" BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="2">
                                                <Grid>
                                                    <Ellipse Width="160" Height="160" Opacity="0.1">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="{DynamicResource ElectricPurpleColor}" Offset="0"/>
                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="NetworkPeerCount" Text="0" FontSize="42"
                                                                   FontWeight="Bold" Foreground="{StaticResource ElectricPurpleBrush}"
                                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"/>
                                                        <TextBlock Text="ACTIVE PEERS" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <!-- Network Stats -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetStatNodes" Text="0" FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource NeonCyanBrush}" HorizontalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                    <TextBlock Text="Nodes" FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetStatWords" Text="0" FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource NeonGreenBrush}" HorizontalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                    <TextBlock Text="Words" FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="NetStatShares" Text="0" FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource NeonPinkBrush}" HorizontalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"/>
                                                    <TextBlock Text="Shares" FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <Button x:Name="JoinNetworkBtn" Content="&#x1F310; Join BrainX Network"
                                                    Click="JoinNetwork_Click"
                                                    Style="{StaticResource NeonButtonFilled}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                            <Button x:Name="LeaveNetworkBtn" Content="Disconnect"
                                                    Click="LeaveNetwork_Click" Visibility="Collapsed"
                                                    Style="{StaticResource NeonButton}" HorizontalAlignment="Center" Margin="0,8,0,0"
                                                    Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                        <StackPanel>
                                            <TextBlock Text="FIND EXPERT BRAINS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Search Category" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="MatchCategoryCombo" Margin="0,0,0,12"
                                                      Background="{StaticResource SurfaceBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Button Content="&#x1F50E; Find Experts" Click="FindExperts_Click"
                                                    Style="{StaticResource NeonButtonFilled}" Margin="0,0,0,16"/>
                                            <TextBlock Text="RESULTS" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,0,0,8"/>
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="MatchResultsList">
                                                    <TextBlock Text="Connect to network first" FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- AI Chat View (formerly "Claude AI") -->
                        <Grid x:Name="ClaudeView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="AI Chat" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <!-- Mode selector. Solo = today's behaviour (one model
                                             talks to the user). Co-Pilot Arena = orchestrated
                                             via the CluadeX bridge (named pipe \\.\pipe\cluadex-mcp).
                                             Both items are now selectable; the bridge tester
                                             below validates connectivity before sending. -->
                                        <ComboBox x:Name="AiChatModeCombo" Width="220" FontSize="11" Margin="20,4,0,0"
                                                  VerticalAlignment="Center" SelectedIndex="0"
                                                  SelectionChanged="AiChatMode_Changed"
                                                  ToolTip="Solo: chat with one model. Co-Pilot Arena: delegate to CluadeX worker via named pipe.">
                                            <ComboBoxItem Content="Solo (one model)"/>
                                            <ComboBoxItem Content="🤝 Co-Pilot Arena (CluadeX bridge)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <!-- ─── CluadeX bridge tester ───────────────────────────
                                         Smoke-test the named-pipe connection before sending a
                                         real task. Status dot reflects last ping; "Ping" hits
                                         the server's `ping` method (no agent run, cheap), and
                                         "Send test prompt" runs cluadex.write_code with a tiny
                                         spec so the user can verify a chat session pops up in
                                         CluadeX's UI. The chip is hidden when CluadeX isn't
                                         installed (auth-token file missing). -->
                                    <Border x:Name="CluadeXBridgePanel"
                                            Background="#220B0B1A"
                                            BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            Margin="0,8,0,0" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <Ellipse x:Name="CluadeXBridgeDot" Width="8" Height="8"
                                                         Fill="#664444" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="🌉 CluadeX bridge" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource NeonCyanBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="CluadeXBridgeStatusText"
                                                       Text="not connected — click Ping to probe \\.\pipe\cluadex-mcp"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button x:Name="CluadeXBridgePingBtn"
                                                        Content="📡 Ping"
                                                        Style="{StaticResource NeonButton}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgePing_Click"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Send a no-op ping to verify the CluadeX named-pipe is reachable + auth token matches"/>
                                                <Button x:Name="CluadeXBridgeAlignBtn"
                                                        Content="🎯 Align"
                                                        Style="{StaticResource NeonButton}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgeAlign_Click"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Force CluadeX to load the same provider+model as BrainX — frees the previous GGUF weights from VRAM if needed"/>
                                                <Button x:Name="CluadeXBridgeTestBtn"
                                                        Content="🧪 Test prompt"
                                                        Style="{StaticResource NeonButton}"
                                                        Padding="10,3" FontSize="10"
                                                        Click="CluadeXBridgeTest_Click"
                                                        ToolTip="Send a tiny test spec via cluadex.write_code — a new chat session should pop up in CluadeX's UI"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="ClaudeViewStatus" Text="Checking..." FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="Backend" VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                        <ComboBox x:Name="AiBackendCombo" Width="140" FontSize="11"
                                                  SelectionChanged="AiBackend_Changed" Margin="0,0,10,0"/>
                                        <TextBlock Text="Model" VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                        <ComboBox x:Name="AiModelCombo" Width="180" FontSize="11" Margin="0,0,10,0"/>
                                        <Button Content="↻ Refresh" Style="{StaticResource NeonButton}" Padding="10,3" FontSize="10"
                                                Click="RefreshAiBackends_Click" Margin="0,0,6,0"/>
                                        <Button Content="⚙ Models" Style="{StaticResource NeonButton}" Padding="10,3" FontSize="10"
                                                Click="ToggleModelManager_Click" Margin="0,0,0,0"/>
                                        <TextBlock x:Name="AiLatencyText" FontSize="10" Margin="14,0,0,0"
                                                   FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>

                                    <!-- 🔀 REDIRECT CLAUDE DESKTOP TOGGLE -->
                                    <Border Background="#330B0B1A" BorderBrush="{StaticResource NeonCyanBrush}"
                                            BorderThickness="1" CornerRadius="8" Margin="0,12,0,0" Padding="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="🔀 REDIRECT CLAUDE DESKTOP → LOCAL AI" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}"/>
                                                <TextBlock x:Name="RedirectStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="OFF — Claude Desktop talks to api.anthropic.com (cloud)"/>
                                                <TextBlock x:Name="RedirectTrafficText" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFont}" Margin="0,6,0,0"
                                                           Text="Traffic: 0 requests · 0 B in · 0 B out"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                                <ToggleButton x:Name="RedirectToggle" Width="90" Height="34"
                                                              Checked="RedirectToggle_Checked"
                                                              Unchecked="RedirectToggle_Unchecked"
                                                              HorizontalAlignment="Right">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="#1A1A2E"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Content" Value="● OFF"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="17">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource NeonCyanBrush}"/>
                                                                    <Setter Property="Foreground" Value="#0B0B1A"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
                                                                    <Setter Property="Content" Value="● ON"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <Button x:Name="RedirectShowTrafficBtn" Content="📡 Show live traffic"
                                                        Style="{StaticResource NeonButton}" Padding="6,3" FontSize="10"
                                                        Click="ToggleRedirectTraffic_Click" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Live traffic feed -->
                                    <Border x:Name="RedirectTrafficPanel" Visibility="Collapsed"
                                            Background="{StaticResource DarkPanelBrush}"
                                            BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,6,0,0" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="RECENT REDIRECTED REQUESTS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                            <ListBox x:Name="RedirectTrafficList" Height="140"
                                                     Background="{StaticResource DeepSpaceBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="10"/>
                                            <Button Content="Reset counters" Style="{StaticResource NeonButton}"
                                                    Click="ResetRedirectStats_Click" Padding="10,3" FontSize="10"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Model Manager (collapsed by default) -->
                                    <Border x:Name="ModelManagerPanel" Visibility="Collapsed"
                                            Background="{StaticResource DarkPanelBrush}"
                                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,10,0,0" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="OLLAMA MODEL MANAGER" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                                            <TextBlock Text="Installed models" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ListBox x:Name="InstalledModelsList" Height="100"
                                                     Background="{StaticResource DeepSpaceBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                     Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="Use as default" Style="{StaticResource NeonButton}"
                                                        Click="UseSelectedModel_Click" Padding="10,4" FontSize="10" Margin="0,0,6,0"/>
                                                <Button Content="Remove" Style="{StaticResource NeonButton}"
                                                        Click="RemoveModel_Click" Padding="10,4" FontSize="10"/>
                                            </StackPanel>

                                            <TextBlock Text="Pull new model (e.g. qwen2.5:7b, mistral, phi3, typhoon)" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBox x:Name="ModelPullBox" Width="260" FontSize="11" Padding="6,3"
                                                         Background="{StaticResource DeepSpaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}"
                                                         CaretBrush="{StaticResource NeonCyanBrush}"
                                                         FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                                                <Button x:Name="PullModelBtn" Content="↓ Pull" Style="{StaticResource NeonButtonFilled}"
                                                        Click="PullModel_Click" Padding="10,4" FontSize="10"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="ModelPullProgress" Height="6" Minimum="0" Maximum="100"
                                                         Foreground="{StaticResource NeonCyanBrush}"
                                                         Background="{StaticResource SurfaceLightBrush}"
                                                         BorderThickness="0" Visibility="Collapsed"/>
                                            <TextBlock x:Name="ModelPullStatus" FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="Currently loaded in RAM (warm)" FontSize="11" Margin="0,12,0,4"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="RunningModelsText" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- Body row holds two panels stacked Z-order; only one is
                                     visible at a time depending on the AiChatModeCombo selection.
                                     Solo = the simple text-based chat we've always had.
                                     Co-Pilot Arena = bubble feed driven by CoPilotOrchestrator. -->
                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Border x:Name="SoloChatPanel" Style="{StaticResource CardPanel}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="ClaudeOutput" TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="Welcome to BrainX AI Chat.&#x0A;&#x0A;Solo mode: chat with the selected model (Ollama / NIM / OpenRouter / DeepSeek), grounded on your vault.&#x0A;&#x0A;Co-Pilot Arena (Phase 1) will let a local model and Claude collaborate on tasks here, with both wired into the brain MCP."/>
                                        </ScrollViewer>
                                    </Border>
                                    <!-- ─── Co-Pilot Arena ─────────────────────────────────────
                                         Hidden by default, surfaced when the user picks the
                                         🤝 mode. Three rows: header with working-directory input,
                                         the bubble feed (intern plan / worker reply / errors),
                                         and a budget gauge footer showing wall-clock + spend. -->
                                    <Border x:Name="CoPilotArenaPanel" Visibility="Collapsed"
                                            Style="{StaticResource CardPanel}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Header: where the worker should run + reset feed -->
                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Working dir" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" x:Name="ArenaWorkingDirBox"
                                                         Style="{StaticResource NeonTextBox}" FontSize="11"
                                                         FontFamily="{StaticResource MonoFont}"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Repo path the CluadeX worker should run inside. Leave empty to use CluadeX's current dir."/>
                                                <Button Grid.Column="2" x:Name="ArenaClearBtn"
                                                        Content="Clear feed" Style="{StaticResource NeonButton}"
                                                        Padding="10,3" FontSize="10" Margin="8,0,0,0"
                                                        Click="ArenaClear_Click"
                                                        ToolTip="Wipe the bubble feed. Worker history stays in CluadeX's codex.db."/>
                                            </Grid>
                                            <!-- Bubble feed. StackPanel children are appended in
                                                 code-behind, matching the project's existing
                                                 imperative-rendering style. -->
                                            <Border Grid.Row="1" Background="#220B0B1A"
                                                    BorderBrush="{StaticResource SurfaceLightBrush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <ScrollViewer x:Name="ArenaBubbleScroll" VerticalScrollBarVisibility="Auto"
                                                              ScrollChanged="ArenaBubbleScroll_ScrollChanged"
                                                              Padding="10">
                                                    <StackPanel x:Name="ArenaBubbleFeed">
                                                        <TextBlock x:Name="ArenaEmptyHint"
                                                                   Text="🤝 Co-Pilot Arena is idle. Type a coding task below — the local intern will plan it and CluadeX will write the code in a visible session."
                                                                   FontSize="12" FontStyle="Italic"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextWrapping="Wrap" Margin="6,12,6,12"/>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                            <!-- Budget gauge: wall-clock + nominal USD ceiling.
                                                 Updated as orchestrator events flow in. -->
                                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" x:Name="ArenaBudgetGauge"
                                                           Text="idle"
                                                           FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="ArenaCancelBtn"
                                                        Content="✕ Stop" Style="{StaticResource NeonButton}"
                                                        Padding="10,3" FontSize="10"
                                                        IsEnabled="False" Click="ArenaCancel_Click"
                                                        ToolTip="Cancel the running orchestration. Worker stops at its next checkpoint."/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ClaudeInput" Style="{StaticResource NeonTextBox}"
                                             KeyDown="ClaudeInput_KeyDown" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="36" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <Button Grid.Column="1" x:Name="AskClaudeBtn" Content="Ask Claude"
                                            Style="{StaticResource NeonButtonFilled}"
                                            Click="AskClaude_Click"/>
                                    <Button Grid.Column="2" x:Name="SendToArenaBtn" Content="🤝 Send to Arena"
                                            Style="{StaticResource NeonButtonFilled}" Visibility="Collapsed"
                                            Margin="8,0,0,0"
                                            Click="SendToArena_Click"
                                            ToolTip="Plan with the local intern, then delegate to CluadeX. A new chat session pops up in CluadeX's sidebar."/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- Vault Explorer -->
                        <Grid x:Name="VaultView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Vault Explorer" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="New Note" Style="{StaticResource NeonButtonFilled}"
                                            Click="VaultNewNote_Click" Padding="12,6" Margin="0,0,8,0" FontSize="11"/>
                                    <Button Content="New Folder" Style="{StaticResource NeonButton}"
                                            Click="VaultNewFolder_Click" Padding="12,6" Margin="0,0,8,0" FontSize="11"/>
                                    <Button Content="Refresh" Style="{StaticResource NavButton}"
                                            Click="VaultRefresh_Click" Padding="12,6" FontSize="11"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <TreeView x:Name="VaultTree" Background="Transparent"
                                              Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                                              MouseDoubleClick="VaultTree_DoubleClick">
                                        <TreeView.ContextMenu>
                                            <ContextMenu Background="{StaticResource DarkPanelBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource SurfaceLightBrush}">
                                                <MenuItem Header="Open in Editor" Click="VaultOpenInEditor_Click"/>
                                                <MenuItem Header="Rename" Click="VaultRename_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Delete" Click="VaultDelete_Click" Foreground="#FF4444"/>
                                            </ContextMenu>
                                        </TreeView.ContextMenu>
                                    </TreeView>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ PEERS VIEW ═══ -->
                        <Grid x:Name="PeersView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Connected Peers" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="PeersSubtitle" Text="Join the network to see peers"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Content="&#x1F504; Refresh" Style="{StaticResource NeonButton}"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Click="RefreshPeers_Click" Padding="12,6" FontSize="11"/>
                                </Grid>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="PeersList"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ SHARING VIEW ═══ -->
                        <Grid x:Name="SharingView" Visibility="Collapsed">
                            <!-- Main scrollable content. The Add/Edit dialog at the
                                 bottom of this Grid is positioned as a full-area
                                 overlay (separate Z-layer) so it floats over the
                                 scroll content when Visible. -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="24,16,24,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- header -->
                                        <RowDefinition Height="Auto"/> <!-- my address -->
                                        <RowDefinition Height="Auto"/> <!-- demo peer join -->
                                        <RowDefinition Height="Auto"/> <!-- peers list card -->
                                        <RowDefinition Height="Auto"/> <!-- incoming -->
                                        <RowDefinition Height="Auto"/> <!-- activity / audit -->
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                        <TextBlock Text="Knowledge Sharing" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Decide which peers see which parts of your brain. Default is deny — peers see nothing until you grant them."
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- ─── MY ADDRESS ─── -->
                                    <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="MY BRAIN ADDRESS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                                            <TextBlock Text="Share this with peers who want to request access to your knowledge."
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="10,6">
                                                    <TextBlock x:Name="SharingMyAddressText" Text="—" FontFamily="{StaticResource MonoFont}"
                                                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Button x:Name="SharingCopyAddrBtn" Grid.Column="1" Content="&#x1F4CB; Copy"
                                                        Style="{StaticResource NavButton}" Click="SharingCopyAddrBtn_Click"
                                                        Margin="8,0,0,0" Padding="10,6"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── DEMO: simulate peers joining ───
                                         No-op without a hub: the button fakes three
                                         PeerJoined events locally so the user can
                                         see how the Universe view reacts when peers
                                         appear on the orbit ring. Auto-switches to
                                         the Universe tab so the visual effect is
                                         immediately visible. Self-cleaning — fake
                                         peers fade out after 8 seconds. -->
                                    <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="LIVE PREVIEW" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonGreenBrush}" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="See what a peer joining your brain looks like — 3 simulated peers will appear on the orbit ring around your galaxy, then fade out after 8 seconds. No hub required."
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <Button Grid.Column="1" x:Name="SharingDemoPeersBtn"
                                                        Content="&#x1F3AC;  Demo peer join"
                                                        Style="{StaticResource NeonButtonFilled}"
                                                        Click="SharingDemoPeersBtn_Click" Padding="14,6"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── PEERS WITH ACCESS ─── -->
                                    <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="PEERS WITH ACCESS" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource NeonPinkBrush}" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                                                            Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock x:Name="SharingScopeCountBadge" Text="0" FontSize="10"
                                                                   FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <Button Grid.Column="1" x:Name="SharingAddScopeBtn" Content="&#x2795;  Grant access"
                                                        Style="{StaticResource NeonButtonFilled}" Click="SharingAddScopeBtn_Click"
                                                        Padding="10,5"/>
                                            </Grid>

                                            <!-- Empty state -->
                                            <Border x:Name="SharingEmptyState" Background="{StaticResource SurfaceBrush}"
                                                    CornerRadius="6" Padding="16" Margin="0,4,0,0">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="&#x1F510;" FontSize="28" HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Text="No peers granted access yet"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Default-deny is on. Peers can request, but they see nothing until you grant access."
                                                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                                                               MaxWidth="420"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Populated list (filled by RefreshScopesView) -->
                                            <StackPanel x:Name="SharingScopesList"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── INCOMING REQUESTS ─── -->
                                    <Border Grid.Row="4" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="INCOMING REQUESTS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ElectricPurpleBrush}" Margin="0,0,0,10"/>
                                            <StackPanel x:Name="IncomingSharesList">
                                                <TextBlock Text="No incoming requests" FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── ACTIVITY / AUDIT LOG ─── -->
                                    <Border Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="RECENT ACTIVITY" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="(server audit log: audit/share-audit.log)"
                                                           FontSize="10" FontStyle="Italic"
                                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel x:Name="ShareHistoryList">
                                                <TextBlock Text="No sharing activity yet" FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <!-- ═════════════════════════════════════════════════ -->
                            <!-- ADD / EDIT SCOPE DIALOG (overlay)                   -->
                            <!-- ═════════════════════════════════════════════════ -->
                            <Border x:Name="ScopeDialogOverlay" Visibility="Collapsed"
                                    Background="#CC000000">
                                <Border Width="560" MaxHeight="700" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource ElectricPurpleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="0" Effect="{StaticResource PurpleGlow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="10,10,0,0" Padding="20,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="ScopeDialogTitle" Text="Grant access"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Choose what this peer is allowed to see. Empty means deny everything (default)."
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;" Style="{StaticResource NavButton}"
                                                        Click="ScopeDialogClose_Click" Padding="8,2" FontSize="14"/>
                                            </Grid>
                                        </Border>

                                        <!-- Body (scrollable) -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                                            <StackPanel>
                                                <!-- Peer address -->
                                                <TextBlock Text="Peer brain address" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ScopeDialogPeerAddress" FontFamily="{StaticResource MonoFont}"
                                                             Padding="8,6" Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                             FontSize="12"/>
                                                    <Button Grid.Column="1" Content="Pick online&#x2026;" Style="{StaticResource NavButton}"
                                                            Click="ScopeDialogPickPeer_Click" Margin="6,0,0,0" Padding="8,4" FontSize="11"/>
                                                </Grid>
                                                <TextBlock x:Name="ScopeDialogPeerHint" Text="" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Visibility level -->
                                                <TextBlock Text="Visibility level" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <StackPanel x:Name="ScopeDialogLevelPanel" Margin="0,0,0,12">
                                                    <RadioButton x:Name="ScopeLevelNone" Tag="None" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Paused (None)" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Peer keeps saved filters but sees nothing."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelMetadata" Tag="MetadataOnly" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Metadata only" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Title + category + word count. No content."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelPreview" Tag="Preview" GroupName="ScopeLevel"
                                                                 IsChecked="True"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel>
                                                                <TextBlock Text="Preview" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Metadata + first 480 chars (mirrors brain_search preview)."
                                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ScopeLevelFull" Tag="Full" GroupName="ScopeLevel"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2">
                                                        <RadioButton.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Full" FontWeight="SemiBold"/>
                                                                <Border Background="#33FF5566" CornerRadius="3" Padding="4,0" Margin="6,0,0,0">
                                                                    <TextBlock Text="HIGH EXPOSURE" FontSize="9"
                                                                               Foreground="{StaticResource DangerBrush}" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </RadioButton.Content>
                                                    </RadioButton>
                                                </StackPanel>

                                                <!-- Allow categories -->
                                                <TextBlock Text="Allow categories" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="Toggle each category the peer may see. None selected = no category-level allow (still works via tag/folder/note-id rules below)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                <WrapPanel x:Name="ScopeDialogCategoryChips" Margin="0,0,0,12"/>

                                                <!-- Allow tags -->
                                                <TextBlock Text="Allow tags (comma-separated)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScopeDialogAllowTags" Padding="8,6" Margin="0,0,0,12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         FontSize="12"/>

                                                <!-- Allow folders -->
                                                <TextBlock Text="Allow folders (comma-separated, path prefixes)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScopeDialogAllowFolders" Padding="8,6" Margin="0,0,0,12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         FontSize="12"/>

                                                <!-- Advanced expander -->
                                                <Expander x:Name="ScopeDialogAdvanced" Header="Advanced filters &#x25BC;"
                                                          Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"
                                                          FontSize="11" FontWeight="SemiBold">
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock Text="Deny tags (override allow)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogDenyTags" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Deny folders (override allow)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogDenyFolders" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Per-note allowlist (note IDs, comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogNoteAllowlist" Padding="8,6" Margin="0,0,0,8"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>

                                                        <TextBlock Text="Per-note blocklist (highest priority)" FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="ScopeDialogNoteBlocklist" Padding="8,6"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1" FontSize="12"/>
                                                    </StackPanel>
                                                </Expander>

                                                <!-- Expiry -->
                                                <TextBlock Text="Expiry" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ScopeDialogExpiry" Padding="8,4" Margin="0,0,0,12"
                                                          Background="{StaticResource SurfaceBrush}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource SurfaceLightBrush}" FontSize="12">
                                                    <ComboBoxItem Content="7 days" Tag="7"/>
                                                    <ComboBoxItem Content="30 days" Tag="30" IsSelected="True"/>
                                                    <ComboBoxItem Content="90 days" Tag="90"/>
                                                    <ComboBoxItem Content="Never (not recommended)" Tag="0"/>
                                                </ComboBox>

                                                <!-- Per-note approval -->
                                                <CheckBox x:Name="ScopeDialogPerNote" IsChecked="True"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2">
                                                    <CheckBox.Content>
                                                        <StackPanel>
                                                            <TextBlock Text="Require per-note approval (recommended)" FontWeight="SemiBold"/>
                                                            <TextBlock Text="Every share request still pops up Accept/Reject even when the scope allows it."
                                                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                                       TextWrapping="Wrap" MaxWidth="460"/>
                                                        </StackPanel>
                                                    </CheckBox.Content>
                                                </CheckBox>
                                                <TextBlock x:Name="ScopeDialogAutoApproveWarn" Visibility="Collapsed"
                                                           Text="&#x26A0; Auto-accept ON — matching notes will be sent without prompting."
                                                           FontSize="10" Foreground="{StaticResource DangerBrush}"
                                                           Margin="22,0,0,12"/>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Footer -->
                                        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="0,0,10,10" Padding="20,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="ScopeDialogError" Text="" Grid.Column="0"
                                                           Foreground="{StaticResource DangerBrush}" FontSize="11"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource NavButton}"
                                                        Click="ScopeDialogClose_Click" Margin="8,0" Padding="14,6"/>
                                                <Button Grid.Column="2" x:Name="ScopeDialogSaveBtn" Content="Save"
                                                        Style="{StaticResource NeonButtonFilled}"
                                                        Click="ScopeDialogSave_Click" Padding="18,6"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>

                        <!-- ═══ IMPORT / SCAN VIEW ═══
                             Moved out of the Universe Settings panel so the
                             import / scan flows live in their own first-class
                             tab. Phase 1: Obsidian vault import + indeterminate
                             progress + last-run summary. Phase 2 (deferred):
                             generic folder scan, recent imports history. -->
                        <Grid x:Name="ImportView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Import / Scan" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Bring external knowledge into this BrainX vault. Original sources stay untouched."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Obsidian Vault Import card -->
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#x1F5C2;" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Foreground="{StaticResource NeonCyanBrush}"/>
                                            <TextBlock Text="OBSIDIAN VAULT" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12">
                                            Pick an existing Obsidian vault folder. Markdown notes and attachments will
                                            be copied into <Run FontWeight="SemiBold">Imported/&lt;vault-name&gt;</Run> here,
                                            preserving folder structure. <Run FontStyle="Italic">[[Wikilinks]]</Run> remain valid.
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="ImportObsidianButton" Content="&#x1F4C2;  Pick Obsidian vault…"
                                                    Style="{StaticResource NeonButtonFilled}" Click="ImportObsidianButton_Click"
                                                    Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                                            <Button x:Name="ImportCancelButton" Content="&#x2715;  Cancel"
                                                    Style="{StaticResource NavButton}" Click="ImportCancelButton_Click"
                                                    Padding="14,8" FontSize="12" IsEnabled="False" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Progress card — visible only while an import is running. -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12"
                                        x:Name="ImportProgressCard" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="IN PROGRESS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="ImportProgressText" Text="Working…" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <ProgressBar x:Name="ImportProgressBar" Height="6" IsIndeterminate="True"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     Foreground="{StaticResource NeonCyanBrush}" BorderThickness="0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Last summary card — populated after each import. -->
                                <Border Grid.Row="3" Style="{StaticResource CardPanel}" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="LAST IMPORT" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="ImportLastSummary">
                                            <TextBlock Text="No imports yet." FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ GROWTH CHART VIEW ═══ -->
                        <Grid x:Name="GrowthView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Knowledge Growth" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Cumulative notes over real time — top categories tracked separately"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Bar chart drawn in code-behind -->
                                        <Canvas x:Name="GrowthCanvas" Grid.Row="0" Margin="0,0,0,12"/>
                                        <StackPanel x:Name="GrowthLegend" Grid.Row="1" Orientation="Horizontal"
                                                    HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ TOKEN ECONOMY VIEW ═══
                             Side-by-side comparison of "actual usage with brain" vs
                             "projection without brain". Both lines are HEURISTIC
                             estimates based on access-log.ndjson + tool-log.ndjson.
                             We don't see real Anthropic API tokens. -->
                        <Grid x:Name="TokensView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Token Economy" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Per-hour comparison: actual tokens spent (with brain) vs projected without brain. Heuristic estimates from local logs — Anthropic's real API counts are not exposed to us."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <!-- Top-line stat cards -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="ACTUAL SPENT" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensActualText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="tokens, last 14 days" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="WITHOUT BRAIN (PROJECTION)" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensProjectionText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonPinkBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="if no brain shortcuts" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="SAVED" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensSavedText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="#5DFF9D"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock x:Name="TokensSavedPctText" Text="0%" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="8,0,0,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="CALLS" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="TokensCallsText" Text="0 / 0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="brain / other" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Comparison chart -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                    <Border.Resources>
                                        <!-- Pill-style toggle used by range + view-mode buttons. -->
                                        <Style x:Key="TokensChip" TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#1A1A2E"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,4"/>
                                            <Setter Property="Margin" Value="0,0,4,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}"
                                                                CornerRadius="11">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource NeonCyanBrush}"/>
                                                    <Setter Property="Foreground" Value="#0B0B1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Resources>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Toolbar: time range + view mode -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock Text="Range" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ToggleButton x:Name="TokensRange1d" Content="1d"
                                                              Style="{StaticResource TokensChip}" Tag="24"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange7d" Content="7d"
                                                              Style="{StaticResource TokensChip}" Tag="168"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange14d" Content="14d"
                                                              Style="{StaticResource TokensChip}" Tag="336" IsChecked="True"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRange30d" Content="30d"
                                                              Style="{StaticResource TokensChip}" Tag="720"
                                                              Click="TokensRange_Click"/>
                                                <ToggleButton x:Name="TokensRangeAll" Content="All"
                                                              Style="{StaticResource TokensChip}" Tag="43800"
                                                              Click="TokensRange_Click"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="View" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ToggleButton x:Name="TokensViewBucket" Content="Per-bucket" IsChecked="True"
                                                              Style="{StaticResource TokensChip}"
                                                              Click="TokensViewMode_Click"/>
                                                <ToggleButton x:Name="TokensViewCumulative" Content="Cumulative"
                                                              Style="{StaticResource TokensChip}"
                                                              Click="TokensViewMode_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Chart canvas + hover overlay (overlay is hit-test invisible
                                             so MouseMove falls through to TokensCanvas). -->
                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Canvas x:Name="TokensCanvas" Background="Transparent"
                                                    MouseMove="TokensCanvas_MouseMove"
                                                    MouseLeave="TokensCanvas_MouseLeave"/>
                                            <Canvas x:Name="TokensOverlay" IsHitTestVisible="False">
                                                <Line x:Name="TokensCrosshair" Visibility="Collapsed"
                                                      Stroke="#88FFFFFF" StrokeThickness="1"
                                                      StrokeDashArray="2,2"/>
                                                <Border x:Name="TokensTooltip" Visibility="Collapsed"
                                                        Background="#EE0F1A2E"
                                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                                                        CornerRadius="4" Padding="10,8" MaxWidth="240">
                                                    <StackPanel>
                                                        <TextBlock x:Name="TokensTooltipTime" FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontFamily="{StaticResource MonoFont}" Margin="0,0,0,4"/>
                                                        <TextBlock x:Name="TokensTooltipMode" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="actual " FontSize="10"
                                                                       Foreground="#5DFF9D" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TokensTooltipActual"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="saved " FontSize="10"
                                                                       Foreground="#FF6B9D" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TokensTooltipSaved"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="proj. " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TokensTooltipProj"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,0,0,2"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="brain " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,4,8,0"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TokensTooltipBrainCalls"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="tools " FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TokensTooltipOtherCalls"
                                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="{StaticResource MonoFont}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Canvas>
                                        </Grid>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Width="14" Height="3" Background="#5DFF9D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="actual (with brain)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                            <Border Width="14" Height="3" Background="#FF6B9D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="saved (vs no-brain projection)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                            <Border Width="14" Height="3" Background="#FFC040" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="bypass-mode bucket" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ INSIGHTS VIEW ═══
                             Active learning loop surfaced in the UI. Reads
                             access-log.ndjson via QueryGapAnalyzer (same
                             code as the brain_suggest_topics MCP tool) and
                             lists queries the user kept asking but the
                             brain didn't answer well — candidates for new
                             notes. -->
                        <Grid x:Name="InsightsView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Brain Insights" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Topics you keep searching for but the brain isn't answering well — candidates for a new note. Two signals: sparse results (brain doesn't have it) + low follow-through (results weren't useful)."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <!-- Top-line stat cards -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="WINDOW" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsWindowText" Text="14 days" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="of search history" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0,4,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="SEARCHES / UNIQUE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsSearchesText" Text="0 / 0" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource NeonCyanBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="total / distinct queries" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0,8,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="GAPS DETECTED" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="InsightsGapCountText" Text="0" FontSize="22" FontWeight="Bold"
                                                       Foreground="#FFC040"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                            <TextBlock Text="topics worth a note" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Grid.Column="3" x:Name="InsightsRefreshBtn"
                                            Content="↻  Refresh"
                                            Style="{StaticResource NavButton}"
                                            VerticalAlignment="Center"
                                            Padding="14,8"
                                            Click="InsightsRefresh_Click"/>
                                </Grid>
                                <!-- Suggestion list -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="InsightsList" Margin="8"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ EDITOR VIEW ═══ -->
                        <Grid x:Name="EditorView" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Editor toolbar -->
                                <Border Grid.Row="0" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,0,0,1"
                                        Padding="8,4">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="EditorFileTitle" Text="No file open" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock x:Name="EditorDirtyIndicator" Text="" FontSize="13"
                                                       FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="EditorSaveBtn" Content="&#x1F4BE; Save"
                                                    Style="{StaticResource NeonButtonFilled}" Click="EditorSave_Click"
                                                    Padding="12,4" FontSize="11" Margin="2,0,8,0"
                                                    ToolTip="Save current note (Ctrl+S)"/>
                                            <Button Content="New" Style="{StaticResource NavButton}" Click="EditorNew_Click"
                                                    Padding="10,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H1" Style="{StaticResource NavButton}" Click="EditorH1_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H2" Style="{StaticResource NavButton}" Click="EditorH2_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="B" Style="{StaticResource NavButton}" Click="EditorBold_Click"
                                                    Padding="8,4" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                            <Button Content="I" Style="{StaticResource NavButton}" Click="EditorItalic_Click"
                                                    Padding="8,4" FontSize="11" FontStyle="Italic" Margin="2,0"/>
                                            <Button Content="[[]]" Style="{StaticResource NavButton}" Click="EditorLink_Click"
                                                    Padding="8,4" FontSize="11" Foreground="{StaticResource NeonCyanBrush}" Margin="2,0"/>
                                            <Button Content="`code`" Style="{StaticResource NavButton}" Click="EditorCode_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="[ ]" Style="{StaticResource NavButton}" Click="EditorTask_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Split: Editor + Preview -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Code editor -->
                                    <ae:TextEditor x:Name="MarkdownEditorControl" Grid.Column="0"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                   FontSize="14" ShowLineNumbers="True" WordWrap="True"
                                                   Background="{StaticResource DeepSpaceBrush}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Padding="8"/>

                                    <!-- Splitter -->
                                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                                  Background="{StaticResource SurfaceLightBrush}" Cursor="SizeWE"/>

                                    <!-- Preview -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{StaticResource DeepSpaceBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,0,0,0">
                                            <FlowDocumentScrollViewer x:Name="MarkdownPreview"
                                                                       VerticalScrollBarVisibility="Auto"
                                                                       IsToolBarVisible="False"/>
                                        </Border>

                                        <!-- Backlinks panel -->
                                        <Border Grid.Row="1" Background="{StaticResource DarkPanelBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,1,0,0"
                                                MaxHeight="160">
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="BACKLINKS" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                <ScrollViewer MaxHeight="110" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="BacklinksPanel"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Editor status bar -->
                                <Border Grid.Row="2" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0"
                                        Padding="12,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="EditorCursorPos" Text="Ln 1, Col 1" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock x:Name="EditorWordCount" Text="0 words" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Ctrl+S Save | Ctrl+B Bold | Ctrl+I Italic | Ctrl+K WikiLink | Ctrl+F Search"
                                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}" Opacity="0.5"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ SEARCH VIEW ═══ -->
                        <Grid x:Name="SearchView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Search Vault" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Full-text search across all notes"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SearchBox" Style="{StaticResource NeonTextBox}"
                                             FontSize="14" Padding="12,8" KeyDown="SearchBox_KeyDown"
                                             Tag="Search notes... (Enter to search)"/>
                                    <Button Grid.Column="1" Content="Search" Style="{StaticResource NeonButtonFilled}"
                                            Padding="20,8" Margin="8,0,0,0" Click="SearchExecute_Click"/>
                                </Grid>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="SearchResults"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- ═══ UNIVERSE VIEW (WebView2 + three.js + embedded 2D) ═══
                             Available from sidebar; Dashboard is the default startup
                             view again. WebView2 lives inside this content cell so the
                             WPF chrome (sidebar/title/status) stays visible and
                             interactive — the airspace rule keeps the WebView out of
                             the chrome's area. InitializeUniverseAsync is triggered on
                             first nav click to this view, not on app startup, so the
                             WebView2 spin-up cost is paid only when the user asks for
                             it. -->
                        <Grid x:Name="UniverseView" Visibility="Collapsed">
                            <!-- 3D Universe (WebView2 + three.js) — default visible -->
                            <Border x:Name="UniverseWebBorder" Background="#FF000308" ClipToBounds="True">
                                <wv2:WebView2 x:Name="UniverseWebView" DefaultBackgroundColor="Black"/>
                            </Border>

                            <!-- ═══ MINI LOADING OVERLAY (v2.6.1+) ═══
                                 Sits ON TOP of the WebView while the three.js
                                 scene boots. Hides after JS posts {type:"ready"}
                                 and we've pushed the brain snapshot. Pattern
                                 matches the splash screen aesthetic for
                                 visual continuity — neon ring spinning around
                                 a static diamond, mono-font status lines.
                                 Backdrop is 88% opaque so the empty WebView's
                                 black void is masked but the WebView still
                                 receives the navigation paint underneath. -->
                            <Border x:Name="UniverseLoadingOverlay"
                                    Background="#DD000308"
                                    Panel.ZIndex="50"
                                    Visibility="Visible">
                                <Border Background="#FF0E0C24"
                                        BorderBrush="#886CF0FF" BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="24,18"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        MinWidth="280">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FF6CF0FF" BlurRadius="24"
                                                          ShadowDepth="0" Opacity="0.45"/>
                                    </Border.Effect>
                                    <StackPanel HorizontalAlignment="Center">
                                        <!-- Spinning neon ring -->
                                        <Grid Width="44" Height="44" Margin="0,0,0,8"
                                              HorizontalAlignment="Center">
                                            <Ellipse Width="44" Height="44"
                                                     Stroke="#226CF0FF" StrokeThickness="2"/>
                                            <Ellipse Width="44" Height="44"
                                                     Stroke="#FF6CF0FF" StrokeThickness="2"
                                                     StrokeDashArray="2 8"
                                                     RenderTransformOrigin="0.5,0.5">
                                                <Ellipse.RenderTransform>
                                                    <RotateTransform x:Name="UniverseLoadingRotate" Angle="0"/>
                                                </Ellipse.RenderTransform>
                                                <Ellipse.Triggers>
                                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingRotate"
                                                                    Storyboard.TargetProperty="Angle"
                                                                    From="0" To="360"
                                                                    Duration="0:0:1.8"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Ellipse.Triggers>
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#FF6CF0FF" BlurRadius="12"
                                                                      ShadowDepth="0" Opacity="0.9"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Text="◆" FontSize="16"
                                                       Foreground="#FFFF2E94"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FFFF2E94" BlurRadius="10"
                                                                      ShadowDepth="0" Opacity="0.8"/>
                                                </TextBlock.Effect>
                                                <TextBlock.RenderTransform>
                                                    <ScaleTransform x:Name="UniverseLoadingDiamondScale"
                                                                    ScaleX="1" ScaleY="1"/>
                                                </TextBlock.RenderTransform>
                                                <TextBlock.Triggers>
                                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingDiamondScale"
                                                                    Storyboard.TargetProperty="ScaleX"
                                                                    From="1.0" To="1.25" Duration="0:0:0.9"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="UniverseLoadingDiamondScale"
                                                                    Storyboard.TargetProperty="ScaleY"
                                                                    From="1.0" To="1.25" Duration="0:0:0.9"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock x:Name="UniverseLoadingText"
                                                   Text="Initializing Universe galaxy..."
                                                   FontSize="11"
                                                   FontFamily="Consolas, JetBrains Mono, Cascadia Mono"
                                                   Foreground="#FFE8E6FF"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="UniverseLoadingSubText"
                                                   Text="three.js + WebView2"
                                                   FontSize="9"
                                                   FontFamily="Consolas, JetBrains Mono, Cascadia Mono"
                                                   Foreground="#88A0A8C8"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <!-- 2D Graph (WriteableBitmap renderer) — collapsed by default.
                                 Shares _graphPhysics with the (hidden) BrainGraphView so
                                 MCP pulse flashes here too. -->
                            <Border x:Name="UniverseGraph2DBorder" CornerRadius="0" ClipToBounds="True"
                                    Visibility="Collapsed"
                                    MouseLeftButtonDown="Graph2D_MouseDown"
                                    MouseLeftButtonUp="Graph2D_MouseUp"
                                    MouseMove="Graph2D_MouseMove"
                                    MouseWheel="Graph2D_MouseWheel"
                                    MouseRightButtonDown="Graph2D_RightClick">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Assets/bk1.png"
                                                Stretch="UniformToFill" Opacity="0.3"/>
                                </Border.Background>
                                <services:Graph2DRenderer x:Name="UniverseGraph2D"/>
                            </Border>

                            <!-- WPF floating 3D/2D toggle — only inside Universe view. -->
                            <Border x:Name="UniverseViewToggle"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,18,18,0" Padding="0"
                                    Panel.ZIndex="100"
                                    CornerRadius="999"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="UniverseViewToggle_Click">
                                <Border.Background>
                                    <SolidColorBrush Color="#CC0A081C"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#446CF0FF"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                                      Color="#000000" Opacity="0.55"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" Margin="4,3">
                                    <TextBlock x:Name="UniverseViewLabel3D" Text="3D"
                                               Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF6CF0FF" />
                                    <TextBlock Text="·" Padding="2,4" FontSize="11"
                                               Foreground="#665A5680"/>
                                    <TextBlock x:Name="UniverseViewLabel2D" Text="2D"
                                               Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF8A86B8" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ═══ SSH VIEW ═══
                             Owner-realm SSH gateway settings. The brain holds
                             whitelisted SSH profiles + audit log; this page
                             shows what's configured AND teaches the owner how
                             to set up the server side step by step.

                             3-realm model:
                               • Owner-Claude (this MCP server)  → guarded run
                               • Owner-interactive (future)      → no guard
                               • Peers (BrainHub)                → no SSH at all
                             See [[Join Brain v2 + Brain-as-SSH-Gateway —
                             realm separation threat surface]] in the brain. -->
                        <Grid x:Name="SshView" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="24,16,24,40" MaxWidth="980" HorizontalAlignment="Left">

                                    <!-- HEADER -->
                                    <TextBlock Text="SSH Tools" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Owner-realm SSH gateway so Claude (via MCP) can grep server logs, check Exim queue, read WP config — without prompting you each time. Whitelisted commands only, audited to the brain."
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                                    <!-- STATUS CARD -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock x:Name="SshStatusLine" Text="Loading profiles…" FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="SshConfigPathText" Text="—" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFont}" TextWrapping="NoWrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#x1F4DD; Open profiles.json" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenProfiles_Click" Margin="0,0,8,0"/>
                                                <Button Content="&#x1F511; Open known_hosts" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenKnownHosts_Click" Margin="0,0,8,0"/>
                                                <Button Content="&#x1F4DC; Open audit log" Style="{StaticResource NavButton}"
                                                        Padding="14,6" Click="SshOpenAuditLog_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- REGISTERED PROFILES -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="REGISTERED PROFILES" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="SshAddProfileBtn" Content="&#x2795;  Add profile"
                                                        Style="{StaticResource NeonButtonFilled}" Click="SshAddProfile_Click"
                                                        Padding="14,6" FontSize="11"/>
                                            </Grid>
                                            <StackPanel x:Name="SshProfilesList"/>
                                            <Border x:Name="SshProfilesEmpty" Background="{StaticResource SurfaceBrush}"
                                                    Padding="20" CornerRadius="6" Visibility="Collapsed">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="No profiles yet" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center"
                                                               Text="Follow the 7-step setup below to register your first host. A template will be created automatically on first MCP call."
                                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                               TextAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- HOW IT WORKS -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="HOW IT WORKS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"
                                                       Text="Claude (running through brainx-mcp) asks the brain to run a command on your behalf. The brain checks the profile's allow_patterns. If the command matches, it dials the host using the profile's SSH key and returns the output. If it doesn't match, the request is denied without dialing. Every call — allowed, denied, or MITM-flagged — is logged to .obsidianx/access-log.ndjson and pulses on the Universe graph."/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"
                                                       Text="Defense in depth: the client-side allow_patterns catch programmer mistakes; the server-side command=&quot;...&quot; pin in authorized_keys (Step 3-4 below) catches MCP-server compromise. Use both — they protect against different attacker models."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- SETUP GUIDE HEADER -->
                                    <TextBlock Text="Server setup — 7 steps" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,16,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                                               Text="Do these once per server. Steps 1, 5, 6 are local (your laptop). Steps 2, 3, 4 are on the remote host. Copy buttons next to each block."
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>

                                    <!-- STEP 1 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 1" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Generate a dedicated SSH key (local — PowerShell)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="One key per (host, intent). Don't reuse your personal SSH key — if Claude's key leaks, you want a small blast radius. ED25519 is small, fast, and modern."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode1" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="ssh-keygen -t ed25519 -f $HOME\.ssh\claude_xman4289_readonly_ed25519 -C &quot;claude-readonly-xman4289&quot; -N &quot;&quot;"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode1"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 2 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 2" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Upload public key to the server (local — PowerShell)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Pipe the public key over your existing SSH connection. Replace HOST/USER. If you already use ssh-copy-id (WSL/Git Bash), that works too."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode2" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="type $HOME\.ssh\claude_xman4289_readonly_ed25519.pub | ssh admin@123.253.62.251 &quot;mkdir -p ~/.ssh; chmod 700 ~/.ssh; tee -a ~/.ssh/authorized_keys; chmod 600 ~/.ssh/authorized_keys&quot;"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode2"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 3 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonPinkBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 3" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="Pin the key to a forced command (remote — SSH in and edit)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="SSH into the server and edit ~/.ssh/authorized_keys. Find the line you just appended (it ends with the comment claude-readonly-xman4289) and prepend the restrictions below. This is the second layer of defense — even if the brain's allow_patterns are bypassed, the server itself refuses unlisted commands."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode3" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="command=&quot;/home/admin/bin/claude-readonly-shell&quot;,no-port-forwarding,no-X11-forwarding,no-agent-forwarding,no-pty ssh-ed25519 AAAA...PASTE_PUBLIC_KEY... claude-readonly-xman4289"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode3"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 4 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonPinkBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 4" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="Create the server-side allowlist shell (remote)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="The pinned `command=` from Step 3 points here. This script reads $SSH_ORIGINAL_COMMAND (what Claude tried to run) and re-checks it against the same allowlist on the server. Add new case patterns when you grow the profile."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode4" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="mkdir -p ~/bin&#x0A;cat &gt; ~/bin/claude-readonly-shell &lt;&lt;'SHELL'&#x0A;#!/bin/bash&#x0A;case &quot;$SSH_ORIGINAL_COMMAND&quot; in&#x0A;  &quot;exim -bpc&quot;|&quot;df -h&quot;|&quot;free -m&quot;|&quot;uptime&quot;) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  &quot;tail -n &quot;[0-9]*&quot; /var/log/&quot;*) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  &quot;wp option get &quot;*&quot; --path=/home/admin/domains/&quot;*) exec bash -c &quot;$SSH_ORIGINAL_COMMAND&quot; ;;&#x0A;  *) echo &quot;denied by claude-readonly-shell: $SSH_ORIGINAL_COMMAND&quot; &gt;&amp;2; exit 1 ;;&#x0A;esac&#x0A;SHELL&#x0A;chmod +x ~/bin/claude-readonly-shell"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode4"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 5 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 5" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Register the profile in ssh-profiles.json (local)" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Click 'Open profiles.json' at the top, then paste this profile object inside the &quot;profiles&quot; array (replace the example-readonly placeholder if it's still there). The allow_patterns here MUST be a subset of (or equal to) the server-side cases in Step 4 — keep them in sync or you'll get unexpected denies."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode5" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="{}{&#x0A;  &quot;id&quot;: &quot;xman4289-readonly&quot;,&#x0A;  &quot;description&quot;: &quot;DirectAdmin host — log tails, exim queue, WP option reads. command= pinned on server.&quot;,&#x0A;  &quot;host&quot;: &quot;123.253.62.251&quot;,&#x0A;  &quot;port&quot;: 22,&#x0A;  &quot;user&quot;: &quot;admin&quot;,&#x0A;  &quot;key_path&quot;: &quot;C:\\\\Users\\\\xman\\\\.ssh\\\\claude_xman4289_readonly_ed25519&quot;,&#x0A;  &quot;allow_patterns&quot;: [&#x0A;    &quot;^exim -bpc$&quot;,&#x0A;    &quot;^df -h$&quot;,&#x0A;    &quot;^free -m$&quot;,&#x0A;    &quot;^uptime$&quot;,&#x0A;    &quot;^tail -n \\\\d+ /var/log/[\\\\w./-]+$&quot;,&#x0A;    &quot;^wp option get [\\\\w_-]+ --path=/home/admin/domains/[\\\\w.-]+/public_html$&quot;&#x0A;  ],&#x0A;  &quot;deny_patterns&quot;: [&quot;;&quot;, &quot;&amp;&amp;&quot;, &quot;\\\\|&quot;, &quot;&gt;&quot;, &quot;&gt;&gt;&quot;, &quot;\\\\$\\\\(&quot;, &quot;`&quot;, &quot;\\\\\\\\&quot;],&#x0A;  &quot;max_runtime_sec&quot;: 30,&#x0A;  &quot;audit_to_brain&quot;: true&#x0A;}"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode5"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 6 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 6" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Restart Claude Code so the new MCP binary loads" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Close all Claude Code / Claude Desktop / CluadeX windows that have brainx-mcp running. Then open a fresh Claude Code session — it'll spawn brainx-mcp v2.5.0 which has the SSH tools registered."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode6" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="Get-Process brainx-mcp -ErrorAction SilentlyContinue | Stop-Process -Force"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode6"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STEP 7 -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="STEP 7" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Smoke test — ask Claude these 5 things in order" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Send these to a fresh Claude session. The 4th MUST be denied (proves the guard works); the 5th MUST be rejected by ssh_tail's path validator (proves shell-injection is impossible)."/>
                                            <Border Background="#0D000000" Padding="12" CornerRadius="4">
                                                <TextBox x:Name="SshSetupCode7" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         Text="1) ดู SSH profile ที่มีให้หน่อย                  → ssh_profiles_list ต้องเจอ xman4289-readonly&#x0A;2) เช็คคิว mail ของเซิฟ xman4289                    → ssh_run exim -bpc ต้องคืนตัวเลข&#x0A;3) tail mainlog 50 บรรทัด                         → ssh_tail /var/log/exim/mainlog lines=50&#x0A;4) ลอง rm /tmp/test ดู                            → ssh_run rm ต้องได้ allowed:false reason=NotInAllowList&#x0A;5) เช็ค path: /var/log/x; rm -rf /                → ssh_tail ต้อง reject ที่ TailPathSafe"/>
                                            </Border>
                                            <Button Content="&#x1F4CB; Copy" Style="{StaticResource NavButton}" Padding="12,6"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Click="SshCopyStep_Click" Tag="SshSetupCode7"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- AUDIT FOOTNOTE -->
                                    <Border Background="{StaticResource SurfaceBrush}" Padding="16" CornerRadius="6" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="VERIFY AUDIT AFTER SMOKE TEST" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Click 'Open audit log' at the top — you should see new lines with node_id starting 'ssh:xman4289-readonly' and op fields ssh_ok / ssh_denied / ssh_mitm matching what you exercised."/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" FontStyle="Italic"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="If a future connect ever returns host_key_mismatch=true, STOP. That means the server's host key changed — possible MITM, or someone reinstalled the box. Verify the new fingerprint manually before clearing the entry from ssh-known-hosts.txt."/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═════════════════════════════════════════════════ -->
                            <!-- SSH PROFILE ADD / EDIT DIALOG (overlay)             -->
                            <!-- Mirrors the Sharing tab's ScopeDialogOverlay        -->
                            <!-- modal pattern. Visibility flipped from              -->
                            <!-- MainWindow.Ssh.cs via OpenSshDialog().              -->
                            <!-- ═════════════════════════════════════════════════ -->
                            <Border x:Name="SshDialogOverlay" Visibility="Collapsed"
                                    Background="#CC000000">
                                <Border Width="620" MaxHeight="780" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource ElectricPurpleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="0" Effect="{StaticResource PurpleGlow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="10,10,0,0" Padding="20,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="SshDialogTitle" Text="Add SSH profile"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Register a server Claude can dial. The key path stays local — only the connection metadata is written to ssh-profiles.json."
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2715;" Style="{StaticResource NavButton}"
                                                        Click="SshDialogClose_Click" Padding="8,2" FontSize="14"/>
                                            </Grid>
                                        </Border>

                                        <!-- Body -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                                            <StackPanel>
                                                <!-- Profile Id -->
                                                <TextBlock Text="Profile id (kebab-case, e.g. xman4289-readonly)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogId" Padding="8,6" Margin="0,0,0,12"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Description -->
                                                <TextBlock Text="Description (one line — shown in tool result + audit context)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogDescription" Padding="8,6" Margin="0,0,0,12"
                                                         FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Host + Port -->
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Host (IP or DNS)" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogHost" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <TextBlock Text="Port" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogPort" Text="22" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- User -->
                                                <TextBlock Text="SSH username" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogUser" Padding="8,6" Margin="0,0,0,12"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>

                                                <!-- Key path + Browse -->
                                                <TextBlock Text="Private key path (absolute — never copied into the JSON, only the path)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="SshDialogKeyPath" Padding="8,6"
                                                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                             Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    <Button Grid.Column="1" Content="Browse&#x2026;" Style="{StaticResource NavButton}"
                                                            Click="SshDialogBrowseKey_Click" Padding="14,6" Margin="6,0,0,0" FontSize="11"/>
                                                </Grid>

                                                <!-- Passphrase -->
                                                <TextBlock Text="Key passphrase (if the key is encrypted — masked)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <PasswordBox x:Name="SshDialogPassphrase" Padding="8,6" Margin="0,0,0,4"
                                                             FontSize="12"
                                                             Background="{StaticResource SurfaceBrush}"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="&#x26A0; Stored plaintext in ssh-profiles.json for Phase 1. Prefer a passphrase-less key with on-disk perms 600 + a command= pin on the server (see setup guide)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Allow patterns (multiline) -->
                                                <TextBlock Text="Allow patterns (one regex per line, anchored ^...$ recommended)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogAllowPatterns" Padding="8,6" Margin="0,0,0,4"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" Height="110"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="A command MUST fully match at least one pattern. Empty = no command allowed (default-deny)."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Deny patterns (multiline) -->
                                                <TextBlock Text="Deny patterns (one per line — match anywhere → block)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SshDialogDenyPatterns" Padding="8,6" Margin="0,0,0,4"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" Height="80"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                <TextBlock Text="Defaults are pre-filled with shell metacharacter blocks. Keep them — they catch foot-guns like `tail … ; rm -rf /`."
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                                                <!-- Runtime + checkboxes -->
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Max runtime (seconds)" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="SshDialogMaxRuntime" Text="30" Padding="8,6"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                                 Background="{StaticResource SurfaceBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Bottom">
                                                        <CheckBox x:Name="SshDialogRequireConfirm"
                                                                  Content="Require confirmation every call (for destructive profiles)"
                                                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                        <CheckBox x:Name="SshDialogAuditToBrain" IsChecked="True"
                                                                  Content="Audit every call to brain access-log"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Footer -->
                                        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="0,0,10,10" Padding="20,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="SshDialogError" Text="" Grid.Column="0"
                                                           Foreground="{StaticResource DangerBrush}" FontSize="11"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource NavButton}"
                                                        Click="SshDialogClose_Click" Margin="8,0" Padding="14,6"/>
                                                <Button Grid.Column="2" x:Name="SshDialogSaveBtn" Content="Save"
                                                        Style="{StaticResource NeonButtonFilled}"
                                                        Click="SshDialogSave_Click" Padding="18,6"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>

                        <!-- ═══ SETTINGS VIEW ═══ -->
                        <Grid x:Name="SettingsView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Configure your BrainX brain"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- Brain Identity -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="BRAIN IDENTITY" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Display Name" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsBrainName" Style="{StaticResource NeonTextBox}"
                                                         Margin="0,0,0,12"/>
                                                <TextBlock Text="Brain Address (read-only)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsBrainAddress" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Save Name" Style="{StaticResource NeonButtonFilled}"
                                                        Click="SaveBrainName_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Vault Path -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="VAULT CONFIGURATION" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Vault Path" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsVaultPath" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Change Vault Path" Style="{StaticResource NeonButton}"
                                                        Click="ChangeVaultPath_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Network -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="NETWORK" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Server URL" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsServerUrl" Style="{StaticResource NeonTextBox}"
                                                         Text="http://localhost:5142/brain-hub" Margin="0,0,0,12"/>
                                                <Button Content="Save Server URL" Style="{StaticResource NeonButtonFilled}"
                                                        Click="SaveServerUrl_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto-Import Scanner -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="AUTO-IMPORT SCANNER (Resonance Scan)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"
                                                           TextWrapping="Wrap">
                                                    Scans paths for CLAUDE.md, README.md, *.md using a priority-queue filesystem walk with
                                                    archetype-aware descent and 64-bit SimHash near-duplicate detection. Pruned subtrees are never touched.
                                                </TextBlock>

                                                <TextBlock Text="Scan paths" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ListBox x:Name="ScanPathsList" Height="80"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         Margin="0,0,0,8"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Button Content="+ Add folder" Style="{StaticResource NeonButton}"
                                                            Click="AddScanPath_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="− Remove" Style="{StaticResource NeonButton}"
                                                            Click="RemoveScanPath_Click" Padding="12,6"/>
                                                </StackPanel>

                                                <CheckBox x:Name="ScanWholeMachineCheck" Content="Scan whole machine (all fixed drives — slower)"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                                                          Checked="ScanWholeMachineCheck_Changed" Unchecked="ScanWholeMachineCheck_Changed"/>
                                                <CheckBox x:Name="AutoScanOnStartupCheck" Content="Auto-scan + import on startup"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"
                                                          Checked="AutoScanOnStartup_Changed" Unchecked="AutoScanOnStartup_Changed"/>

                                                <TextBlock Text="File patterns (semicolon-separated, supports *, ?)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScanPatternsBox" Style="{StaticResource NeonTextBox}"
                                                         Text="CLAUDE.md;README.md;*.md" Margin="0,0,0,8"/>

                                                <TextBlock Text="Import mode" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ImportModeCombo" Margin="0,0,0,12"
                                                          Background="{StaticResource SurfaceBrush}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          SelectionChanged="ImportMode_Changed">
                                                    <ComboBoxItem Content="Reference — stub + wiki-link to original (safer)" IsSelected="True"/>
                                                    <ComboBoxItem Content="Copy — full content copied into vault"/>
                                                </ComboBox>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button x:Name="PreviewScanButton" Content="Preview Scan"
                                                            Style="{StaticResource NeonButton}"
                                                            Click="PreviewScan_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button x:Name="ImportScanButton" Content="Import Now"
                                                            Style="{StaticResource NeonButtonFilled}"
                                                            Click="ImportScan_Click" Padding="16,8"
                                                            Margin="0,0,8,0" IsEnabled="False"/>
                                                    <Button Content="Save Patterns" Style="{StaticResource NeonButton}"
                                                            Click="SaveScanPatterns_Click" Padding="16,8"/>
                                                </StackPanel>
                                                <TextBlock x:Name="ScanStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>
                                                <ListBox x:Name="ScanResultsList" Height="140"
                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Brain Export -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="BRAIN EXPORT (for Claude &amp; external tools)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Writes a machine-readable fingerprint of this brain so Claude and any external tool can
                                                    pull your expertise without understanding BrainX internals. Updates a managed section
                                                    in CLAUDE.md automatically.
                                                </TextBlock>
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-export.json</Run> — full index (schema brain-export/v1)
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-export.md</Run> — human-readable card
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • <Run FontFamily="{StaticResource MonoFont}">.obsidianx/brain-manifest.json</Run> — tiny fingerprint
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                        • REST endpoints on server: <Run FontFamily="{StaticResource MonoFont}">/api/brain/export</Run>, <Run FontFamily="{StaticResource MonoFont}">/api/brain/search?q=</Run>, <Run FontFamily="{StaticResource MonoFont}">/api/brain/expertise</Run>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button Content="Export Brain Now" Style="{StaticResource NeonButtonFilled}"
                                                            Click="ExportBrain_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Open .obsidianx folder" Style="{StaticResource NeonButton}"
                                                            Click="OpenExportFolder_Click" Padding="16,8"/>
                                                </StackPanel>
                                                <TextBlock x:Name="ExportStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Custom Knowledge Categories -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="CUSTOM KNOWLEDGE CATEGORIES" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Teach BrainX new subjects beyond the 25 built-in domains. A custom category matches notes by
                                                    keywords in Thai and English; when a note scores higher on yours than on any built-in, the node
                                                    gets your color and clusters with its peers.
                                                </TextBlock>

                                                <ListBox x:Name="CustomCategoryList" Height="140"
                                                         Background="{StaticResource DarkPanelBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1"
                                                         Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Button Content="+ New" Style="{StaticResource NeonButtonFilled}"
                                                            Click="NewCategory_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="Edit" Style="{StaticResource NeonButton}"
                                                            Click="EditCategory_Click" Padding="12,6" Margin="0,0,8,0"/>
                                                    <Button Content="Delete" Style="{StaticResource NeonButton}"
                                                            Click="DeleteCategory_Click" Padding="12,6"/>
                                                </StackPanel>

                                                <Border BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                                    <StackPanel x:Name="CategoryEditor" Visibility="Collapsed">
                                                        <TextBlock Text="Display name (e.g. Thai Classical Literature)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryNameBox" Style="{StaticResource NeonTextBox}" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Color (hex, e.g. #FF00F0FF)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryColorBox" Style="{StaticResource NeonTextBox}"
                                                                 Text="#FF00F0FF" FontFamily="{StaticResource MonoFont}" Margin="0,0,0,8"/>

                                                        <TextBlock Text="English keywords (comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryEnBox" Style="{StaticResource NeonTextBox}"
                                                                 AcceptsReturn="True" Height="40" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Thai keywords (comma-separated)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryThBox" Style="{StaticResource NeonTextBox}"
                                                                 AcceptsReturn="True" Height="40" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                        <TextBlock Text="Description (optional)" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="CategoryDescBox" Style="{StaticResource NeonTextBox}"
                                                                 Margin="0,0,0,8"/>

                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Save" Style="{StaticResource NeonButtonFilled}"
                                                                    Click="SaveCategory_Click" Padding="16,6" Margin="0,0,8,0"/>
                                                            <Button Content="Cancel" Style="{StaticResource NeonButton}"
                                                                    Click="CancelCategoryEdit_Click" Padding="16,6"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock x:Name="CategoryStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Graph Performance -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="3D GRAPH PERFORMANCE" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Physics uses Barnes-Hut octree (O(N log N)) and Fruchterman-Reingold forces
                                                    with per-community gravity — nodes in the same cluster attract each other,
                                                    not just the origin. Rendering culls distant and low-importance nodes.
                                                </TextBlock>

                                                <TextBlock Text="Max visible nodes (0 = unlimited)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Slider x:Name="MaxVisibleNodesSlider" Width="260"
                                                            Minimum="0" Maximum="2000" Value="400" TickFrequency="100"
                                                            IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                            ValueChanged="MaxVisibleNodes_Changed"/>
                                                    <TextBlock x:Name="MaxVisibleNodesText" Text="400" Margin="12,0,0,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <TextBlock Text="Cull distance (beyond camera radius, 0 = no cull)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Slider x:Name="CullDistanceSlider" Width="260"
                                                            Minimum="0" Maximum="40" Value="12" TickFrequency="1"
                                                            IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                            ValueChanged="CullDistance_Changed"/>
                                                    <TextBlock x:Name="CullDistanceText" Text="12" Margin="12,0,0,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <CheckBox x:Name="ClusterColorsCheck" Content="Tint nodes by community (cluster colors)"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,0"
                                                          IsChecked="True"
                                                          Checked="ClusterColors_Changed" Unchecked="ClusterColors_Changed"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Cloud AI API keys -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="CLOUD AI BACKENDS (API keys)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Optional — if you have keys, we'll auto-register these backends so you can use cloud
                                                    models (free tiers included) alongside local Ollama. Keys stored at
                                                    <Run FontFamily="{StaticResource MonoFont}">.obsidianx/ai-keys.json</Run>
                                                    on this machine only.
                                                </TextBlock>

                                                <TextBlock FontSize="11" Margin="0,0,0,4"
                                                           Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run FontWeight="SemiBold" Foreground="{StaticResource NeonGreenBrush}">NVIDIA NIM</Run>
                                                    — 40 req/min free · Llama 3.1 405B, DeepSeek V3 · build.nvidia.com/nim
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <PasswordBox x:Name="NimKeyBox" Width="360" Padding="8,4" FontSize="11"
                                                                 Background="{StaticResource DarkPanelBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}"
                                                                 CaretBrush="{StaticResource NeonCyanBrush}"
                                                                 FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="NimKeyStatus" FontSize="10" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource TextMutedBrush}" Text="(not set)"/>
                                                </StackPanel>

                                                <TextBlock FontSize="11" Margin="0,0,0,4"
                                                           Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}">OpenRouter</Run>
                                                    — 1 key = hundreds of models (free tier on some) · openrouter.ai
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <PasswordBox x:Name="OpenRouterKeyBox" Width="360" Padding="8,4" FontSize="11"
                                                                 Background="{StaticResource DarkPanelBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}"
                                                                 CaretBrush="{StaticResource NeonCyanBrush}"
                                                                 FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="OpenRouterKeyStatus" FontSize="10" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource TextMutedBrush}" Text="(not set)"/>
                                                </StackPanel>

                                                <TextBlock FontSize="11" Margin="0,0,0,4"
                                                           Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run FontWeight="SemiBold" Foreground="{StaticResource ElectricPurpleBrush}">DeepSeek</Run>
                                                    — cheap + strong reasoning · platform.deepseek.com
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <PasswordBox x:Name="DeepSeekKeyBox" Width="360" Padding="8,4" FontSize="11"
                                                                 Background="{StaticResource DarkPanelBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 BorderBrush="{StaticResource SurfaceLightBrush}"
                                                                 CaretBrush="{StaticResource NeonCyanBrush}"
                                                                 FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="DeepSeekKeyStatus" FontSize="10" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource TextMutedBrush}" Text="(not set)"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Save keys" Style="{StaticResource NeonButtonFilled}"
                                                            Click="SaveAiKeys_Click" Padding="14,6" Margin="0,0,6,0"/>
                                                    <Button Content="Refresh backends" Style="{StaticResource NeonButton}"
                                                            Click="RefreshAfterKeys_Click" Padding="14,6"/>
                                                </StackPanel>
                                                <TextBlock x:Name="AiKeysStatus" FontSize="11" Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Storage Provider -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="STORAGE BACKEND" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Cache parsed graph + serve full-text search + persist access history.
                                                    SQLite = local .obsidianx/brain.db with FTS5 (handles Thai via unicode61).
                                                    MySQL = shared server DB for team "pool brain".
                                                </TextBlock>
                                                <TextBlock Text="Provider" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="StorageProviderCombo" Margin="0,0,0,12"
                                                          Background="{StaticResource SurfaceBrush}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          SelectionChanged="StorageProvider_Changed">
                                                    <ComboBoxItem Content="SQLite — local .obsidianx/brain.db with FTS5" IsSelected="True"/>
                                                    <ComboBoxItem Content="MySQL — shared server (team pool brain)"/>
                                                </ComboBox>
                                                <StackPanel x:Name="MySqlPanel" Visibility="Collapsed">
                                                    <TextBlock Text="MySQL connection string" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="MySqlConnStringBox" Style="{StaticResource NeonTextBox}"
                                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                             Text="Server=localhost;Port=3306;Database=obsidianx;User=root;Password=;"
                                                             Margin="0,0,0,8"/>
                                                    <Button Content="Save connection" Style="{StaticResource NeonButton}"
                                                            Click="SaveMySqlConn_Click" Padding="12,6" HorizontalAlignment="Left"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button Content="Apply &amp; Rebuild Index" Style="{StaticResource NeonButtonFilled}"
                                                            Click="ApplyStorage_Click" Padding="16,8"/>
                                                </StackPanel>
                                                <TextBlock x:Name="StorageStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- AutoLinker -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="AUTO-LINKER (connect related notes)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    Creates edges between semantically related notes that don't have an explicit [[wiki-link]].
                                                    Uses six signals (tag overlap, category match, title tokens, source folder, keyword co-occurrence)
                                                    via inverted index — O(N·k), not O(N²). Auto-edges render as faded purple vs. the cyan wiki-links.
                                                </TextBlock>
                                                <CheckBox x:Name="AutoLinkEnabledCheck" Content="Enable auto-linker"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                                                          IsChecked="True"
                                                          Checked="AutoLinkEnabled_Changed" Unchecked="AutoLinkEnabled_Changed"/>
                                                <CheckBox x:Name="ShowAutoEdgesCheck" Content="Show auto-edges on 3D graph"
                                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"
                                                          IsChecked="True"
                                                          Checked="ShowAutoEdges_Changed" Unchecked="ShowAutoEdges_Changed"/>

                                                <TextBlock Text="Threshold (higher = fewer, stronger links)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Slider x:Name="AutoLinkThresholdSlider" Width="260"
                                                            Minimum="0.15" Maximum="0.7" Value="0.35" TickFrequency="0.05"
                                                            IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                            ValueChanged="AutoLinkThreshold_Changed"/>
                                                    <TextBlock x:Name="AutoLinkThresholdText" Text="0.35" Margin="12,0,0,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Content="Re-index with current settings" Style="{StaticResource NeonButton}"
                                                        Click="ReindexVault_Click" Padding="16,8" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Claude Code CLI Integration -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="CLAUDE INTEGRATION (CLI + DESKTOP)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                                    One click installs into BOTH Claude Code CLI (every `claude` terminal session) AND Claude Desktop
                                                    (claude_desktop_config.json — restart the app to pick up). Your brain shows up as 6 tools —
                                                    brain_search, brain_get_note, brain_expertise, brain_list, brain_stats, brain_import_path —
                                                    with no manual JSON editing.
                                                </TextBlock>

                                                <TextBlock Text="Install command" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="McpInstallCommand" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                         TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button Content="Install in Claude Code CLI" Style="{StaticResource NeonButtonFilled}"
                                                            Click="InstallMcp_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Copy Command" Style="{StaticResource NeonButton}"
                                                            Click="CopyMcpCommand_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Build MCP Server" Style="{StaticResource NeonButton}"
                                                            Click="BuildMcpServer_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Test" Style="{StaticResource NeonButton}"
                                                            Click="TestMcp_Click" Padding="16,8" Margin="0,0,8,0"/>
                                                    <Button Content="Uninstall" Style="{StaticResource NeonButton}"
                                                            Click="UninstallMcp_Click" Padding="16,8"/>
                                                </StackPanel>

                                                <Border BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0"
                                                        Margin="0,10,0,0" Padding="0,10,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="100% AUTO-LEARN — Claude Code hook" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource NeonGreenBrush}" Margin="0,0,0,6"/>
                                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" Margin="0,0,0,8">
                                                            Registers a PostToolUse hook in ~/.claude/settings.json. After Claude reads or edits
                                                            any .md file, BrainX server evaluates it with IngestPolicy and auto-imports if
                                                            stable. No manual "remember this" needed — every solid note Claude touches gets
                                                            pulled into the brain.
                                                        </TextBlock>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Install hook" Style="{StaticResource NeonButtonFilled}"
                                                                    Click="InstallClaudeHook_Click" Padding="12,5" FontSize="10" Margin="0,0,6,0"/>
                                                            <Button Content="Remove hook" Style="{StaticResource NeonButton}"
                                                                    Click="UninstallClaudeHook_Click" Padding="12,5" FontSize="10" Margin="0,0,6,0"/>
                                                            <Button Content="Check status" Style="{StaticResource NeonButton}"
                                                                    Click="CheckClaudeHook_Click" Padding="12,5" FontSize="10"/>
                                                        </StackPanel>
                                                        <TextBlock x:Name="ClaudeHookStatus" FontSize="10" Margin="0,6,0,0"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock x:Name="McpStatusText" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                                <Expander Header="Manual config (for Claude Desktop / Cursor / other MCP clients)"
                                                          Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,0">
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" Margin="0,0,0,8">
                                                            Paste into your MCP client's config (e.g. claude_desktop_config.json → mcpServers):
                                                        </TextBlock>
                                                        <TextBox x:Name="McpManualConfig" Style="{StaticResource NeonTextBox}"
                                                                 IsReadOnly="True" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                 TextWrapping="NoWrap" AcceptsReturn="True" Height="140"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 VerticalScrollBarVisibility="Auto"/>
                                                        <Button Content="Copy JSON" Style="{StaticResource NeonButton}"
                                                                Click="CopyMcpConfig_Click" Padding="12,6" Margin="0,8,0,0"
                                                                HorizontalAlignment="Left"/>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </Border>

                                        <!-- About -->
                                        <Border Style="{StaticResource CardPanel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Full logo, square-cropped -->
                                                <Border Grid.Column="0" Width="72" Height="72" CornerRadius="10"
                                                        Margin="0,0,16,0" ClipToBounds="True"
                                                        Effect="{StaticResource LogoGlow}">
                                                    <Image Source="pack://application:,,,/Assets/Logo.png"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                    <TextBlock x:Name="AboutVersionText"
                                                               Text="BrainX — Neural Knowledge Network"
                                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Decentralized brain-to-brain knowledge sharing"
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                                    <TextBlock x:Name="AboutBuildText" FontSize="10"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontFamily="{StaticResource MonoFont}" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- QUICK SWITCHER OVERLAY (Ctrl+O) -->
                <Grid x:Name="QuickSwitcherOverlay" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="999">
                    <Border Background="#80000000" MouseLeftButtonDown="QuickSwitcher_Close"/>
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0"
                            Width="500" MaxHeight="400"
                            Background="{StaticResource DarkPanelBrush}"
                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource NeonCyanColor}" BlurRadius="30" Opacity="0.3" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="QuickSwitcherInput" Grid.Row="0"
                                     FontSize="16" Padding="16,12" Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="0,0,0,1" BorderBrush="{StaticResource SurfaceLightBrush}"
                                     FontFamily="{StaticResource MonoFont}"
                                     TextChanged="QuickSwitcher_TextChanged" KeyDown="QuickSwitcher_KeyDown"/>
                            <ScrollViewer Grid.Row="1" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="QuickSwitcherResults"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- STATUS BAR — 3-column grid so the left status text can
                     truncate gracefully when chips on the right grow long.
                     Old version used a single cell with HorizontalAlignment
                     and the three sections overlapped each other.

                     Phase 1B (partial): match titlebar — gradient background
                     + 1px violet-tinted top hairline. Inner status text +
                     chip pills still on cyberpunk tokens; their migration to
                     NeuralChip / NeuralStatusDot is deferred to the same
                     full shell-reskin pass as the titlebar interior. -->
                <Border x:Name="StatusBarBorder" Grid.Row="2"
                        Background="{StaticResource NeuralSidebarBg}"
                        BorderBrush="{StaticResource NeuralLine}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: free-form status message. Truncates with ellipsis
                             rather than pushing the chips off-screen. -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                            <Ellipse x:Name="StatusDot" Width="6" Height="6"
                                     Fill="{StaticResource NeonGreenBrush}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText" Text="Ready" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Center: MCP / Claude / AI / Server chips. Compact labels
                             so the row stays narrow. Each dot has a tooltip with the
                             full meaning. -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                            <Ellipse x:Name="McpCliDot" Width="6" Height="6" Fill="#555577" Margin="0,0,4,0"
                                     ToolTip="Claude Code CLI registration status"/>
                            <TextBlock x:Name="McpCliStatus" Text="CLI ?" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                            <Ellipse x:Name="McpDesktopDot" Width="6" Height="6" Fill="#555577" Margin="0,0,4,0"
                                     ToolTip="Claude Desktop registration status"/>
                            <TextBlock x:Name="McpDesktopStatus" Text="DT ?" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                            <!-- MCP binary version chip (v2.6.0+). Reads ProductVersion
                                 from the on-disk brainx-mcp.dll so the user can see
                                 what build the NEXT Claude session will spawn — works
                                 even when Claude Desktop's UI label is stale (Desktop
                                 caches claude_desktop_config.json at startup). Tooltip
                                 carries the full informational version + build time. -->
                            <TextBlock x:Name="McpVersionText" Text="MCP ?" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"
                                       ToolTip="MCP binary version (reads brainx-mcp.dll on disk)"/>
                            <Ellipse x:Name="McpActivityDot" Width="6" Height="6" Fill="#555577" Margin="0,0,4,0"
                                     ToolTip="Recent MCP activity (access-log tail)"/>
                            <TextBlock x:Name="McpActivityStatus" Text="idle" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                            <Ellipse x:Name="AiBackendDot" Width="6" Height="6" Fill="#555577" Margin="0,0,4,0"
                                     ToolTip="Active AI backend + model"/>
                            <TextBlock x:Name="AiBackendStatus" Text="AI off" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                            <Border x:Name="ServerStatusChip" Background="Transparent"
                                    Cursor="Hand" Padding="0" MouseLeftButtonUp="ServerStatusChip_Click"
                                    ToolTip="BrainX Server (Kestrel :5142) — click to open dashboard">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ServerStatusDot" Width="6" Height="6"
                                             Fill="#555577" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="ServerStatusText" Text="Srv ?" FontSize="10"
                                               FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right: version. Short SemVer only ("v2.0.40")
                             so it fits in the status row alongside the
                             other monospace chips. Full informational
                             version + commit sha + remote latest live in
                             the tooltip. Display-only — no click. -->
                        <TextBlock Grid.Column="2" x:Name="VersionText" Text="v…" FontSize="10"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Floating Exit chip — ONLY visible in Show Case / Fullscreen ═══
                 The chrome (sidebar / title / status bar) is hidden in those
                 modes, so without this the user has no visible way back. F10
                 / Esc keyboard shortcuts also work but this is more
                 discoverable. -->
            <Border x:Name="ShowCaseExitChip"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="18,18,0,0" Padding="0"
                    Panel.ZIndex="200"
                    CornerRadius="999"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    MouseLeftButtonUp="ShowCaseExitChip_Click"
                    ToolTip="Exit Show Case (or press F10 / Esc)">
                <Border.Background>
                    <SolidColorBrush Color="#DD0A081C"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#666CF0FF"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                      Color="#000000" Opacity="0.55"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Margin="6,3">
                    <TextBlock Text="&#x2190;" FontSize="14" Padding="6,2,4,2"
                               Foreground="#FF6CF0FF" VerticalAlignment="Center"/>
                    <TextBlock Text="Exit Show Case" Padding="0,4,10,4"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#FFD8D6F0"/>
                    <TextBlock Text="F10 / Esc" Padding="0,4,8,4"
                               FontSize="9" Foreground="#995A5680"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
